{"id":253,"name":"wavespeed","entries":[{"identifier":"609fc016-ae74-457c-84ed-71b4a2b939b0","name":"WaveSpeed气泡外生图","findRegex":"<imagine>([\\s\\S]*?)<\\/imagine>","replaceString":"<div style=\"width:0;height:0;opacity:0;overflow:hidden;\"></div>\n<script>\n(async function () {\n  const WAVESPEED_API_KEY = 'wsk_live_MZxXCtuAuxTbG6B7rBoexb3Z0I6bx1l_nMBoA9aaeGk';\n  const WAVESPEED_MODEL = 'stability-ai/stable-diffusion-3.5-large-turbo';\n  const IMAGINE_PREFIX = '';\n\n  const lastMsg = (await tavo.message.find(-1))[0];\n  if (!lastMsg) return;\n\n  const match = lastMsg.content.match(/<imagine>([\\s\\S]*?)<\\/imagine>/i);\n  if (!match) return;\n  const captured = match[1].trim();\n\n  const cached = tavo.get('imagine-cache-ws');\n  if (captured === cached) return;\n  tavo.set('imagine-cache-ws', captured);\n\n  const fullPrompt = IMAGINE_PREFIX + captured;\n\n  // 步骤1：提交生图任务\n  let taskId;\n  try {\n    const submitRes = await fetch(\n      `https://api.wavespeed.ai/api/v3/${WAVESPEED_MODEL}`,\n      {\n        method: 'POST',\n        headers: {\n          'Authorization': `Bearer ${WAVESPEED_API_KEY}`,\n          'Content-Type': 'application/json'\n        },\n        body: JSON.stringify({\n          prompt: fullPrompt,\n          size: '1024*1024',\n          num_inference_steps: 28,\n          guidance_scale: 3.5,\n          num_images: 1,\n          output_format: 'jpeg',\n          enable_sync_mode: false\n        })\n      }\n    );\n    const submitData = await submitRes.json();\n    taskId = submitData?.data?.id;\n    if (!taskId) {\n      console.error('[wavespeed] 提交失败', JSON.stringify(submitData));\n      return;\n    }\n    console.log('[wavespeed] 任务已提交 id=' + taskId);\n  } catch (e) {\n    console.error('[wavespeed] 提交异常', e.message);\n    return;\n  }\n\n  // 步骤2：轮询结果，最多等60秒\n  let imgUrl = null;\n  for (let i = 0; i < 30; i++) {\n    await new Promise(r => setTimeout(r, 2000));\n    try {\n      const pollRes = await fetch(\n        `https://api.wavespeed.ai/api/v3/predictions/${taskId}/result`,\n        {\n          headers: { 'Authorization': `Bearer ${WAVESPEED_API_KEY}` }\n        }\n      );\n      const pollData = await pollRes.json();\n      const status = pollData?.data?.status;\n      console.log('[wavespeed] 轮询 ' + i + ' status=' + status);\n      if (status === 'completed') {\n        imgUrl = pollData?.data?.outputs?.[0];\n        break;\n      } else if (status === 'failed') {\n        console.error('[wavespeed] 生成失败', JSON.stringify(pollData));\n        return;\n      }\n    } catch (e) {\n      console.error('[wavespeed] 轮询异常', e.message);\n    }\n  }\n\n  if (!imgUrl) {\n    console.error('[wavespeed] 超时，未拿到图片');\n    return;\n  }\n\n  console.log('[wavespeed] 图片URL=' + imgUrl);\n\n  // 步骤3：发到输入框展示（气泡外）\n  tavo.input.set(`<img src=\"${imgUrl}\" style=\"max-width:100%;border-radius:8px;\" />`);\n  tavo.input.send();\n\n})();\n</script>","trimStrings":[],"placements":["char"],"timing":"display","substitution":"none","minDepth":null,"maxDepth":0,"enabled":true}]}