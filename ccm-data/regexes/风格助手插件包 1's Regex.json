{"id":277,"name":"风格助手插件包 1's Regex","entries":[{"identifier":"87602ecd-359f-4b7a-9fa4-abf8ba070171","name":"风格助手启动","findRegex":"$","replaceString":"<script>\n(function(){\ntry{\n  var T; try{T=window.top||window}catch(_){T=window}\n  var D=T.document||document;\n  var KEY='sp5_booted';\n  if(T[KEY])return;\n  T[KEY]=true;\n\n  /* ── 全局样式 ── */\n  var css=D.createElement('style');\n  css.textContent=[\n    /* 工具栏容器：插入到DOM里，不浮动，自然占位 */\n    '#sp-bar-wrap{',\n      'width:100%;display:flex;justify-content:center;',\n      'padding:6px 0 4px;',\n      'background:rgba(14,14,26,0.0);', /* 透明背景，融入页面 */\n      'flex-shrink:0;',\n    '}',\n    '#sp-bar{',\n      'display:inline-flex;align-items:center;gap:5px;',\n      'padding:6px 12px;border-radius:40px;',\n      'background:rgba(20,20,36,0.85);border:1px solid rgba(255,255,255,0.09);',\n      'backdrop-filter:blur(10px);box-shadow:0 2px 12px rgba(0,0,0,0.35);',\n    '}',\n    '#sp-bar .sp-b{width:32px;height:32px;border-radius:50%;border:none;cursor:pointer;font-size:15px;background:rgba(255,255,255,0.07);color:#fff;display:flex;align-items:center;justify-content:center;transition:background .15s,transform .12s;}',\n    '#sp-bar .sp-b:hover{background:rgba(255,255,255,0.16);transform:scale(1.1);}',\n    '#sp-bar .sp-b.on{background:rgba(130,80,255,0.55);}',\n    '#sp-bar .sp-sep{width:1px;height:20px;background:rgba(255,255,255,0.13);margin:0 2px;}',\n    /* 弹窗：固定在屏幕，在工具栏wrap正上方 */\n    '#sp-mask{position:fixed;inset:0;z-index:8999;background:transparent;}',\n    '#sp-pop{position:fixed;left:50%;transform:translateX(-50%);z-index:9001;background:rgba(16,16,32,0.97);border:1px solid rgba(130,80,255,0.35);border-radius:18px;padding:18px;width:290px;max-width:88vw;box-shadow:0 10px 40px rgba(0,0,0,0.65);max-height:60vh;overflow-y:auto;}',\n    '#sp-pop .sp-title{color:#c4b5fd;font-size:13px;font-weight:700;margin-bottom:12px;}',\n    '.sp-pi{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:10px;border:1.5px solid rgba(255,255,255,0.07);background:rgba(255,255,255,0.04);color:#e2e8f0;font-size:12px;width:100%;text-align:left;cursor:pointer;margin-bottom:6px;transition:background .12s,border-color .12s;}',\n    '.sp-pi:hover{background:rgba(130,80,255,0.15);}',\n    '.sp-pi.sel{background:rgba(130,80,255,0.28);border-color:rgba(130,80,255,0.8);}',\n    '.sp-eff-wrap{margin-top:12px;}',\n    '.sp-eff-lbl{color:#94a3b8;font-size:11px;margin-bottom:7px;}',\n    '.sp-eff-row{display:flex;gap:7px;}',\n    '.sp-eb{width:40px;height:40px;border-radius:10px;border:1.5px solid rgba(255,255,255,0.09);background:rgba(255,255,255,0.05);font-size:17px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .12s;}',\n    '.sp-eb:hover,.sp-eb.on{background:rgba(130,80,255,0.28);border-color:rgba(130,80,255,0.6);}',\n    '#sp-go{width:100%;margin-top:14px;padding:11px;border:none;border-radius:10px;background:linear-gradient(135deg,#8b5cf6,#6366f1);color:#fff;font-size:13px;font-weight:700;cursor:pointer;}',\n    '#sp-go:disabled{opacity:.55;cursor:not-allowed;}',\n    '#sp-toast{position:fixed;top:60px;left:50%;transform:translateX(-50%);background:rgba(20,20,40,0.95);color:#e2e8f0;padding:9px 18px;border-radius:20px;font-size:13px;z-index:10000;border:1px solid rgba(130,80,255,0.3);opacity:0;transition:opacity .25s;pointer-events:none;white-space:nowrap;}',\n    '#sp-toast.show{opacity:1;}',\n    '#sp-ov{position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:99999;overflow:hidden;}',\n    '@keyframes sp-fall{0%{opacity:1;transform:translateY(0) rotate(0)}100%{opacity:0;transform:translateY(100vh) rotate(540deg)}}',\n    '@keyframes sp-burst{0%{opacity:1;transform:scale(0)}100%{opacity:0;transform:scale(4)}}',\n  ].join('');\n  D.head.appendChild(css);\n\n  var STYLES=[\n    {id:\"funny\",e:\"\\ud83d\\ude02\",n:\"\\u641e\\u7b11\\u98ce\",p:\"\\u8bf7\\u628a\\u4e0a\\u4e00\\u6bb5\\u5bf9\\u8bdd\\u5185\\u5bb9\\u7528\\u641e\\u7b11\\u5e7d\\u9ed8\\u7684\\u98ce\\u683c\\u91cd\\u65b0\\u6f14\\u7ece\\uff0c\\u53ef\\u4ee5\\u52a0\\u5165\\u7f51\\u7edc\\u6897\\u3001\\u8c10\\u97f3\\u6897\\u3001\\u610f\\u60f3\\u4e0d\\u5230\\u7684\\u53cd\\u8f6c\\uff0c\\u8ba9\\u6c14\\u6c1b\\u8f7b\\u677e\\u7206\\u7b11\\u3002\"},\n    {id:\"horror\",e:\"\\ud83d\\udc7b\",n:\"\\u6050\\u6016\\u98ce\",p:\"\\u8bf7\\u628a\\u4e0a\\u4e00\\u6bb5\\u5bf9\\u8bdd\\u7528\\u60ac\\u7591\\u60ca\\u609a\\u7684\\u98ce\\u683c\\u91cd\\u65b0\\u6f14\\u7ece\\uff0c\\u52a0\\u5165\\u7ec6\\u601d\\u6781\\u6050\\u7684\\u7ec6\\u8282\\u3001\\u4ee4\\u4eba\\u4e0d\\u5b89\\u7684\\u8f6c\\u6298\\uff0c\\u7ed3\\u5c3e\\u7559\\u4e0b\\u60ac\\u5ff5\\u6216\\u51b7\\u610f\\u3002\"},\n    {id:\"sweet\",e:\"\\ud83c\\udf38\",n:\"\\u751c\\u5ba0\\u98ce\",p:\"\\u8bf7\\u628a\\u4e0a\\u4e00\\u6bb5\\u5bf9\\u8bdd\\u7528\\u8d85\\u9ad8\\u751c\\u5ea6\\u7684\\u751c\\u5ba0\\u98ce\\u683c\\u91cd\\u65b0\\u6f14\\u7ece\\uff0c\\u89d2\\u8272\\u5bf9\\u7528\\u6237\\u6781\\u5ea6\\u6e29\\u67d4\\u4f53\\u8d34\\uff0c\\u5145\\u6ee1\\u7231\\u610f\\u548c\\u7ec6\\u817b\\u7684\\u5c0f\\u52a8\\u4f5c\\u3002\"},\n    {id:\"epic\",e:\"\\u2694\\ufe0f\",n:\"\\u53f2\\u8bd7\\u98ce\",p:\"\\u8bf7\\u628a\\u4e0a\\u4e00\\u6bb5\\u5bf9\\u8bdd\\u7528\\u5b8f\\u5927\\u53d9\\u4e8b\\u7684\\u53f2\\u8bd7\\u98ce\\u683c\\u91cd\\u65b0\\u6f14\\u7ece\\uff0c\\u628a\\u666e\\u901a\\u7684\\u4e8b\\u5199\\u51fa\\u547d\\u8fd0\\u611f\\u548c\\u5386\\u53f2\\u539a\\u91cd\\u611f\\uff0c\\u5145\\u6ee1\\u58ee\\u9614\\u7684\\u610f\\u8c61\\u3002\"},\n    {id:\"cat\",e:\"\\ud83d\\udc31\",n:\"\\u732b\\u732b\\u98ce\",p:\"\\u8bf7\\u628a\\u4e0a\\u4e00\\u6bb5\\u5bf9\\u8bdd\\u7528\\u53ef\\u7231\\u732b\\u5a18/\\u5e7c\\u6001\\u98ce\\u683c\\u91cd\\u65b0\\u6f14\\u7ece\\uff0c\\u89d2\\u8272\\u8bf4\\u8bdd\\u65b9\\u5f0f\\u8f6f\\u840c\\u788e\\u788e\\u5ff5\\uff0c\\u52a0\\u5165\\u55b5\\u55b5\\u7b49\\u732b\\u54aa\\u5143\\u7d20\\u3002\"},\n    {id:\"deep\",e:\"\\ud83c\\udf0a\",n:\"\\u6df1\\u60c5\\u98ce\",p:\"\\u8bf7\\u628a\\u4e0a\\u4e00\\u6bb5\\u5bf9\\u8bdd\\u7528\\u514b\\u5236\\u53c8\\u6d53\\u70c8\\u7684\\u6df1\\u60c5\\u98ce\\u683c\\u91cd\\u65b0\\u6f14\\u7ece\\uff0c\\u5927\\u91cf\\u5185\\u5fc3\\u72ec\\u767d\\uff0c\\u60c5\\u611f\\u538b\\u6291\\u5728\\u5b57\\u91cc\\u884c\\u95f4\\uff0c\\u6b32\\u8a00\\u53c8\\u6b62\\u3002\"},\n    {id:\"chaos\",e:\"\\ud83e\\udd21\",n:\"\\u6574\\u6d3b\\u98ce\",p:\"\\u8bf7\\u628a\\u4e0a\\u4e00\\u6bb5\\u5bf9\\u8bdd\\u7528\\u5b8c\\u5168\\u8352\\u8bde\\u7684\\u6574\\u6d3b\\u98ce\\u683c\\u91cd\\u65b0\\u6f14\\u7ece\\uff0c\\u53ef\\u4ee5\\u6253\\u7834\\u7b2c\\u56db\\u5835\\u5899\\uff0c\\u52a0\\u5165\\u5b8c\\u5168\\u8131\\u8f68\\u7684\\u795e\\u5c55\\u5f00\\u3002\"},\n    {id:\"power\",e:\"\\ud83d\\udd25\",n:\"\\u723d\\u6587\\u98ce\",p:\"\\u8bf7\\u628a\\u4e0a\\u4e00\\u6bb5\\u5bf9\\u8bdd\\u7528\\u723d\\u6587\\u98ce\\u683c\\u91cd\\u65b0\\u6f14\\u7ece\\uff0c\\u4e3b\\u89d2\\u5149\\u73af\\u5168\\u5f00\\uff0c\\u5f3a\\u52bf\\u53cd\\u8f6c\\uff0c\\u6253\\u8138\\u6253\\u5f97\\u54cd\\u4eae\\uff0c\\u70ed\\u8840\\u71c3\\u5230\\u6781\\u70b9\\u3002\"},\n  ];\n  var EFFECTS=[\n    {id:'flower',  e:'🎉',n:'撒花'},\n    {id:'firework',e:'🎆',n:'烟花'},\n    {id:'snow',    e:'❄️',n:'飘雪'},\n    {id:'stars',   e:'💫',n:'星星雨'},\n  ];\n  var ST={style:null,pos:'replace_last',effect:null};\n\n  function rnd(){return Math.random();}\n  function mk(t,a,p){var e=D.createElement(t);Object.keys(a||{}).forEach(function(k){e[k]=a[k]});if(p)p.appendChild(e);return e;}\n  function rm(el){el&&el.parentNode&&el.parentNode.removeChild(el);}\n\n  function toast(msg,dur){\n    var el=D.getElementById('sp-toast')||mk('div',{id:'sp-toast'},D.body);\n    el.textContent=msg;el.classList.add('show');\n    clearTimeout(el._t);\n    el._t=setTimeout(function(){el.classList.remove('show');},dur||2500);\n  }\n\n  function fx(id){\n    var ov=D.getElementById('sp-ov')||mk('div',{id:'sp-ov'},D.body);\n    ov.innerHTML='';\n    if(id==='firework'){\n      for(var i=0;i<12;i++)(function(){\n        var p=mk('div',{},ov),sz=40+rnd()*90,c=['#ff6b6b','#ffd93d','#6bcb77','#4d96ff','#c77dff'][~~(rnd()*5)];\n        p.style.cssText='position:absolute;width:'+sz+'px;height:'+sz+'px;border-radius:50%;border:3px solid '+c+';left:'+rnd()*90+'vw;top:'+rnd()*80+'vh;animation:sp-burst '+(0.4+rnd()*0.5)+'s '+(rnd()*0.8)+'s ease-out forwards';\n        setTimeout(function(){rm(p)},2500);\n      })();\n    } else {\n      var C={flower:['#ff6b6b','#ffd93d','#6bcb77','#4d96ff','#c77dff'],snow:['#e0f2fe','#bae6fd','#fff']};\n      var col=C[id]||C.flower;\n      for(var j=0;j<80;j++)(function(){\n        var p=mk('div',{},ov),dur=1.8+rnd()*2.5;\n        if(id==='stars'){p.textContent=['⭐','✨','💫'][~~(rnd()*3)];p.style.cssText='position:absolute;font-size:'+(10+rnd()*14)+'px';}\n        else{var sz2=id==='snow'?(4+rnd()*7):(6+rnd()*10);p.style.cssText='position:absolute;width:'+sz2+'px;height:'+sz2+'px;background:'+col[~~(rnd()*col.length)]+';border-radius:'+(id==='flower'?'50% 0 50% 0':'50%');}\n        p.style.left=rnd()*100+'vw';p.style.top='-30px';\n        p.style.animation='sp-fall '+dur+'s '+(rnd()*1.5)+'s linear forwards';\n        setTimeout(function(){rm(p)},(dur+2)*1000);\n      })();\n    }\n    setTimeout(function(){ov.innerHTML='';},6000);\n  }\n\n  /* ── 弹窗 ── */\n  function closePop(){rm(D.getElementById('sp-mask'));rm(D.getElementById('sp-pop'));}\n\n  function openPop(s){\n    ST.style=s;ST.pos='replace_last';ST.effect=null;\n    closePop();\n    var mask=mk('div',{id:'sp-mask'},D.body);\n    mask.addEventListener('click',function(){\n      closePop();\n      D.querySelectorAll('#sp-bar .sp-b').forEach(function(b){b.classList.remove('on');});\n    });\n    // 弹窗定位：在工具栏wrap正上方\n    var wrap=D.getElementById('sp-bar-wrap');\n    var wRect=wrap?wrap.getBoundingClientRect():{top:T.innerHeight-100};\n    var popMaxH=Math.min(T.innerHeight*0.6,440);\n    var top=wRect.top-popMaxH-8;\n    if(top<8)top=8;\n\n    var pop=mk('div',{id:'sp-pop'},D.body);\n    pop.style.top=top+'px';pop.style.maxHeight=popMaxH+'px';\n\n    var title=mk('div',{className:'sp-title'},pop);\n    title.textContent=s.e+' '+s.n+' · 注入到哪里？';\n\n    var POS=[\n      {id:'replace_last',ic:'✏️',lb:'更新最后一条 AI 回复'},\n      {id:'next_reply',  ic:'➕',lb:'作为角色的下一条新回复'},\n      {id:'input_box',   ic:'💬',lb:'填入输入框，不发送'},\n    ];\n    var posEls={};\n    POS.forEach(function(pi){\n      var btn=mk('button',{className:'sp-pi'},pop);\n      btn.innerHTML='<span style=\"flex-shrink:0;font-size:15px;margin-right:2px\">'+pi.ic+'</span><span>'+pi.lb+'</span>';\n      posEls[pi.id]=btn;\n      btn.addEventListener('click',function(){\n        Object.keys(posEls).forEach(function(k){posEls[k].classList.remove('sel');});\n        btn.classList.add('sel');ST.pos=pi.id;\n      });\n    });\n    posEls['replace_last'].classList.add('sel');\n\n    var ew=mk('div',{className:'sp-eff-wrap'},pop);\n    mk('div',{className:'sp-eff-lbl'},ew).textContent='群聊氛围特效（可选）';\n    var er=mk('div',{className:'sp-eff-row'},ew);\n    var effEls={};\n    EFFECTS.forEach(function(ef){\n      var btn=mk('button',{className:'sp-eb',title:ef.n},er);\n      btn.textContent=ef.e;effEls[ef.id]=btn;\n      btn.addEventListener('click',function(){\n        if(ST.effect===ef.id){ST.effect=null;btn.classList.remove('on');}\n        else{Object.keys(effEls).forEach(function(k){effEls[k].classList.remove('on');});ST.effect=ef.id;btn.classList.add('on');}\n      });\n    });\n\n    var go=mk('button',{id:'sp-go'},pop);\n    go.textContent='确认生成';\n    go.addEventListener('click',function(){doGen();});\n  }\n\n  /* ── 生成 ── */\n  async function doGen(){\n    var s=ST.style,pos=ST.pos,ef=ST.effect;\n    if(!s)return;\n    closePop();\n    D.querySelectorAll('#sp-bar .sp-b').forEach(function(b){b.classList.remove('on');});\n    if(ef)fx(ef);\n    try{\n      toast('🔄 生成中…',20000);\n      var generated='';\n      var suffix='\\n\\n只输出正文，保持角色身份，不要加任何说明或前缀。';\n      if(pos==='replace_last'){\n        var msgs=await tavo.message.find(-1,{role:'assistant'});\n        if(!msgs||!msgs.length){toast('❌ 找不到上一条 AI 回复');return;}\n        var lastMsg=msgs[0];\n        generated=await tavo.generate(\n          '以下是角色的原始回复：\\n---\\n'+lastMsg.content+'\\n---\\n\\n请将上面这段回复用「'+s.n+'」风格重新改写。\\n'+s.p+suffix,\n          {context:true}\n        );\n        lastMsg.content=generated;\n        await tavo.message.update(lastMsg);\n        toast('✅ 已更新最后一条回复');\n      } else if(pos==='next_reply'){\n        generated=await tavo.generate(\n          '请以当前角色身份，用「'+s.n+'」风格写一条新的回复。\\n'+s.p+suffix,\n          {context:true}\n        );\n        await tavo.message.append({content:generated});\n        toast('✅ 新回复已追加');\n      } else {\n        generated=await tavo.generate(\n          '请以当前角色身份，用「'+s.n+'」风格写一条回复。\\n'+s.p+suffix,\n          {context:true}\n        );\n        tavo.input.set(generated);\n        toast('✅ 已填入输入框');\n      }\n    }catch(err){\n      console.error('[风格插件]',err);\n      toast('❌ 失败：'+(err&&err.message||String(err)));\n    }\n    ST.style=null;\n  }\n\n  /* ── 挂载工具栏到输入框上方 ── */\n  function buildBar(){\n    if(D.getElementById('sp-bar-wrap'))return;\n\n    // 创建 wrap + bar\n    var wrap=mk('div',{id:'sp-bar-wrap'});\n    var bar=mk('div',{id:'sp-bar'},wrap);\n\n    STYLES.forEach(function(s){\n      var btn=mk('button',{className:'sp-b',title:s.n},bar);\n      btn.textContent=s.e;\n      btn.addEventListener('click',function(e){\n        e.stopPropagation();\n        var open=!!D.getElementById('sp-pop');\n        var same=open&&ST.style&&ST.style.id===s.id;\n        closePop();\n        bar.querySelectorAll('.sp-b').forEach(function(b){b.classList.remove('on');});\n        if(!same){btn.classList.add('on');openPop(s);}\n      });\n    });\n\n    mk('div',{className:'sp-sep'},bar);\n    var tog=mk('button',{className:'sp-b',title:'收起/展开'},bar);\n    tog.textContent='🎭';tog.style.background='rgba(130,80,255,0.28)';\n    tog.addEventListener('click',function(e){\n      e.stopPropagation();\n      var h=bar.style.display==='none';\n      bar.style.display=h?'':'none';\n      if(!h)closePop();\n    });\n\n    // 插入到页面：找输入框的父容器，把 wrap 插在输入框前面\n    function mount(){\n      if(D.getElementById('sp-bar-wrap'))return true; // 已挂载\n      // 寻找输入框区域的父容器\n      var anchor=\n        D.querySelector('[class*=\"InputArea\"]')||\n        D.querySelector('[class*=\"inputArea\"]')||\n        D.querySelector('[class*=\"chat-input\"]')||\n        D.querySelector('[class*=\"ChatInput\"]')||\n        D.querySelector('[class*=\"message-input\"]')||\n        D.querySelector('[class*=\"MessageInput\"]')||\n        D.querySelector('[class*=\"input-wrapper\"]')||\n        D.querySelector('[class*=\"inputWrapper\"]')||\n        D.querySelector('[class*=\"bottom-bar\"]')||\n        D.querySelector('[class*=\"BottomBar\"]')||\n        D.querySelector('[class*=\"footer\"]');\n\n      // fallback：找 textarea 或 contenteditable 往上两层\n      if(!anchor){\n        var inp=D.querySelector('textarea')||D.querySelector('[contenteditable=\"true\"]');\n        if(inp)anchor=inp.parentElement&&inp.parentElement.parentElement||inp.parentElement;\n      }\n\n      if(anchor){\n        // 把 wrap 插在 anchor 的最前面（输入框上方）\n        anchor.insertBefore(wrap, anchor.firstChild);\n        console.log('[风格插件] 工具栏已挂载到:', anchor.className||anchor.tagName);\n        return true;\n      }\n      return false;\n    }\n\n    if(!mount()){\n      // DOM 还没准备好，等待后重试\n      var obs=new MutationObserver(function(){\n        if(mount())obs.disconnect();\n      });\n      obs.observe(D.body,{childList:true,subtree:true});\n      // 超时兜底：5秒后还没挂载就直接加到body底部\n      setTimeout(function(){\n        if(!D.getElementById('sp-bar-wrap')){\n          wrap.style.cssText='position:fixed;bottom:0;left:0;right:0;z-index:9000;';\n          D.body.appendChild(wrap);\n          console.warn('[风格插件] 未找到输入框容器，降级为fixed定位');\n        }\n      },5000);\n    }\n  }\n\n  buildBar();\n  console.log('[风格插件v5] 已加载');\n\n}catch(e){console.error('[风格插件]',e);}\n})();\n</script>","trimStrings":[],"placements":["user"],"timing":"display","substitution":"none","minDepth":null,"maxDepth":null,"enabled":true},{"identifier":"1638be1e-b0a1-4c4c-b504-352d0a384010","name":"风格指令清理","findRegex":"/<STYLE_CMD>[\\s\\S]*?<\\/STYLE_CMD>/gi","replaceString":"","trimStrings":[],"placements":["char"],"timing":"display","substitution":"none","minDepth":null,"maxDepth":null,"enabled":true}]}