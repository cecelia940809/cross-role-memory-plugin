{"id":123,"name":"手机桌面","entries":[{"identifier":"ab9fcd57-72d9-445a-ab27-a5525b133a98","name":"手机桌面","findRegex":"/【开场简介】/s","replaceString":"<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>No.24 角色室 · 手机桌面生成器</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;600;700&family=ZCOOL+QingKe+HuangYou&display=swap\" rel=\"stylesheet\">\n<style>\n*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n:root {\n  --bg:       #f8f6f2;\n  --bg2:      #ffffff;\n  --bg3:      #f3f0eb;\n  --bg4:      #ece8e0;\n  --ink:      #1e1a14;\n  --ink2:     #3d3628;\n  --ink3:     #6b5f4a;\n  --gold:     #9a7a3a;\n  --gold2:    #b8924a;\n  --gold-lt:  #e8d9b8;\n  --gold-bg:  #faf5eb;\n  --rose:     #a05a6a;\n  --sage:     #4a8a6a;\n  --border:   #e0d8c8;\n  --border2:  #c8bc9e;\n  --shadow-s: 0 2px 12px rgba(60,40,10,0.06);\n  --shadow-m: 0 6px 32px rgba(60,40,10,0.10);\n  --shadow-l: 0 16px 64px rgba(60,40,10,0.13);\n  --text:     #1e1a14;\n  --text-mid: #5a4e38;\n  --text-dim: #9a8e78;\n  --r:        14px;\n  --r2:       10px;\n}\n\nhtml { scroll-behavior: smooth; }\n\nbody {\n  font-family: 'Noto Serif SC', serif;\n  background: var(--bg);\n  color: var(--text);\n  min-height: 100vh;\n  overflow-x: hidden;\n}\n\n/* subtle texture */\nbody::before {\n  content: '';\n  position: fixed; inset: 0; z-index: -1;\n  background:\n    radial-gradient(ellipse 70% 50% at 20% 10%, rgba(154,122,58,0.04) 0%, transparent 60%),\n    radial-gradient(ellipse 50% 70% at 85% 85%, rgba(74,138,106,0.03) 0%, transparent 60%);\n  pointer-events: none;\n}\n\n/* ── HEADER ── */\n.header {\n  text-align: center;\n  padding: 64px 24px 52px;\n  border-bottom: 1px solid var(--border);\n  background: var(--bg2);\n}\n\n.header-line {\n  display: flex; align-items: center; justify-content: center; gap: 14px;\n  margin-bottom: 20px;\n}\n.hl { width: 48px; height: 1px; background: linear-gradient(90deg, transparent, var(--gold2)); }\n.hl.r { background: linear-gradient(90deg, var(--gold2), transparent); }\n.hd { color: var(--gold2); font-size: 14px; letter-spacing: 2px; }\n\n.room-num {\n  font-family: 'ZCOOL QingKe HuangYou', cursive;\n  font-size: clamp(48px, 9vw, 88px);\n  color: var(--ink);\n  line-height: 0.9;\n  letter-spacing: -2px;\n  margin-bottom: 10px;\n  position: relative;\n}\n.room-num span {\n  color: var(--gold2);\n}\n\n.h-title {\n  font-size: 15px; color: var(--ink3);\n  letter-spacing: 5px; font-weight: 400;\n  margin-bottom: 8px;\n}\n.h-sub {\n  font-size: 12px; color: var(--text-dim);\n  letter-spacing: 1.5px;\n}\n.h-badge {\n  display: inline-flex; align-items: center; gap: 5px;\n  margin-top: 16px;\n  background: var(--gold-bg);\n  border: 1px solid var(--gold-lt);\n  border-radius: 20px;\n  padding: 4px 14px;\n  font-size: 11px; color: var(--gold);\n  letter-spacing: 1.5px;\n}\n\n/* ── STEP BAR ── */\n.stepbar {\n  background: var(--bg2);\n  border-bottom: 1px solid var(--border);\n  display: flex; align-items: center; justify-content: center;\n  gap: 0; padding: 20px 24px;\n  position: sticky; top: 0; z-index: 10;\n}\n\n.sn {\n  display: flex; flex-direction: column; align-items: center; gap: 6px;\n  cursor: pointer; transition: opacity 0.3s;\n}\n.sn.inactive { opacity: 0.35; pointer-events: none; }\n\n.sc {\n  width: 30px; height: 30px; border-radius: 50%;\n  border: 1.5px solid var(--border2);\n  display: flex; align-items: center; justify-content: center;\n  font-size: 12px; color: var(--text-dim);\n  background: var(--bg2);\n  transition: all 0.3s;\n}\n.sn.active .sc {\n  border-color: var(--gold2); color: var(--gold2);\n  box-shadow: 0 0 0 4px rgba(184,146,74,0.1);\n}\n.sn.done .sc {\n  background: var(--gold2); border-color: var(--gold2);\n  color: #fff;\n}\n.sl { font-size: 10px; color: var(--text-dim); letter-spacing: 0.5px; white-space: nowrap; }\n.sn.active .sl { color: var(--gold); }\n\n.sc-line {\n  flex: 1; height: 1px; background: var(--border);\n  margin: 0 8px; margin-bottom: 18px; max-width: 80px;\n  transition: background 0.4s;\n}\n.sc-line.done { background: var(--gold-lt); }\n\n/* ── MAIN ── */\n.main { max-width: 860px; margin: 0 auto; padding: 40px 20px 100px; }\n\n/* ── PANEL ── */\n.panel {\n  background: var(--bg2);\n  border: 1px solid var(--border);\n  border-radius: var(--r);\n  padding: 40px 44px;\n  margin-bottom: 14px;\n  display: none;\n  animation: fadeUp 0.35s cubic-bezier(.4,0,.2,1);\n  box-shadow: var(--shadow-s);\n}\n.panel.active { display: block; }\n@keyframes fadeUp {\n  from { opacity: 0; transform: translateY(14px); }\n  to   { opacity: 1; transform: translateY(0); }\n}\n@media(max-width:600px){ .panel { padding: 24px 18px; } }\n\n.ph {\n  display: flex; align-items: flex-start; gap: 16px;\n  margin-bottom: 32px;\n  padding-bottom: 24px;\n  border-bottom: 1px solid var(--border);\n}\n.ph-ico {\n  width: 44px; height: 44px; border-radius: 12px;\n  background: var(--gold-bg); border: 1px solid var(--gold-lt);\n  display: flex; align-items: center; justify-content: center;\n  font-size: 22px; flex-shrink: 0;\n}\n.ph-title { font-size: 17px; font-weight: 700; color: var(--ink); margin-bottom: 4px; }\n.ph-desc  { font-size: 12px; color: var(--text-dim); line-height: 1.6; }\n\n/* ── FORM ── */\n.fg { margin-bottom: 20px; }\n.fr { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 20px; }\n@media(max-width:560px){ .fr { grid-template-columns: 1fr; } }\n\nlabel {\n  display: block; font-size: 11px; font-weight: 700;\n  color: var(--gold); letter-spacing: 1.5px; text-transform: uppercase;\n  margin-bottom: 7px;\n}\nlabel .hint {\n  font-weight: 400; color: var(--text-dim); font-size: 11px;\n  text-transform: none; letter-spacing: 0; margin-left: 6px;\n}\n\ninput[type=text], input[type=number], textarea, select {\n  width: 100%;\n  background: var(--bg3);\n  border: 1px solid var(--border);\n  border-radius: var(--r2);\n  padding: 10px 13px;\n  font-size: 13.5px;\n  font-family: 'Noto Serif SC', serif;\n  color: var(--ink);\n  transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;\n  outline: none; -webkit-appearance: none;\n}\ninput:focus, textarea:focus, select:focus {\n  border-color: var(--gold2);\n  background: var(--bg2);\n  box-shadow: 0 0 0 3px rgba(184,146,74,0.1);\n}\ninput::placeholder, textarea::placeholder { color: var(--text-dim); }\ntextarea { resize: vertical; min-height: 78px; line-height: 1.7; }\nselect { cursor: pointer; }\n\n/* ── APP TOGGLES ── */\n.app-grid {\n  display: grid; grid-template-columns: repeat(auto-fill, minmax(84px, 1fr));\n  gap: 8px; margin-top: 6px;\n}\n.at {\n  display: flex; flex-direction: column; align-items: center; gap: 7px;\n  padding: 14px 6px 11px;\n  border-radius: 12px; border: 1.5px solid var(--border);\n  cursor: pointer; background: var(--bg3);\n  transition: all 0.2s; user-select: none; position: relative;\n}\n.at.on {\n  border-color: var(--gold2);\n  background: var(--gold-bg);\n  box-shadow: 0 2px 10px rgba(184,146,74,0.12);\n}\n.at .t-ico { font-size: 24px; }\n.at .t-nm  { font-size: 11px; color: var(--text-dim); text-align: center; }\n.at.on .t-nm { color: var(--gold); font-weight: 600; }\n.at input { display: none; }\n.at .ck {\n  position: absolute; top: 5px; right: 5px;\n  width: 14px; height: 14px; border-radius: 50%;\n  background: var(--gold2); display: none;\n  align-items: center; justify-content: center;\n  font-size: 8px; color: #fff;\n}\n.at.on .ck { display: flex; }\n\n/* ── DYNAMIC LIST ── */\n.dl { display: flex; flex-direction: column; gap: 6px; }\n.di {\n  display: flex; align-items: center; gap: 7px;\n  background: var(--bg3); border: 1px solid var(--border);\n  border-radius: var(--r2); padding: 5px 7px 5px 12px;\n  transition: border-color 0.2s;\n}\n.di:focus-within { border-color: var(--gold2); }\n.di input {\n  flex: 1; background: none; border: none; border-radius: 0;\n  padding: 6px 0; font-size: 13px; box-shadow: none;\n}\n.di input:focus { box-shadow: none; border-color: transparent; background: none; }\n.di .si {\n  flex: 0.9; border-left: 1px solid var(--border);\n  padding-left: 10px; color: var(--text-mid); font-size: 12px;\n}\n.di .xi {\n  width: 24px; height: 24px; border-radius: 6px; border: none;\n  background: none; color: var(--text-dim); font-size: 16px;\n  cursor: pointer; display: flex; align-items: center; justify-content: center;\n  flex-shrink: 0; transition: all 0.15s; line-height: 1;\n}\n.di .xi:hover { background: #fde8f0; color: var(--rose); }\n\n.add-row {\n  display: flex; align-items: center; gap: 5px; justify-content: center;\n  background: none; border: 1px dashed var(--border2);\n  border-radius: var(--r2); padding: 8px;\n  color: var(--text-dim); font-size: 12px;\n  font-family: 'Noto Serif SC', serif;\n  cursor: pointer; width: 100%; margin-top: 4px;\n  transition: all 0.2s; letter-spacing: 0.5px;\n}\n.add-row:hover { border-color: var(--gold2); color: var(--gold); background: var(--gold-bg); }\n\n/* ── AI BAR ── */\n.ai-bar {\n  display: flex; align-items: center; gap: 12px;\n  background: var(--gold-bg);\n  border: 1px solid var(--gold-lt);\n  border-radius: 12px; padding: 14px 18px;\n  margin-bottom: 28px;\n}\n.ai-ico { font-size: 22px; flex-shrink: 0; }\n.ai-txt { flex: 1; font-size: 12.5px; color: var(--ink3); line-height: 1.6; }\n.ai-txt strong { color: var(--gold); }\n.ai-btn {\n  flex-shrink: 0;\n  background: linear-gradient(135deg, var(--gold), var(--gold2));\n  border: none; border-radius: 8px;\n  padding: 9px 18px; font-size: 12px; font-weight: 700;\n  font-family: 'Noto Serif SC', serif;\n  color: #fff; cursor: pointer;\n  transition: all 0.2s; letter-spacing: 0.5px;\n  white-space: nowrap;\n  box-shadow: 0 2px 10px rgba(154,122,58,0.25);\n}\n.ai-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 18px rgba(154,122,58,0.35); }\n.ai-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }\n.spin { display: inline-block; animation: spin 0.9s linear infinite; }\n@keyframes spin { to { transform: rotate(360deg); } }\n\n/* ── AI STATUS ── */\n.ai-status {\n  display: none; align-items: center; gap: 8px;\n  padding: 10px 14px;\n  background: var(--bg3); border-radius: var(--r2);\n  margin-bottom: 16px; font-size: 12px; color: var(--text-mid);\n}\n.ai-status.show { display: flex; }\n.ai-status-dot {\n  width: 8px; height: 8px; border-radius: 50%;\n  background: var(--gold2); flex-shrink: 0;\n  animation: pulse 1.2s ease-in-out infinite;\n}\n@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.8)} }\n\n/* ── NAV BTNS ── */\n.nav-row {\n  display: flex; justify-content: space-between; align-items: center;\n  margin-top: 36px; padding-top: 24px;\n  border-top: 1px solid var(--border);\n  gap: 12px;\n}\n.btn-back {\n  background: none; border: 1px solid var(--border2);\n  border-radius: var(--r2); padding: 10px 20px;\n  font-size: 13px; font-family: 'Noto Serif SC', serif;\n  color: var(--text-dim); cursor: pointer;\n  transition: all 0.2s;\n}\n.btn-back:hover { border-color: var(--gold2); color: var(--ink); }\n\n.btn-next {\n  background: linear-gradient(135deg, var(--gold), var(--gold2));\n  border: none; border-radius: var(--r2);\n  padding: 11px 30px; font-size: 13.5px; font-weight: 700;\n  font-family: 'Noto Serif SC', serif;\n  color: #fff; cursor: pointer;\n  box-shadow: 0 3px 16px rgba(154,122,58,0.28);\n  transition: all 0.2s; letter-spacing: 0.5px;\n}\n.btn-next:hover { transform: translateY(-1px); box-shadow: 0 5px 22px rgba(154,122,58,0.38); }\n\n/* ── OUTPUT ── */\n.out-tabs { display: flex; gap: 4px; margin-bottom: 12px; flex-wrap: wrap; }\n.ot {\n  padding: 7px 15px; border-radius: 8px;\n  border: 1px solid var(--border);\n  font-size: 11.5px; color: var(--text-dim);\n  cursor: pointer; transition: all 0.2s;\n  font-family: 'Noto Serif SC', serif;\n  background: var(--bg3); letter-spacing: 0.5px;\n}\n.ot.active { background: var(--gold-bg); border-color: var(--gold2); color: var(--gold); }\n.ot:hover:not(.active) { border-color: var(--border2); color: var(--ink3); }\n\n.code-out {\n  background: #1c1814;\n  border-radius: var(--r2);\n  padding: 18px;\n  font-family: 'Courier New', monospace;\n  font-size: 11px; line-height: 1.75;\n  color: #c8d8a0;\n  max-height: 280px; overflow-y: auto;\n  white-space: pre-wrap; word-break: break-all;\n  display: none;\n}\n.code-out.vis { display: block; }\n.code-out::-webkit-scrollbar { width: 4px; }\n.code-out::-webkit-scrollbar-thumb { background: #4a4030; border-radius: 2px; }\n\n.dl-row { display: flex; gap: 8px; margin-top: 14px; flex-wrap: wrap; }\n.dlb {\n  display: flex; align-items: center; gap: 6px;\n  padding: 9px 18px; border-radius: var(--r2); border: none;\n  font-size: 12px; font-family: 'Noto Serif SC', serif;\n  cursor: pointer; font-weight: 600; transition: all 0.2s;\n  letter-spacing: 0.5px;\n}\n.dlb-p { background: linear-gradient(135deg, var(--gold), var(--gold2)); color: #fff; box-shadow: 0 2px 10px rgba(154,122,58,0.25); }\n.dlb-p:hover { transform: translateY(-1px); }\n.dlb-g { background: var(--bg3); color: var(--text-mid); border: 1px solid var(--border2); }\n.dlb-g:hover { background: var(--bg4); color: var(--ink); }\n\n/* ── SUMMARY ── */\n.sum-grid {\n  display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));\n  gap: 10px; margin-bottom: 24px;\n}\n.sc2 {\n  background: var(--bg3); border: 1px solid var(--border);\n  border-radius: 12px; padding: 14px;\n}\n.sk { font-size: 10px; color: var(--text-dim); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 5px; }\n.sv { font-size: 14px; color: var(--ink); font-weight: 700; }\n.ss { font-size: 11px; color: var(--text-dim); margin-top: 3px; }\n\n/* ── GUIDE ── */\n.guide {\n  margin-top: 20px; padding: 18px 22px;\n  background: var(--gold-bg); border: 1px solid var(--gold-lt);\n  border-radius: 12px;\n}\n.gt { font-size: 11px; color: var(--gold); letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 10px; }\n.gb { font-size: 12px; color: var(--ink3); line-height: 2.1; }\n.gb b { color: var(--ink2); }\n\n/* ── TOAST ── */\n.toast {\n  position: fixed; bottom: 36px; left: 50%;\n  transform: translateX(-50%) translateY(12px);\n  background: var(--ink); color: #f0e8d0;\n  padding: 10px 22px; border-radius: 22px;\n  font-size: 13px; border: 1px solid rgba(255,255,255,0.1);\n  box-shadow: var(--shadow-m);\n  opacity: 0; transition: all 0.3s; pointer-events: none; z-index: 999;\n}\n.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }\n\n/* ── OVERLAY ── */\n.overlay {\n  display: none; position: fixed; inset: 0; z-index: 200;\n  background: rgba(248,246,242,0.85);\n  backdrop-filter: blur(8px);\n  align-items: center; justify-content: center;\n  flex-direction: column; gap: 18px;\n}\n.overlay.show { display: flex; }\n.ov-ring {\n  width: 48px; height: 48px; border-radius: 50%;\n  border: 2px solid var(--gold-lt);\n  border-top-color: var(--gold2);\n  animation: spin 0.9s linear infinite;\n}\n.ov-msg { font-size: 15px; color: var(--ink2); letter-spacing: 1.5px; }\n.ov-sub { font-size: 12px; color: var(--text-dim); }\n\n/* scrollbar */\n::-webkit-scrollbar { width: 6px; }\n::-webkit-scrollbar-track { background: transparent; }\n::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }\n</style>\n</head>\n<body>\n\n<div class=\"overlay\" id=\"overlay\">\n  <div class=\"ov-ring\"></div>\n  <div class=\"ov-msg\" id=\"ovMsg\">正在生成…</div>\n  <div class=\"ov-sub\" id=\"ovSub\">请稍候</div>\n</div>\n\n<!-- HEADER -->\n<div class=\"header\">\n  <div class=\"header-line\">\n    <div class=\"hl\"></div><span class=\"hd\">✦</span><div class=\"hl r\"></div>\n  </div>\n  <div class=\"room-num\">No.<span>24</span></div>\n  <div class=\"h-title\">角色室 · 手机桌面生成器</div>\n  <div class=\"h-sub\">为角色定制一部真实的手机 · 一键导入 Tavo</div>\n  <div class=\"h-badge\">✦ Tavo JavaScript API 驱动</div>\n  <div style=\"margin-top:14px;display:flex;align-items:center;gap:8px;justify-content:center;flex-wrap:wrap\">\n    <label style=\"font-size:11px;color:var(--text-dim);letter-spacing:0.5px;text-transform:none;font-weight:400;margin:0\">✦ 自动填写 API Key：</label>\n    <input id=\"apiKeyInput\" type=\"password\" placeholder=\"sk-ant-api03-...\" style=\"width:200px;font-size:11px;padding:5px 10px;border-radius:8px;border:1px solid var(--border);background:var(--bg3);color:var(--ink);font-family:monospace;outline:none\">\n  </div>\n</div>\n\n<!-- STEP BAR -->\n<div class=\"stepbar\" id=\"stepbar\">\n  <div class=\"sn active\" data-s=\"1\" data-jump=\"1\">\n    <div class=\"sc\">1</div><div class=\"sl\">角色基础</div>\n  </div>\n  <div class=\"sc-line\" id=\"l1\"></div>\n  <div class=\"sn inactive\" data-s=\"2\" data-jump=\"2\">\n    <div class=\"sc\">2</div><div class=\"sl\">App 内容</div>\n  </div>\n  <div class=\"sc-line\" id=\"l2\"></div>\n  <div class=\"sn inactive\" data-s=\"3\" data-jump=\"3\">\n    <div class=\"sc\">3</div><div class=\"sl\">生成导出</div>\n  </div>\n</div>\n\n<div class=\"main\">\n\n<!-- ══ STEP 1 ══ -->\n<div class=\"panel active\" id=\"p1\">\n  <div class=\"ph\">\n    <div class=\"ph-ico\">📱</div>\n    <div>\n      <div class=\"ph-title\">角色基础信息</div>\n      <div class=\"ph-desc\">填写角色名与城市，其余内容可以在下一步交给 AI 自动生成</div>\n    </div>\n  </div>\n\n  <div class=\"fr\">\n    <div class=\"fg\">\n      <label>角色名 <span class=\"hint\">必填</span></label>\n      <input type=\"text\" id=\"cName\" placeholder=\"例：叶晚晴\">\n    </div>\n    <div class=\"fg\">\n      <label>头像 Emoji</label>\n      <input type=\"text\" id=\"cEmoji\" value=\"🌸\" maxlength=\"2\" style=\"font-size:22px;text-align:center;padding:6px\">\n    </div>\n  </div>\n\n  <div class=\"fr\">\n    <div class=\"fg\">\n      <label>所在城市 <span class=\"hint\">用于天气·地图·外卖</span></label>\n      <input type=\"text\" id=\"cCity\" placeholder=\"例：上海 静安区\">\n    </div>\n    <div class=\"fg\">\n      <label>手机主题</label>\n      <select id=\"cTheme\">\n        <option value=\"紫色毛玻璃\">紫色毛玻璃</option>\n        <option value=\"粉樱渐变\">粉樱渐变</option>\n        <option value=\"深空黑金\">深空黑金</option>\n        <option value=\"薄荷绿清新\">薄荷绿清新</option>\n        <option value=\"暖橘奶油\">暖橘奶油</option>\n        <option value=\"蓝灰极简\">蓝灰极简</option>\n      </select>\n    </div>\n  </div>\n\n  <div class=\"fg\">\n    <label>性格简述 <span class=\"hint\">几个词即可，AI 会根据它生成 App 内容</span></label>\n    <textarea id=\"cPersonality\" placeholder=\"例：温柔内敛，喜欢独处，爱喝咖啡，有点念旧，偶尔有奇怪的执念…\" style=\"min-height:62px\"></textarea>\n  </div>\n\n  <div class=\"fg\">\n    <label>触发词 <span class=\"hint\">用户说这些词时展示手机，逗号分隔</span></label>\n    <input type=\"text\" id=\"cTrigger\" value=\"捡起手机, 看手机, 查看手机, 手机响了, 解锁手机\">\n  </div>\n\n  <div class=\"fg\">\n    <label>开启的 App <span class=\"hint\">点击选择，未选的不生成世界书条目</span></label>\n    <div class=\"app-grid\" id=\"appGrid\">\n      <label class=\"at on\"><input type=\"checkbox\" name=\"app\" value=\"wechat\" checked>\n        <div class=\"ck\">✓</div><div class=\"t-ico\">💬</div><div class=\"t-nm\">微信</div></label>\n      <label class=\"at on\"><input type=\"checkbox\" name=\"app\" value=\"music\" checked>\n        <div class=\"ck\">✓</div><div class=\"t-ico\">🎵</div><div class=\"t-nm\">音乐</div></label>\n      <label class=\"at on\"><input type=\"checkbox\" name=\"app\" value=\"album\" checked>\n        <div class=\"ck\">✓</div><div class=\"t-ico\">📷</div><div class=\"t-nm\">相册</div></label>\n      <label class=\"at on\"><input type=\"checkbox\" name=\"app\" value=\"memo\" checked>\n        <div class=\"ck\">✓</div><div class=\"t-ico\">📝</div><div class=\"t-nm\">备忘录</div></label>\n      <label class=\"at on\"><input type=\"checkbox\" name=\"app\" value=\"diary\" checked>\n        <div class=\"ck\">✓</div><div class=\"t-ico\">💕</div><div class=\"t-nm\">心情日记</div></label>\n      <label class=\"at on\"><input type=\"checkbox\" name=\"app\" value=\"delivery\" checked>\n        <div class=\"ck\">✓</div><div class=\"t-ico\">🍟</div><div class=\"t-nm\">外卖</div></label>\n      <label class=\"at on\"><input type=\"checkbox\" name=\"app\" value=\"weather\" checked>\n        <div class=\"ck\">✓</div><div class=\"t-ico\">🌤</div><div class=\"t-nm\">天气</div></label>\n      <label class=\"at\"><input type=\"checkbox\" name=\"app\" value=\"taobao\">\n        <div class=\"ck\">✓</div><div class=\"t-ico\">🛒</div><div class=\"t-nm\">淘宝</div></label>\n      <label class=\"at on\"><input type=\"checkbox\" name=\"app\" value=\"map\" checked>\n        <div class=\"ck\">✓</div><div class=\"t-ico\">📍</div><div class=\"t-nm\">地图</div></label>\n      <label class=\"at\"><input type=\"checkbox\" name=\"app\" value=\"health\">\n        <div class=\"ck\">✓</div><div class=\"t-ico\">❤️</div><div class=\"t-nm\">健康</div></label>\n    </div>\n  </div>\n\n  <div class=\"nav-row\">\n    <div></div>\n    <button class=\"btn-next\" data-action=\"goStep2\">下一步 →</button>\n  </div>\n</div>\n\n<!-- ══ STEP 2 ══ -->\n<div class=\"panel\" id=\"p2\">\n  <div class=\"ph\">\n    <div class=\"ph-ico\">✦</div>\n    <div>\n      <div class=\"ph-title\">App 内容填写</div>\n      <div class=\"ph-desc\">可手动填写，也可点击「AI 自动填写」让系统根据角色性格一键生成</div>\n    </div>\n  </div>\n\n  <div class=\"ai-bar\">\n    <div class=\"ai-ico\">🤖</div>\n    <div class=\"ai-txt\"><strong>AI 自动填写</strong> · 根据角色名和性格，自动生成所有 App 的内容细节</div>\n    <button class=\"ai-btn\" id=\"aiBtn\" data-action=\"autoFill\">✦ 自动填写</button>\n  </div>\n\n  <div class=\"ai-status\" id=\"aiStatus\">\n    <div class=\"ai-status-dot\"></div>\n    <span id=\"aiStatusTxt\">AI 正在生成内容…</span>\n  </div>\n\n  <!-- 微信 -->\n  <div class=\"fg\" id=\"sec-wechat\">\n    <label>💬 微信 · 联系人 <span class=\"hint\">emoji · 备注名 · 最近消息 · 未读数</span></label>\n    <div class=\"dl\" id=\"wechatList\">\n      <div class=\"di\">\n        <input type=\"text\" placeholder=\"🐱\" style=\"width:30px;text-align:center;flex:none\">\n        <input type=\"text\" placeholder=\"备注名\" style=\"flex:1\">\n        <input type=\"text\" placeholder=\"最近一条消息\" class=\"si\" style=\"flex:2\">\n        <input type=\"number\" placeholder=\"未读\" style=\"width:42px;flex:none;text-align:center\">\n        <button class=\"xi\" data-action=\"delRow\">×</button>\n      </div>\n    </div>\n    <button class=\"add-row\" data-action=\"addWechat\">+ 添加联系人</button>\n  </div>\n\n  <!-- 音乐 -->\n  <div class=\"fg\" id=\"sec-music\">\n    <label>🎵 音乐 · 正在播放</label>\n    <div class=\"fr\" style=\"margin-bottom:10px\">\n      <input type=\"text\" id=\"mSong\" placeholder=\"歌曲名\">\n      <input type=\"text\" id=\"mArtist\" placeholder=\"歌手\">\n    </div>\n    <label>歌单 <span class=\"hint\">最近在听的</span></label>\n    <div class=\"dl\" id=\"musicList\">\n      <div class=\"di\">\n        <input type=\"text\" placeholder=\"歌曲名\" style=\"flex:1\">\n        <input type=\"text\" placeholder=\"歌手\" class=\"si\" style=\"flex:1\">\n        <button class=\"xi\" data-action=\"delRow\">×</button>\n      </div>\n    </div>\n    <button class=\"add-row\" data-action=\"addMusic\">+ 添加歌曲</button>\n  </div>\n\n  <!-- 相册 -->\n  <div class=\"fg\" id=\"sec-album\">\n    <label>📷 相册 · 珍藏场景 <span class=\"hint\">逗号分隔</span></label>\n    <textarea id=\"albumContent\" placeholder=\"例：和朋友在咖啡馆的下午, 上次去海边的傍晚, 家里的橘猫\"></textarea>\n    <label style=\"margin-top:12px\">最近拍的一张照片</label>\n    <textarea id=\"lastPhoto\" placeholder=\"描述内容和当时心情\" style=\"min-height:58px\"></textarea>\n  </div>\n\n  <!-- 备忘录 -->\n  <div class=\"fg\" id=\"sec-memo\">\n    <label>📝 备忘录 · 存着什么 <span class=\"hint\">逗号分隔</span></label>\n    <textarea id=\"memoContent\" placeholder=\"例：想买的东西, 想看的书, 睡前碎碎念, 某个让她在意的细节\"></textarea>\n  </div>\n\n  <!-- 心情日记 -->\n  <div class=\"fg\" id=\"sec-diary\">\n    <label>💕 今日心情日记 <span class=\"hint\">第一人称，100字以内</span></label>\n    <textarea id=\"diaryText\" placeholder=\"例：今天光线很好，在窗边喝了一杯热可可……\" style=\"min-height:88px\"></textarea>\n    <div class=\"fr\" style=\"margin-top:10px;margin-bottom:0\">\n      <div><label>心情</label>\n        <select id=\"diaryMood\">\n          <option value=\"😊 开心\">😊 开心</option><option value=\"🥰 幸福\">🥰 幸福</option>\n          <option value=\"😌 平静\">😌 平静</option><option value=\"😔 低落\">😔 低落</option>\n          <option value=\"😤 烦躁\">😤 烦躁</option><option value=\"🥺 难过\">🥺 难过</option>\n          <option value=\"😴 困倦\">😴 困倦</option><option value=\"🤭 害羞\">🤭 害羞</option>\n        </select></div>\n      <div><label>天气</label>\n        <select id=\"diaryWeather\">\n          <option value=\"☀️ 晴天\">☀️ 晴天</option><option value=\"⛅ 多云\" selected>⛅ 多云</option>\n          <option value=\"🌧 雨天\">🌧 雨天</option><option value=\"🌦 阵雨\">🌦 阵雨</option>\n          <option value=\"🌫 阴天\">🌫 阴天</option><option value=\"❄️ 下雪\">❄️ 下雪</option>\n        </select></div>\n    </div>\n  </div>\n\n  <!-- 外卖 -->\n  <div class=\"fg\" id=\"sec-delivery\">\n    <label>🍟 外卖 · 最新订单</label>\n    <div class=\"fr\" style=\"margin-bottom:10px\">\n      <input type=\"text\" id=\"deliveryItem\" placeholder=\"商品名（如：黄油牛角包）\">\n      <input type=\"text\" id=\"deliveryStatus\" placeholder=\"状态（如：骑手距离500米）\">\n    </div>\n    <label>点餐偏好 <span class=\"hint\">可选</span></label>\n    <input type=\"text\" id=\"deliveryPref\" placeholder=\"例：甜食控，常点奶茶和甜点\">\n  </div>\n\n  <!-- 天气 -->\n  <div class=\"fg\" id=\"sec-weather\">\n    <label>🌤 天气 · 补充说明 <span class=\"hint\">可选</span></label>\n    <input type=\"text\" id=\"weatherNote\" placeholder=\"例：最近连续降雨，她一直窝在家里\">\n  </div>\n\n  <!-- 地图 -->\n  <div class=\"fg\" id=\"sec-map\">\n    <label>📍 地图 · 常去地方 <span class=\"hint\">逗号分隔，3-5个</span></label>\n    <input type=\"text\" id=\"mapPlaces\" placeholder=\"例：楼下的咖啡馆, 公司附近的公园, 那家她喜欢的书店\">\n  </div>\n\n  <!-- 淘宝 -->\n  <div class=\"fg\" id=\"sec-taobao\">\n    <label>🛒 淘宝 · 购物车 <span class=\"hint\">逗号分隔</span></label>\n    <input type=\"text\" id=\"taobaoItems\" placeholder=\"例：香薰蜡烛, 新出的手账本, 一盆绿植\">\n  </div>\n\n  <!-- 健康 -->\n  <div class=\"fg\" id=\"sec-health\">\n    <label>❤️ 健康 · 今日状态 <span class=\"hint\">可选</span></label>\n    <input type=\"text\" id=\"healthNote\" placeholder=\"例：睡眠很差，才睡了5小时，步数1200步\">\n  </div>\n\n  <div class=\"nav-row\">\n    <button class=\"btn-back\" data-action=\"goStep1\">← 返回</button>\n    <button class=\"btn-next\" data-action=\"generate\">✦ 生成世界书</button>\n  </div>\n</div>\n\n<!-- ══ STEP 3 ══ -->\n<div class=\"panel\" id=\"p3\">\n  <div class=\"ph\">\n    <div class=\"ph-ico\">✦</div>\n    <div>\n      <div class=\"ph-title\">生成完成</div>\n      <div class=\"ph-desc\">下载文件后通过 Tavo JavaScript 一键导入，或手动导入世界书和正则</div>\n    </div>\n  </div>\n\n  <div class=\"sum-grid\" id=\"sumGrid\"></div>\n\n  <div class=\"out-tabs\">\n    <button class=\"ot active\" data-tab=\"lorebook\">📚 世界书 JSON</button>\n    <button class=\"ot\" data-tab=\"regex\">🔍 正则 JSON</button>\n    <button class=\"ot\" data-tab=\"tavojs\">⚡ Tavo 导入脚本</button>\n    <button class=\"ot\" data-tab=\"prompt\">💬 系统预设</button>\n  </div>\n\n  <div class=\"code-out vis\" id=\"out-lorebook\"></div>\n  <div class=\"code-out\" id=\"out-regex\"></div>\n  <div class=\"code-out\" id=\"out-tavojs\"></div>\n  <div class=\"code-out\" id=\"out-prompt\"></div>\n\n  <div class=\"dl-row\">\n    <button class=\"dlb dlb-p\" data-action=\"dlLorebook\">⬇ 世界书 JSON</button>\n    <button class=\"dlb dlb-p\" data-action=\"dlRegex\">⬇ 正则 JSON</button>\n    <button class=\"dlb dlb-g\" data-action=\"dlAll\">📦 全部下载</button>\n    <button class=\"dlb dlb-g\" data-action=\"copyActive\">📋 复制当前</button>\n  </div>\n\n  <div class=\"guide\">\n    <div class=\"gt\">✦ Tavo 导入方法</div>\n    <div class=\"gb\">\n      <b>推荐：</b>复制「Tavo 导入脚本」内容，粘贴到 Tavo JavaScript 控制台执行，自动创建世界书+正则并绑定到当前聊天<br>\n      <b>世界书：</b>Tavo → 世界书 → 导入 → 选择 JSON 文件<br>\n      <b>正则：</b>Tavo → 正则 → 导入 → 选择 JSON 文件<br>\n      <b>系统预设：</b>粘贴到角色卡的 System Prompt 字段\n    </div>\n  </div>\n\n  <div class=\"nav-row\">\n    <button class=\"btn-back\" data-action=\"goStep2\">← 返回修改</button>\n    <button class=\"btn-next\" style=\"background:linear-gradient(135deg,#3a7a5a,var(--sage))\" data-action=\"resetAll\">重新创建 ↺</button>\n  </div>\n</div>\n\n</div><!-- /main -->\n<div class=\"toast\" id=\"toast\"></div>\n\n<script>\n// ══ TOGGLES ══ (fixed: use change event on checkbox)\ndocument.querySelectorAll('.at').forEach(el=>{\n  const cb=el.querySelector('input');\n  cb.addEventListener('change',()=>{\n    el.classList.toggle('on',cb.checked);\n  });\n});\n\n// ══ EVENT DELEGATION (replaces inline onclick= which are stripped by DOMPurify) ══\ndocument.addEventListener('click', e => {\n  const t = e.target.closest('[data-action],[data-tab],[data-jump]');\n  if (!t) return;\n\n  // data-action handlers\n  const act = t.getAttribute('data-action');\n  if (act === 'goStep2') { goStep(2); return; }\n  if (act === 'goStep1') { goStep(1); return; }\n  if (act === 'generate') { generate(); return; }\n  if (act === 'autoFill') { autoFill(); return; }\n  if (act === 'resetAll') { resetAll(); return; }\n  if (act === 'addWechat') { addWechat(); return; }\n  if (act === 'addMusic') { addMusic(); return; }\n  if (act === 'dlLorebook') { dlLorebook(); return; }\n  if (act === 'dlRegex') { dlRegex(); return; }\n  if (act === 'dlAll') { dlAll(); return; }\n  if (act === 'copyActive') { copyActive(); return; }\n  if (act === 'delRow') { delRow(t); return; }\n\n  // data-tab handlers (tab switching)\n  const tab = t.getAttribute('data-tab');\n  if (tab) { switchTab(tab, t); return; }\n\n  // data-jump handlers (step nav)\n  const jmp = t.getAttribute('data-jump');\n  if (jmp) { jump(parseInt(jmp)); return; }\n});\n\n// ══ STEP NAV ══\nlet cur=1;\nfunction goStep(n){\n  document.getElementById('p'+cur).classList.remove('active');\n  document.querySelectorAll('.sn').forEach((el,i)=>{\n    el.classList.remove('active','done','inactive');\n    const sc=el.querySelector('.sc');\n    if(i+1<n){el.classList.add('done');sc.textContent='✓';}\n    else if(i+1===n){el.classList.add('active');sc.textContent=i+1;}\n    else{el.classList.add('inactive');sc.textContent=i+1;}\n  });\n  for(let i=1;i<=2;i++){\n    const l=document.getElementById('l'+i);\n    if(l) l.classList.toggle('done',i<n);\n  }\n  if(n===2) refreshSecs();\n  cur=n;\n  document.getElementById('p'+n).classList.add('active');\n  window.scrollTo({top:0,behavior:'smooth'});\n}\nfunction jump(n){if(n<cur)goStep(n);}\nfunction resetAll(){goStep(1);}\n\nfunction refreshSecs(){\n  const apps=getApps();\n  ['wechat','music','album','memo','diary','delivery','weather','map','taobao','health'].forEach(a=>{\n    const el=document.getElementById('sec-'+a);\n    if(el)el.style.display=apps.includes(a)?'block':'none';\n  });\n}\n\n// ══ HELPERS ══\nconst v=id=>(document.getElementById(id)||{}).value?.trim()||'';\nconst getApps=()=>Array.from(document.querySelectorAll('input[name=app]:checked')).map(i=>i.value);\nconst delRow=btn=>btn.closest('.di').remove();\n\nfunction addWechat(){\n  const d=document.createElement('div');d.className='di';\n  d.innerHTML=`<input type=\"text\" placeholder=\"🐱\" style=\"width:30px;text-align:center;flex:none\">\n    <input type=\"text\" placeholder=\"备注名\" style=\"flex:1\">\n    <input type=\"text\" placeholder=\"最近消息\" class=\"si\" style=\"flex:2\">\n    <input type=\"number\" placeholder=\"未读\" style=\"width:42px;flex:none;text-align:center\">\n    <button class=\"xi\" data-action=\"delRow\">×</button>`;\n  document.getElementById('wechatList').appendChild(d);\n  d.querySelector('input').focus();\n}\nfunction addMusic(){\n  const d=document.createElement('div');d.className='di';\n  d.innerHTML=`<input type=\"text\" placeholder=\"歌曲名\" style=\"flex:1\">\n    <input type=\"text\" placeholder=\"歌手\" class=\"si\" style=\"flex:1\">\n    <button class=\"xi\" data-action=\"delRow\">×</button>`;\n  document.getElementById('musicList').appendChild(d);\n  d.querySelector('input').focus();\n}\n\nconst getWechat=()=>Array.from(document.querySelectorAll('#wechatList .di')).map(r=>{\n  const ins=r.querySelectorAll('input');\n  return{emoji:ins[0].value||'👤',name:ins[1].value,msg:ins[2].value,unread:ins[3].value||0};\n}).filter(r=>r.name);\n\nconst getMusic=()=>Array.from(document.querySelectorAll('#musicList .di')).map(r=>{\n  const ins=r.querySelectorAll('input');\n  return{name:ins[0].value,artist:ins[1].value};\n}).filter(r=>r.name);\n\nconst esc=s=>String(s||'').replace(/\"/g,'&quot;').replace(/</g,'&lt;');\n\n// ══ AI AUTO FILL ══\nasync function autoFill(){\n  const name=v('cName'),personality=v('cPersonality'),city=v('cCity')||'某城市';\n  const apps=getApps();\n  if(!name){toast('请先填写角色名');return;}\n\n  const btn=document.getElementById('aiBtn');\n  const status=document.getElementById('aiStatus');\n  const statusTxt=document.getElementById('aiStatusTxt');\n\n  btn.disabled=true;\n  btn.innerHTML='<span class=\"spin\">⟳</span> 生成中…';\n  status.classList.add('show');\n  statusTxt.textContent='AI 正在根据角色性格生成内容…';\n\n  // 分步提示词，只让AI生成文字内容，减少token\n  const prompt=`你是角色设定生成助手。根据角色\"${name}\"（城市：${city}，性格：${personality||'温柔内敛，有点念旧'}）生成手机App内容。\n\n需要生成的App：${apps.join('、')}\n\n返回纯JSON，不加任何说明和代码块标记，格式：\n{\"wechat\":[{\"emoji\":\"表情\",\"name\":\"联系人名\",\"msg\":\"最近消息\",\"unread\":数字}],\"nowSong\":\"歌名\",\"nowArtist\":\"歌手\",\"playlist\":[{\"name\":\"歌名\",\"artist\":\"歌手\"}],\"album\":\"场景1,场景2,场景3\",\"lastPhoto\":\"描述\",\"memo\":\"事项1,事项2,事项3\",\"diaryText\":\"日记正文80字内\",\"diaryMood\":\"😊 开心\",\"diaryWeather\":\"⛅ 多云\",\"deliveryItem\":\"商品\",\"deliveryStatus\":\"配送状态\",\"deliveryPref\":\"偏好\",\"mapPlaces\":\"地点1,地点2,地点3\",\"taobaoItems\":\"商品1,商品2\",\"healthNote\":\"状态\",\"weatherNote\":\"补充\"}\n\n要求：wechat至少3人，playlist至少3首，内容贴合性格，有生活感和细节。`;\n\n  try {\n    statusTxt.textContent='正在请求 AI…';\n    // NOTE: Direct browser API calls require x-api-key and special CORS header\n    // Get API key from input field (added below) or prompt user\n    const apiKey = (document.getElementById('apiKeyInput')||{}).value?.trim() || '';\n    if(!apiKey){ toast('请先在页面顶部输入 Anthropic API Key'); btn.disabled=false; btn.innerHTML='✦ 自动填写'; status.classList.remove('show'); return; }\n    const res=await fetch('https://api.anthropic.com/v1/messages',{\n      method:'POST',\n      headers:{\n        'Content-Type':'application/json',\n        'x-api-key': apiKey,\n        'anthropic-version': '2023-06-01',\n        'anthropic-dangerous-direct-browser-access': 'true'\n      },\n      body:JSON.stringify({\n        model:'claude-sonnet-4-20250514',\n        max_tokens:2000,\n        messages:[{role:'user',content:prompt}]\n      })\n    });\n\n    if(!res.ok){\n      const err=await res.text();\n      throw new Error('API错误 '+res.status+': '+err.slice(0,100));\n    }\n\n    const data=await res.json();\n    statusTxt.textContent='正在解析数据…';\n\n    // 获取文本内容\n    let text='';\n    if(data.content&&Array.isArray(data.content)){\n      text=data.content.filter(b=>b.type==='text').map(b=>b.text).join('');\n    }\n    if(!text) throw new Error('API返回内容为空');\n\n    // 清理JSON：去掉markdown代码块\n    text=text.trim();\n    text=text.replace(/^```+(?:json)?\\s*/i,'').replace(/\\s*```+$/,'').trim();\n\n    // 找到JSON的开始和结束\n    const start=text.indexOf('{');\n    const end=text.lastIndexOf('}');\n    if(start===-1||end===-1) throw new Error('未找到有效的JSON对象');\n    text=text.slice(start,end+1);\n\n    // 解析\n    const d=JSON.parse(text);\n    fillFromAI(d);\n    status.classList.remove('show');\n    toast('✦ AI 自动填写完成，可手动调整');\n\n  } catch(e){\n    console.error('[AI自动填写错误]',e);\n    status.classList.remove('show');\n    toast('生成失败：'+e.message.slice(0,30)+'，请手动填写或重试');\n  }\n\n  btn.disabled=false;\n  btn.innerHTML='✦ 自动填写';\n}\n\nfunction fillFromAI(d){\n  // 微信\n  const wl=document.getElementById('wechatList');\n  wl.innerHTML='';\n  (d.wechat||[]).forEach(c=>{\n    if(!c.name)return;\n    const div=document.createElement('div');div.className='di';\n    div.innerHTML=`<input type=\"text\" value=\"${esc(c.emoji||'👤')}\" style=\"width:30px;text-align:center;flex:none\">\n      <input type=\"text\" value=\"${esc(c.name)}\" style=\"flex:1\">\n      <input type=\"text\" value=\"${esc(c.msg||'')}\" class=\"si\" style=\"flex:2\">\n      <input type=\"number\" value=\"${parseInt(c.unread)||0}\" style=\"width:42px;flex:none;text-align:center\">\n      <button class=\"xi\" data-action=\"delRow\">×</button>`;\n    wl.appendChild(div);\n  });\n\n  // 音乐\n  if(d.nowSong) document.getElementById('mSong').value=d.nowSong;\n  if(d.nowArtist) document.getElementById('mArtist').value=d.nowArtist;\n  const ml=document.getElementById('musicList');ml.innerHTML='';\n  (d.playlist||[]).forEach(s=>{\n    if(!s.name)return;\n    const div=document.createElement('div');div.className='di';\n    div.innerHTML=`<input type=\"text\" value=\"${esc(s.name)}\" style=\"flex:1\">\n      <input type=\"text\" value=\"${esc(s.artist||'')}\" class=\"si\" style=\"flex:1\">\n      <button class=\"xi\" data-action=\"delRow\">×</button>`;\n    ml.appendChild(div);\n  });\n\n  // 文本字段\n  const map={album:'albumContent',lastPhoto:'lastPhoto',memo:'memoContent',\n    diaryText:'diaryText',deliveryItem:'deliveryItem',deliveryStatus:'deliveryStatus',\n    deliveryPref:'deliveryPref',mapPlaces:'mapPlaces',taobaoItems:'taobaoItems',\n    healthNote:'healthNote',weatherNote:'weatherNote'};\n  for(const k in map){\n    if(d[k]!=null){\n      const el=document.getElementById(map[k]);\n      if(el) el.value=d[k];\n    }\n  }\n\n  // 下拉框\n  const setSelect=(id,val)=>{\n    if(!val)return;\n    const sel=document.getElementById(id);\n    if(!sel)return;\n    for(const opt of sel.options){\n      if(opt.value===val||opt.text===val){sel.value=opt.value;return;}\n    }\n  };\n  setSelect('diaryMood',d.diaryMood);\n  setSelect('diaryWeather',d.diaryWeather);\n}\n\n// ══ GENERATE ══\nfunction generate(){\n  showOverlay('正在组装世界书…','处理 App 内容数据');\n  setTimeout(()=>{\n    try{\n      const d=collectData();\n      buildLorebook(d);\n      buildRegex(d);\n      buildTavoJS(d);\n      buildPrompt(d);\n      buildSummary(d);\n      hideOverlay();\n      goStep(3);\n    }catch(e){\n      console.error(e);\n      hideOverlay();\n      toast('生成错误：'+e.message);\n    }\n  },500);\n}\n\nfunction collectData(){\n  return{\n    name:v('cName')||'角色',emoji:v('cEmoji')||'🌸',\n    city:v('cCity')||'某城市',theme:v('cTheme'),\n    personality:v('cPersonality'),triggers:v('cTrigger'),\n    apps:getApps(),wechat:getWechat(),\n    mSong:v('mSong')||'小幸运',mArtist:v('mArtist')||'田馥甄',\n    music:getMusic(),album:v('albumContent'),lastPhoto:v('lastPhoto'),\n    memo:v('memoContent'),diaryText:v('diaryText'),\n    diaryMood:v('diaryMood')||'😌 平静',diaryWeather:v('diaryWeather')||'⛅ 多云',\n    deliveryItem:v('deliveryItem')||'奶茶',deliveryStatus:v('deliveryStatus')||'配送中',\n    deliveryPref:v('deliveryPref'),mapPlaces:v('mapPlaces'),\n    taobaoItems:v('taobaoItems'),healthNote:v('healthNote'),weatherNote:v('weatherNote'),\n  };\n}\n\n// ══ LOREBOOK ══\nfunction buildLorebook(d){\n  let uid=1;\n  const mk=(keywords,content,name)=>({\n    identifier:`entry-${uid++}`,name,content,enabled:true,\n    strategy:'keyword',keywords,secondaryKeywords:[],\n    secondaryKeywordStrategy:'none',scanDepth:4,\n    caseSensitive:false,matchWholeWord:false,\n    injectionPosition:'lorebookAfter',injectionDepth:4,\n    injectionRole:'system',probability:100,sticky:1,cooldown:0,delay:0,\n  });\n\n  const trigs=d.triggers.split(',').map(t=>t.trim()).filter(Boolean);\n  const entries=[];\n\n  entries.push(mk(trigs,\n    `[${d.name}的手机 · 桌面]\\n主题：${d.theme}\\n已开启App：${d.apps.join('、')}\\n\\n查看手机时，以第三人称描述桌面：壁纸颜色（${d.theme}风格）、时间、可见图标。自然融入叙事，不要列表罗列。`,\n    `${d.name}的手机桌面`));\n\n  if(d.apps.includes('wechat')&&d.wechat.length>0){\n    const lines=d.wechat.map(c=>`  ${c.emoji} ${c.name}${c.unread>0?` [未读${c.unread}]`:''} · 「${c.msg}」`).join('\\n');\n    entries.push(mk(['查看微信','打开微信','open_wechat','微信消息'],\n      `[${d.name}的微信]\\n${lines}\\n\\n选择1-2条最有情绪的展示，体现她的社交状态。未读消息自然带出她的反应。`,\n      `${d.name}的微信`));\n  }\n\n  if(d.apps.includes('music')){\n    const pl=[`  ♫ ${d.mSong} - ${d.mArtist}（正在播放·单曲循环）`,...d.music.map((s,i)=>`  ${i+2}. ${s.name} - ${s.artist}`)].join('\\n');\n    entries.push(mk(['查看音乐','打开音乐','open_music','歌单','在听什么'],\n      `[${d.name}的音乐]\\n当前：${d.mSong}（${d.mArtist}）· 单曲循环\\n\\n${pl}\\n\\n可带出她听这首歌的状态或这首歌对她的意义。`,\n      `${d.name}的音乐`));\n  }\n\n  if(d.apps.includes('album')&&(d.album||d.lastPhoto)){\n    entries.push(mk(['查看相册','打开相册','open_album','相册里'],\n      `[${d.name}的相册]\\n珍藏场景：${d.album||'日常碎片'}\\n最近一张：${d.lastPhoto||'（暂无）'}\\n\\n选1-2张最有情绪价值的照片，用细节渲染。`,\n      `${d.name}的相册`));\n  }\n\n  if(d.apps.includes('memo')&&d.memo){\n    const items=d.memo.split(',').map(m=>`  • ${m.trim()}`).join('\\n');\n    entries.push(mk(['查看备忘录','open_memo','备忘录'],\n      `[${d.name}的备忘录]\\n${items}\\n\\n选1-2条最有角色特色的展示。`,\n      `${d.name}的备忘录`));\n  }\n\n  if(d.apps.includes('diary')){\n    entries.push(mk(['查看日记','open_diary','心情日记','她的日记'],\n      `[${d.name}的心情日记]\\n今天 ${d.diaryMood} · ${d.diaryWeather}\\n\\n${d.diaryText||'（今天还没写）'}\\n\\n用第一人称展示，这是最私密的内容，可带出轻微的私密感。`,\n      `${d.name}的心情日记`));\n  }\n\n  if(d.apps.includes('delivery')){\n    entries.push(mk(['查看外卖','open_delivery','外卖订单','等外卖'],\n      `[${d.name}的外卖]\\n最新订单：${d.deliveryItem} · ${d.deliveryStatus}\\n城市：${d.city}\\n偏好：${d.deliveryPref||'甜食居多'}\\n\\n体现她等待时的状态，或这道食物与当下心情的契合。`,\n      `${d.name}的外卖`));\n  }\n\n  if(d.apps.includes('weather')){\n    entries.push(mk(['查看天气','open_weather','天气怎么样'],\n      `[${d.name}的天气]\\n位置：${d.city} · ${d.diaryWeather}\\n${d.weatherNote?'备注：'+d.weatherNote:''}\\n\\n用天气带出氛围，自然融入她的行为动机。`,\n      `${d.name}的天气`));\n  }\n\n  if(d.apps.includes('map')&&d.mapPlaces){\n    const places=d.mapPlaces.split(',').map(p=>`  📍 ${p.trim()}`).join('\\n');\n    entries.push(mk(['查看地图','open_map','地图上','在哪里'],\n      `[${d.name}的地图]\\n常去地点：\\n${places}\\n\\n收藏夹暗示她的生活轨迹，结合情境展示。`,\n      `${d.name}的地图`));\n  }\n\n  if(d.apps.includes('taobao')&&d.taobaoItems){\n    entries.push(mk(['查看淘宝','open_taobao','购物车'],\n      `[${d.name}的淘宝购物车]\\n${d.taobaoItems}\\n\\n这些商品反映她最近的心思和小心愿。`,\n      `${d.name}的淘宝`));\n  }\n\n  if(d.apps.includes('health')){\n    entries.push(mk(['查看健康','open_health','今日步数'],\n      `[${d.name}的健康]\\n${d.healthNote||'根据角色当下状态合理推断'}\\n\\n健康数据侧面反映生活状态，可带出情绪暗示。`,\n      `${d.name}的健康`));\n  }\n\n  const lb={name:`${d.name}的手机世界书`,description:`No.24角色室生成 · ${d.name}的手机桌面模拟`,entries};\n  window._lb=lb; window._cname=d.name;\n  document.getElementById('out-lorebook').textContent=JSON.stringify(lb,null,2);\n}\n\n// ══ REGEX ══\nfunction buildRegex(d){\n  const rx={\n    name:`${d.name}的手机桌面正则`,\n    entries:[\n      {name:'系统提示隐藏',findRegex:'/\\\\[系统提示[：:][^\\\\]]*\\\\]/gim',replaceString:'',placements:['char'],timing:'display',enabled:true},\n      {name:'手机界面美化（可选）',findRegex:'/\\\\[([^的\\\\]]+的手机[^\\\\]]*)\\\\]/gim',replaceString:'📱 $1',placements:['char'],timing:'display',enabled:false}\n    ]\n  };\n  window._rx=rx;\n  document.getElementById('out-regex').textContent=JSON.stringify(rx,null,2);\n}\n\n// ══ TAVO JS ══\nfunction buildTavoJS(d){\n  const js=`// ══════════════════════════════════════════\n// No.24 角色室 · ${d.name} 手机桌面自动导入脚本\n// 在 Tavo JavaScript 控制台中执行\n// ══════════════════════════════════════════\n(async () => {\n  tavo.utils.toast('开始导入 ${d.name} 的手机世界书…');\n\n  // 1. 创建世界书\n  const lorebookData = ${JSON.stringify(window._lb,null,2)};\n  const lbId = await tavo.lorebook.create(lorebookData);\n  if (!lbId) { tavo.utils.toast('世界书创建失败'); return; }\n  tavo.utils.toast('✦ 世界书已创建 ID:' + lbId);\n\n  // 2. 创建正则\n  const regexData = ${JSON.stringify(window._rx,null,2)};\n  const rxId = await tavo.regex.create(regexData);\n  if (rxId) tavo.utils.toast('✦ 正则已创建 ID:' + rxId);\n\n  // 3. 绑定世界书到当前聊天\n  const chat = await tavo.chat.current();\n  if (chat) {\n    const existIds = (chat.lorebooks || []).map(l => l.id);\n    await tavo.chat.update({ lorebooks: [...existIds, lbId] });\n    tavo.utils.toast('✦ 已绑定到当前聊天');\n  }\n\n  await new Promise(r => setTimeout(r, 400));\n  tavo.utils.toast('🎉 ${d.name} 的手机桌面导入完成！');\n  console.log('[No.24角色室] 完成', { lorebookId: lbId, regexId: rxId });\n})();`;\n\n  window._js=js;\n  document.getElementById('out-tavojs').textContent=js;\n}\n\n// ══ PROMPT ══\nfunction buildPrompt(d){\n  const appNames=d.apps.map(a=>({wechat:'微信',music:'音乐',album:'相册',memo:'备忘录',diary:'心情日记',delivery:'外卖',weather:'天气',taobao:'淘宝',map:'地图',health:'健康'}[a]||a)).join('、');\n  const prompt=`# ${d.name}的手机模拟预设\n由 No.24 角色室生成\n\n## 规则\n\n当对话出现手机情节时：\n\n**桌面**：描述${d.theme}风格的壁纸和氛围，不要罗列所有图标\n**已安装**：${appNames}\n\n**微信**：选1-2条最有情绪的消息，语气自然，未读消息自然带出反应\n\n**音乐**：当前播放 ${d.mSong}（${d.mArtist}）· 单曲循环，用音乐渲染氛围\n\n**日记**：第一人称，今日 ${d.diaryMood} · ${d.diaryWeather}，最私密的内容\n\n**整体原则**\n- 手机内容融入叙事，不突兀列出\n- 用细节暗示内心，而非直白说明\n- 手机是角色当下状态的镜子\n\n性格底色：${d.personality||'温柔内敛，略带神秘感'}`;\n\n  window._prompt=prompt;\n  document.getElementById('out-prompt').textContent=prompt;\n}\n\n// ══ SUMMARY ══\nfunction buildSummary(d){\n  const cnt=document.getElementById('out-lorebook').textContent.split('\"identifier\"').length-1;\n  document.getElementById('sumGrid').innerHTML=`\n    <div class=\"sc2\"><div class=\"sk\">角色</div><div class=\"sv\">${d.emoji} ${d.name}</div><div class=\"ss\">${d.city}</div></div>\n    <div class=\"sc2\"><div class=\"sk\">开启 App</div><div class=\"sv\">${d.apps.length} 个</div><div class=\"ss\">${d.apps.slice(0,4).join(' · ')}</div></div>\n    <div class=\"sc2\"><div class=\"sk\">微信联系人</div><div class=\"sv\">${d.wechat.length} 位</div></div>\n    <div class=\"sc2\"><div class=\"sk\">歌单</div><div class=\"sv\">${d.music.length+1} 首</div><div class=\"ss\">播放：${d.mSong}</div></div>\n    <div class=\"sc2\"><div class=\"sk\">世界书条目</div><div class=\"sv\">${cnt} 条</div></div>`;\n}\n\n// ══ TAB ══\nlet curTab='lorebook';\nfunction switchTab(tab,btn){\n  document.querySelectorAll('.ot').forEach(t=>t.classList.remove('active'));\n  document.querySelectorAll('.code-out').forEach(b=>b.classList.remove('vis'));\n  btn.classList.add('active');\n  document.getElementById('out-'+tab).classList.add('vis');\n  curTab=tab;\n}\n\n// ══ DOWNLOAD ══\nfunction dl(name,content,type='application/json'){\n  const blob=new Blob([content],{type});\n  const url=URL.createObjectURL(blob);\n  const a=document.createElement('a');\n  a.href=url;a.download=name;a.click();\n  URL.revokeObjectURL(url);\n}\nfunction dlLorebook(){dl(`${window._cname||'角色'}_手机世界书.json`,JSON.stringify(window._lb,null,2));toast('✦ 世界书已下载');}\nfunction dlRegex(){dl(`${window._cname||'角色'}_手机正则.json`,JSON.stringify(window._rx,null,2));toast('✦ 正则已下载');}\nfunction dlAll(){\n  dlLorebook();\n  setTimeout(()=>dlRegex(),300);\n  setTimeout(()=>dl(`${window._cname||'角色'}_Tavo导入脚本.js`,window._js,'text/javascript'),600);\n  setTimeout(()=>dl(`${window._cname||'角色'}_系统预设.txt`,window._prompt,'text/plain'),900);\n  toast('📦 四个文件正在下载…');\n}\nfunction copyActive(){\n  const el=document.getElementById('out-'+curTab);\n  navigator.clipboard.writeText(el.textContent).then(()=>toast('✦ 已复制到剪贴板'));\n}\n\n// ══ OVERLAY & TOAST ══\nfunction showOverlay(msg,sub){\n  document.getElementById('ovMsg').textContent=msg;\n  document.getElementById('ovSub').textContent=sub;\n  document.getElementById('overlay').classList.add('show');\n}\nfunction hideOverlay(){document.getElementById('overlay').classList.remove('show');}\nfunction toast(msg){\n  const t=document.getElementById('toast');\n  t.textContent=msg;t.classList.add('show');\n  setTimeout(()=>t.classList.remove('show'),2800);\n}\n</script>\n</body>\n</html>","trimStrings":[],"placements":["char"],"timing":"display","substitution":"none","minDepth":null,"maxDepth":null,"enabled":true}]}