{"id":281,"name":"记忆格式转换插件's Regex","entries":[{"identifier":"849e0532-32ea-438c-88e7-b3ad33a5969a","name":"记忆格式转换插件启动","findRegex":"$","replaceString":"<script>\n(function(){\ntry{\n  var T; try{T=window.top||window}catch(_){T=window}\n  var D=T.document||document;\n  var KEY='rf_booted';\n  if(T[KEY])return;\n  T[KEY]=true;\n\n  var css=D.createElement('style');\n  css.textContent=[\n    '#rf-btn{',\n      'position:fixed;bottom:90px;right:72px;z-index:9500;',\n      'width:48px;height:48px;border-radius:50%;',\n      'background:linear-gradient(135deg,rgba(60,150,220,0.92),rgba(80,190,255,0.88));',\n      'border:1px solid rgba(120,200,255,0.5);',\n      'box-shadow:0 4px 18px rgba(60,150,255,0.45);',\n      'display:flex;align-items:center;justify-content:center;',\n      'font-size:20px;cursor:pointer;backdrop-filter:blur(10px);',\n      'transition:transform .15s,box-shadow .15s;',\n    '}',\n    '#rf-btn:hover{transform:scale(1.08);box-shadow:0 6px 24px rgba(80,170,255,0.6);}',\n    '#rf-btn:active{transform:scale(0.95);}',\n    '#rf-mask{position:fixed;inset:0;z-index:9600;background:rgba(0,0,0,0.45);backdrop-filter:blur(2px);}',\n    '#rf-pop{',\n      'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);',\n      'z-index:9700;width:360px;max-width:90vw;max-height:78vh;',\n      'background:rgba(10,14,28,0.97);border:1px solid rgba(80,170,255,0.35);',\n      'border-radius:18px;padding:18px 20px;overflow-y:auto;',\n      'box-shadow:0 12px 40px rgba(0,0,0,0.6);',\n    '}',\n    '#rf-pop .rf-title{color:#93c5fd;font-size:15px;font-weight:700;margin-bottom:6px;display:flex;align-items:center;gap:6px;}',\n    '#rf-pop .rf-sub{color:#94a3b8;font-size:12px;margin-bottom:14px;line-height:1.5;}',\n    '#rf-pop .rf-stat{display:flex;justify-content:space-between;background:rgba(255,255,255,0.05);border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;color:#e2e8f0;}',\n    '#rf-pop .rf-stat b{color:#93c5fd;}',\n    '#rf-list{max-height:240px;overflow-y:auto;margin-bottom:14px;}',\n    '.rf-item{font-size:12px;color:#cbd5e1;background:rgba(255,255,255,0.04);border-radius:8px;padding:7px 10px;margin-bottom:5px;line-height:1.4;white-space:pre-wrap;}',\n    '.rf-item .rf-tag{color:#93c5fd;font-weight:700;display:block;margin-bottom:3px;}',\n    '#rf-go{width:100%;padding:11px;border:none;border-radius:10px;background:linear-gradient(135deg,#3b82f6,#06b6d4);color:#fff;font-size:13px;font-weight:700;cursor:pointer;margin-bottom:8px;}',\n    '#rf-go:disabled{opacity:.5;cursor:not-allowed;}',\n    '#rf-cancel{width:100%;padding:9px;border:1px solid rgba(255,255,255,0.12);border-radius:10px;background:transparent;color:#94a3b8;font-size:12px;cursor:pointer;}',\n    '#rf-toast{position:fixed;top:20px;left:50%;transform:translateX(-50%);background:rgba(16,20,38,0.95);color:#e2e8f0;padding:9px 18px;border-radius:20px;font-size:13px;z-index:10000;border:1px solid rgba(80,170,255,0.3);opacity:0;transition:opacity .25s;pointer-events:none;white-space:nowrap;}',\n    '#rf-toast.show{opacity:1;top:60px;transition:opacity .25s,top .25s;}',\n  ].join('');\n  D.head.appendChild(css);\n\n  function mk(t,a,p){var e=D.createElement(t);Object.keys(a||{}).forEach(function(k){e[k]=a[k]});if(p)p.appendChild(e);return e;}\n  function rm(el){el&&el.parentNode&&el.parentNode.removeChild(el);}\n\n  function toast(msg,dur){\n    var el=D.getElementById('rf-toast')||mk('div',{id:'rf-toast'},D.body);\n    el.textContent=msg;el.classList.add('show');\n    clearTimeout(el._t);\n    el._t=setTimeout(function(){el.classList.remove('show');},dur||2500);\n  }\n\n  function closePop(){rm(D.getElementById('rf-mask'));rm(D.getElementById('rf-pop'));}\n\n  function renderBlockItem(container, blockText){\n    var lines = blockText.split('\\n').filter(function(l){return l.trim().length>0;});\n    var item = mk('div',{className:'rf-item'}, container);\n    if(lines.length && /^\\[.*\\]$/.test(lines[0].trim())){\n      var tag = mk('span',{className:'rf-tag'}, item);\n      tag.textContent = lines[0].trim();\n      var rest = lines.slice(1).join('\\n');\n      item.appendChild(D.createTextNode(rest));\n    } else {\n      item.textContent = blockText;\n    }\n  }\n\n  function buildConfirmPop(memories){\n    closePop();\n    var mask=mk('div',{id:'rf-mask'},D.body);\n    mask.addEventListener('click',closePop);\n\n    var pop=mk('div',{id:'rf-pop'},D.body);\n    pop.addEventListener('click',function(e){e.stopPropagation();});\n\n    var title=mk('div',{className:'rf-title'},pop);\n    title.innerHTML='<span>🗂️</span><span>记忆格式转换</span>';\n\n    var sub=mk('div',{className:'rf-sub'},pop);\n    sub.textContent='将按事件把相关记忆归并为 [人物 — 事件] + 细节 的结构化格式，不会丢失任何信息。';\n\n    var stat=mk('div',{className:'rf-stat'},pop);\n    stat.innerHTML='当前记忆条数 &nbsp;<b>'+memories.length+'</b> 条';\n\n    var list=mk('div',{id:'rf-list'},pop);\n    memories.forEach(function(m){\n      var item=mk('div',{className:'rf-item'},list);\n      item.textContent=m;\n    });\n\n    var go=mk('button',{id:'rf-go'},pop);\n    go.textContent='开始转换';\n    go.addEventListener('click',function(){ doReformat(memories,go); });\n\n    var cancel=mk('button',{id:'rf-cancel'},pop);\n    cancel.textContent='取消';\n    cancel.addEventListener('click',closePop);\n  }\n\n  function buildResultPop(before,after,newMemories){\n    closePop();\n    var mask=mk('div',{id:'rf-mask'},D.body);\n    mask.addEventListener('click',closePop);\n\n    var pop=mk('div',{id:'rf-pop'},D.body);\n    pop.addEventListener('click',function(e){e.stopPropagation();});\n\n    var title=mk('div',{className:'rf-title'},pop);\n    title.innerHTML='<span>✅</span><span>转换完成</span>';\n\n    var stat=mk('div',{className:'rf-stat'},pop);\n    stat.innerHTML=before+' 条 → <b>'+after+'</b> 个事件块';\n\n    var list=mk('div',{id:'rf-list'},pop);\n    newMemories.forEach(function(m){\n      renderBlockItem(list, m);\n    });\n\n    var go=mk('button',{id:'rf-go'},pop);\n    go.textContent='完成';\n    go.addEventListener('click',closePop);\n  }\n\n  async function doReformat(memories,btn){\n    btn.disabled=true;\n    btn.textContent='转换中…';\n    try{\n      var memoryList=memories.map(function(m,i){return (i+1)+'. '+m;}).join('\\n');\n\n      var prompt='以下是当前的记忆列表（每行一条，互相独立）：\\n'+memoryList+'\\n\\n'+\n        '请将这些记忆按所属事件归并为结构化的事件块。\\n'+\n        '要求：\\n'+\n        '1. 描述同一事件、同一场景、同一次互动的多条记忆，归并为同一个事件块\\n'+\n        '2. 每个事件块的第一行是标题，格式：\"[涉及人物 — 事件简述]\"，涉及人物用逗号分隔，主角在前\\n'+\n        '3. 标题行之后，用\"· \"开头列出该事件的具体细节，每条占一行\\n'+\n        '4. 不属于任何事件、单独的个人信息（如年龄、过敏史等）保持独立，格式仍为\"[User — 个人信息]\"+一条\"· \"细节\\n'+\n        '5. 不要丢失任何原有信息，不要编造新信息\\n'+\n        '6. 不同事件块之间，用一个单独的分隔行 \"===\" 隔开\\n'+\n        '7. 不要输出任何解释、编号或前言，只输出事件块本身\\n\\n'+\n        '输出格式示例：\\n'+\n        '[User, 维多利亚·凌 — 海边约会]\\n'+\n        '· 共进海鲜大餐并观看日落\\n'+\n        '· User视为今年最开心的一天\\n'+\n        '===\\n'+\n        '[User — 童年回忆]\\n'+\n        '· 童年养猫因病去世，仍有自责感';\n\n      var result=await tavo.generate(prompt,{context:false});\n\n      var newMemories=result.split('===')\n        .map(function(block){return block.trim();})\n        .filter(function(block){return block.length>0;});\n\n      if(newMemories.length===0){\n        toast('❌ 转换结果为空，已取消保存');\n        closePop();\n        return;\n      }\n\n      var memory=await tavo.memory.current();\n      var before=memory.memories.length;\n      memory.memories=newMemories;\n      await tavo.memory.update(memory);\n\n      buildResultPop(before,newMemories.length,newMemories);\n    }catch(err){\n      console.error('[记忆格式转换]',err);\n      toast('❌ 失败：'+(err&&err.message||String(err)));\n      closePop();\n    }\n  }\n\n  async function openReformat(){\n    try{\n      var memory=await tavo.memory.current();\n      if(!memory.memories||memory.memories.length===0){\n        toast('当前没有记忆可转换');\n        return;\n      }\n      buildConfirmPop(memory.memories);\n    }catch(err){\n      console.error('[记忆格式转换]',err);\n      toast('❌ 读取记忆失败：'+(err&&err.message||String(err)));\n    }\n  }\n\n  function buildButton(){\n    if(D.getElementById('rf-btn'))return;\n    var btn=mk('div',{id:'rf-btn',title:'转换为事件块格式'},D.body);\n    btn.textContent='🗂️';\n    btn.addEventListener('click',function(e){\n      e.stopPropagation();\n      openReformat();\n    });\n  }\n\n  buildButton();\n  console.log('[记忆格式转换插件v1] 已加载');\n\n}catch(e){console.error('[记忆格式转换插件]',e);}\n})();\n</script>","trimStrings":[],"placements":["user"],"timing":"display","substitution":"none","minDepth":null,"maxDepth":null,"enabled":true},{"identifier":"09a2fc40-f62a-4ebf-8e67-b0b9b893c9c4","name":"记忆格式转换指令清理","findRegex":"/<RF_CMD>[\\s\\S]*?<\\/RF_CMD>/gi","replaceString":"","trimStrings":[],"placements":["char"],"timing":"display","substitution":"none","minDepth":null,"maxDepth":null,"enabled":true}]}