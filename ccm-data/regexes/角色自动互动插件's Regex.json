{"id":310,"name":"角色自动互动插件's Regex","entries":[{"identifier":"21c8db72-5ba3-4238-ae56-cc4aa1b142f9","name":"自动互动插件启动","findRegex":"$","replaceString":"<script>\n(function(){\ntry{\n  var T; try{T=window.top||window}catch(_){T=window}\n  var D=T.document||document;\n\n  // ---- 本实例绑定的聊天ID（用于安全判定：只在“正打开这个聊天”时才真正发送消息，避免切到别的聊天时误发）----\n  var MY_CHAT_ID = null;\n  var chatIdReady = (async function(){\n    try{ var c = await tavo.chat.current(); MY_CHAT_ID = (c && c.id != null) ? c.id : null; }catch(e){}\n  })();\n\n  var DEFAULT_ALARM = {\n    id:'default_morning', label:'工作日早晨叫醒', enabled:false,\n    days:[1,2,3,4,5], startTime:'08:00', endTime:'08:30',\n    probMin:100, probMax:100, prompt:'今天她要上班，该叫她起床了。'\n  };\n  var DEFAULTS={\n    autoMsg:{enabled:false, idleMinutes:10, maxPerSession:3},\n    burst:{enabled:false, maxParts:3, delayMs:900},\n    stickerOnly:{enabled:false},\n    alarms:[DEFAULT_ALARM]\n  };\n\n  function loadSettings(){\n    try{ var s=tavo.get('amg_settings'); if(s&&typeof s==='object'){\n      return {\n        autoMsg:Object.assign({},DEFAULTS.autoMsg,s.autoMsg||{}),\n        burst:Object.assign({},DEFAULTS.burst,s.burst||{}),\n        stickerOnly:Object.assign({},DEFAULTS.stickerOnly,s.stickerOnly||{}),\n        alarms:(Array.isArray(s.alarms) && s.alarms.length) ? s.alarms : JSON.parse(JSON.stringify(DEFAULTS.alarms))\n      };\n    } }catch(e){}\n    return JSON.parse(JSON.stringify(DEFAULTS));\n  }\n  function saveSettings(s){ try{ tavo.set('amg_settings', s); }catch(e){} }\n\n  function loadState(){\n    try{ var st=tavo.get('amg_state'); if(st&&typeof st==='object'){ return Object.assign({lastTriggerMap:{}}, st); } }catch(e){}\n    return {lastTriggerMap:{}};\n  }\n  function saveState(st){ try{ tavo.set('amg_state', st); }catch(e){} }\n\n  function pad2(n){ return (n<10?'0':'')+n; }\n  function todayStr(){ var d=new Date(); return d.getFullYear()+'-'+pad2(d.getMonth()+1)+'-'+pad2(d.getDate()); }\n  function nowHHMM(){ var d=new Date(); return pad2(d.getHours())+':'+pad2(d.getMinutes()); }\n  function inTimeWindow(cur,start,end){ if(!start||!end) return false; return start<=end ? (cur>=start&&cur<=end) : (cur>=start||cur<=end); }\n  function rollProb(min,max){ var lo=Math.min(min,max), hi=Math.max(min,max); var p=lo+Math.random()*(hi-lo); return Math.random()*100 < p; }\n\n  async function isActiveChat(){\n    try{ var c=await tavo.chat.current(); return !!(c && MY_CHAT_ID!=null && c.id===MY_CHAT_ID); }catch(e){ return false; }\n  }\n\n  async function fireProactive(prompt, tag){\n    try{\n      var reaction=await tavo.generate(prompt, {context:true});\n      await tavo.message.append({role:'assistant', content:reaction});\n      return true;\n    }catch(err){ console.error('[自动互动-'+tag+']',err); return false; }\n  }\n\n  async function checkAlarms(s, st){\n    if(!(await isActiveChat())) return;\n    var today=todayStr(), cur=nowHHMM(), dow=new Date().getDay(), changed=false;\n    var list = s.alarms||[];\n    for(var i=0;i<list.length;i++){\n      var a=list[i];\n      if(!a || !a.enabled) continue;\n      if(!Array.isArray(a.days) || a.days.indexOf(dow)===-1) continue;\n      if(st.lastTriggerMap[a.id]===today) continue;\n      if(!inTimeWindow(cur, a.startTime, a.endTime)) continue;\n      if(!rollProb(a.probMin!=null?a.probMin:100, a.probMax!=null?a.probMax:100)) continue;\n      var prompt='系统提示（仅你可见，不要在回复中提及这是系统提示）：现在触发了一条定时提醒「'+(a.label||'提醒')+'」。请用你的角色身份和语气，围绕下面这句设定自然地对对方说一句话，可以适当发挥但要贴合情境，不要机械复述原句：'+(a.prompt||'');\n      var ok=await fireProactive(prompt, 'alarm');\n      if(ok){ st.lastTriggerMap[a.id]=today; changed=true; }\n    }\n    if(changed) saveState(st);\n  }\n\n  async function checkAutoMsgTick(s){\n    if(!s.autoMsg.enabled) return;\n    if(!(await isActiveChat())) return;\n    var last=0; try{ last=tavo.get('amg_last_activity')||0; }catch(e){}\n    var count=0; try{ count=tavo.get('amg_proactive_count')||0; }catch(e){}\n    if(count >= s.autoMsg.maxPerSession) return;\n    var idleMs=Date.now()-last;\n    var thresholdMs=(s.autoMsg.idleMinutes||10)*60000;\n    if(idleMs < thresholdMs) return;\n    try{ tavo.set('amg_last_activity', Date.now()); tavo.set('amg_proactive_count', count+1); }catch(e){}\n    await fireProactive('系统提示（仅你可见，不要在回复中提及这是系统提示）：你已经有一段时间没收到对方的新消息了。请用你的角色身份和语气，主动发一条消息找对方聊聊——可以是分享点什么、问候、想念对方、或者撒娇式地找存在感，简短自然，符合你的人设。', 'autoMsg');\n  }\n\n  // 切回/进入这个聊天时的补发检查：不需要真的“在后台运行”，\n  // 只要这个聊天再次被打开渲染，就用记录下来的上次活动时间判断你离开了多久，\n  // 超过阈值就立刻补一条“我等你很久了”式的消息，效果上等同于角色在你不在时找过你。\n  async function catchUpOnEnter(s){\n    if(!s.autoMsg.enabled) return;\n    var last=0; try{ last=tavo.get('amg_last_activity')||0; }catch(e){}\n    var count=0; try{ count=tavo.get('amg_proactive_count')||0; }catch(e){}\n    if(!last || count >= s.autoMsg.maxPerSession) return;\n    var idleMs=Date.now()-last;\n    var thresholdMs=(s.autoMsg.idleMinutes||10)*60000;\n    if(idleMs < thresholdMs) return;\n    try{ tavo.set('amg_last_activity', Date.now()); tavo.set('amg_proactive_count', count+1); }catch(e){}\n    await fireProactive('系统提示（仅你可见，不要在回复中提及这是系统提示）：对方刚刚回到和你的对话——你已经有一段时间没收到TA的新消息了。请用你的角色身份和语气主动开口，可以是想念、撒娇式地问对方去哪了、或者自然地接上话题，简短自然，符合你的人设。', 'catchup');\n  }\n\n  // ---- 活动刷新 + 切入检测：每次用户消息渲染都会执行，不受下面的单次初始化锁限制 ----\n  (async function(){\n    try{\n      await chatIdReady;\n      if(MY_CHAT_ID==null) return;\n      var isNewVisit = (T.amg_last_seen_chat !== MY_CHAT_ID);\n      T.amg_last_seen_chat = MY_CHAT_ID;\n      if(isNewVisit){\n        var s0 = loadSettings();\n        await catchUpOnEnter(s0);\n      }\n      tavo.set('amg_last_activity', Date.now());\n      tavo.set('amg_proactive_count', 0);\n    }catch(e0){}\n  })();\n\n  var KEY='amg_booted';\n  if(T[KEY])return;\n  T[KEY]=true;\n\n  var css=D.createElement('style');\n  css.textContent=[\n    '#amg-btn{position:fixed;bottom:370px;right:16px;z-index:9500;width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,rgba(251,146,60,0.92),rgba(168,85,247,0.85));border:1px solid rgba(255,200,150,0.5);box-shadow:0 4px 18px rgba(251,146,60,0.45);display:flex;align-items:center;justify-content:center;font-size:20px;cursor:pointer;backdrop-filter:blur(10px);transition:transform .15s;}',\n    '#amg-btn:hover{transform:scale(1.08);}',\n    '#amg-btn:active{transform:scale(0.95);}',\n    '#amg-mask{position:fixed;inset:0;z-index:9600;background:rgba(0,0,0,0.45);backdrop-filter:blur(2px);}',\n    '#amg-pop{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:9700;width:330px;max-width:92vw;max-height:84vh;background:rgba(16,12,10,0.97);border:1px solid rgba(251,146,60,0.35);border-radius:18px;padding:16px;overflow-y:auto;box-shadow:0 12px 40px rgba(0,0,0,0.6);color:#e2e8f0;}',\n    '.amg-title{font-size:15px;font-weight:700;margin-bottom:10px;display:flex;align-items:center;gap:6px;color:#fdba74;}',\n    '#amg-close{position:absolute;top:12px;right:14px;font-size:18px;color:#94a3b8;cursor:pointer;background:none;border:none;}',\n    '.amg-sec{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:12px;padding:11px 12px;margin-bottom:10px;}',\n    '.amg-sec-head{display:flex;align-items:center;justify-content:space-between;}',\n    '.amg-sec-head .nm{font-size:13px;font-weight:700;}',\n    '.amg-sec-desc{font-size:11px;color:#94a3b8;margin-top:4px;line-height:1.5;}',\n    '.amg-sw{position:relative;width:40px;height:23px;border-radius:13px;background:rgba(255,255,255,0.15);cursor:pointer;flex-shrink:0;}',\n    '.amg-sw.on{background:linear-gradient(135deg,#fb923c,#a855f7);}',\n    '.amg-sw .dot{position:absolute;top:2px;left:2px;width:19px;height:19px;border-radius:50%;background:#fff;transition:left .15s;}',\n    '.amg-sw.on .dot{left:19px;}',\n    '.amg-row{display:flex;align-items:center;justify-content:space-between;margin-top:8px;font-size:11.5px;color:#cbd5e1;gap:6px;}',\n    '.amg-row select,.amg-row input[type=range]{flex:0 0 auto;}',\n    '.amg-row select{background:rgba(255,255,255,0.08);color:#e2e8f0;border:1px solid rgba(255,255,255,0.15);border-radius:7px;padding:3px 6px;font-size:11.5px;}',\n    '#amg-save{width:100%;padding:11px;border:none;border-radius:10px;background:linear-gradient(135deg,#fb923c,#a855f7);color:#fff;font-weight:700;cursor:pointer;margin-top:6px;}',\n    '#amg-toast{position:fixed;top:20px;left:50%;transform:translateX(-50%);background:rgba(16,20,38,0.95);color:#e2e8f0;padding:9px 18px;border-radius:20px;font-size:13px;z-index:10000;border:1px solid rgba(251,146,60,0.3);opacity:0;transition:opacity .25s;pointer-events:none;white-space:nowrap;}',\n    '#amg-toast.show{opacity:1;top:60px;transition:opacity .25s,top .25s;}',\n    '.amg-alarm-card{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:9px 10px;margin-top:9px;}',\n    '.amg-alarm-head{display:flex;align-items:center;gap:8px;}',\n    '.amg-alarm-name{flex:1;min-width:0;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.14);border-radius:7px;color:#e2e8f0;font-size:12.5px;font-weight:600;padding:5px 8px;}',\n    '.amg-alarm-del{background:none;border:none;color:#f87171;font-size:14px;cursor:pointer;flex-shrink:0;padding:2px 4px;}',\n    '.amg-days{display:flex;gap:5px;margin-top:9px;}',\n    '.amg-day{width:26px;height:26px;border-radius:50%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);display:flex;align-items:center;justify-content:center;font-size:11px;color:#94a3b8;cursor:pointer;flex-shrink:0;}',\n    '.amg-day.on{background:linear-gradient(135deg,#fb923c,#a855f7);color:#fff;border-color:transparent;}',\n    '.amg-row input[type=time]{background:rgba(255,255,255,0.08);color:#e2e8f0;border:1px solid rgba(255,255,255,0.15);border-radius:7px;padding:3px 6px;font-size:11.5px;flex:1;min-width:0;}',\n    '.amg-prob{width:44px;background:rgba(255,255,255,0.08);color:#e2e8f0;border:1px solid rgba(255,255,255,0.15);border-radius:7px;padding:3px 5px;font-size:11.5px;text-align:center;}',\n    '.amg-alarm-plabel{font-size:11px;color:#94a3b8;margin-top:9px;}',\n    '.amg-alarm-prompt{width:100%;box-sizing:border-box;margin-top:5px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.14);border-radius:7px;color:#e2e8f0;font-size:12px;padding:7px 8px;min-height:52px;resize:vertical;font-family:inherit;}',\n    '#amg-alarm-add{width:100%;padding:9px;border:1px dashed rgba(251,146,60,0.5);border-radius:9px;background:rgba(251,146,60,0.08);color:#fdba74;font-weight:600;font-size:12.5px;cursor:pointer;margin-top:10px;}',\n  ].join('');\n  D.head.appendChild(css);\n\n  function mk(t,a,p){var e=D.createElement(t);Object.keys(a||{}).forEach(function(k){e[k]=a[k]});if(p)p.appendChild(e);return e;}\n  function rm(el){el&&el.parentNode&&el.parentNode.removeChild(el);}\n  function toast(msg,dur){\n    var el=D.getElementById('amg-toast')||mk('div',{id:'amg-toast'},D.body);\n    el.textContent=msg;el.classList.add('show');\n    clearTimeout(el._t);el._t=setTimeout(function(){el.classList.remove('show');},dur||2200);\n  }\n  function closePop(){rm(D.getElementById('amg-mask'));rm(D.getElementById('amg-pop'));}\n\n  function dayLabel(n){ return ['日','一','二','三','四','五','六'][n]; }\n\n  function openPanel(){\n    var s=loadSettings();\n    closePop();\n    var mask=mk('div',{id:'amg-mask'},D.body); mask.addEventListener('click',closePop);\n    var pop=mk('div',{id:'amg-pop'},D.body); pop.addEventListener('click',function(e){e.stopPropagation();});\n    var closeBtn=mk('button',{id:'amg-close'},pop); closeBtn.textContent='✕'; closeBtn.addEventListener('click',closePop);\n    var title=mk('div',{className:'amg-title'},pop); title.innerHTML='<span>🔔</span><span>角色自动互动设置</span>';\n\n    // 自动发消息\n    var sec1=mk('div',{className:'amg-sec'},pop);\n    var h1=mk('div',{className:'amg-sec-head'},sec1);\n    mk('span',{className:'nm'},h1).textContent='💬 自动发消息';\n    var sw1=mk('div',{className:'amg-sw'+(s.autoMsg.enabled?' on':'')},h1); mk('div',{className:'dot'},sw1);\n    sw1.addEventListener('click',function(){ s.autoMsg.enabled=!s.autoMsg.enabled; sw1.classList.toggle('on',s.autoMsg.enabled); });\n    mk('div',{className:'amg-sec-desc'},sec1).textContent='你不说话太久时，角色会主动找你聊。仅在你正打开这个聊天页面时才会真正发送；如果这段时间你切去了别的聊天，角色不会跨窗口偷偷发消息，而是会在你下次重新打开这个聊天时，按你离开的时长立刻补上一条，效果上就像它一直在等你。';\n    var r1=mk('div',{className:'amg-row'},sec1);\n    mk('span',{},r1).textContent='无活动多久后触发';\n    var sel1=mk('select',{},r1);\n    [5,10,15,30,60].forEach(function(m){ var o=mk('option',{value:m},sel1); o.textContent=m+'分钟'; if(m===s.autoMsg.idleMinutes)o.selected=true; });\n    sel1.addEventListener('change',function(){ s.autoMsg.idleMinutes=parseInt(sel1.value,10); });\n    var r1b=mk('div',{className:'amg-row'},sec1);\n    mk('span',{},r1b).textContent='每次对话最多主动发';\n    var rangeMax=mk('input',{type:'range',min:'1',max:'5',value:String(s.autoMsg.maxPerSession)},r1b);\n    var rangeMaxVal=mk('span',{},r1b); rangeMaxVal.textContent=s.autoMsg.maxPerSession+'条';\n    rangeMax.addEventListener('input',function(){ s.autoMsg.maxPerSession=parseInt(rangeMax.value,10); rangeMaxVal.textContent=s.autoMsg.maxPerSession+'条'; });\n\n    // 连续发消息\n    var sec2=mk('div',{className:'amg-sec'},pop);\n    var h2=mk('div',{className:'amg-sec-head'},sec2);\n    mk('span',{className:'nm'},h2).textContent='📩 连续发消息';\n    var sw2=mk('div',{className:'amg-sw'+(s.burst.enabled?' on':'')},h2); mk('div',{className:'dot'},sw2);\n    sw2.addEventListener('click',function(){ s.burst.enabled=!s.burst.enabled; sw2.classList.toggle('on',s.burst.enabled); });\n    mk('div',{className:'amg-sec-desc'},sec2).textContent='把角色一条长回复按句子拆成多条连续气泡发出，模拟真人连续打字的感觉。';\n    var r2=mk('div',{className:'amg-row'},sec2);\n    mk('span',{},r2).textContent='最多拆成几条';\n    var rangeParts=mk('input',{type:'range',min:'2',max:'5',value:String(s.burst.maxParts)},r2);\n    var rangePartsVal=mk('span',{},r2); rangePartsVal.textContent=s.burst.maxParts+'条';\n    rangeParts.addEventListener('input',function(){ s.burst.maxParts=parseInt(rangeParts.value,10); rangePartsVal.textContent=s.burst.maxParts+'条'; });\n    var r2b=mk('div',{className:'amg-row'},sec2);\n    mk('span',{},r2b).textContent='每条间隔';\n    var rangeDelay=mk('input',{type:'range',min:'400',max:'2000',step:'100',value:String(s.burst.delayMs)},r2b);\n    var rangeDelayVal=mk('span',{},r2b); rangeDelayVal.textContent=s.burst.delayMs+'ms';\n    rangeDelay.addEventListener('input',function(){ s.burst.delayMs=parseInt(rangeDelay.value,10); rangeDelayVal.textContent=s.burst.delayMs+'ms'; });\n\n    // 只回表情包\n    var sec3=mk('div',{className:'amg-sec'},pop);\n    var h3=mk('div',{className:'amg-sec-head'},sec3);\n    mk('span',{className:'nm'},h3).textContent='🐻 只回表情包';\n    var sw3=mk('div',{className:'amg-sw'+(s.stickerOnly.enabled?' on':'')},h3); mk('div',{className:'dot'},sw3);\n    sw3.addEventListener('click',function(){ s.stickerOnly.enabled=!s.stickerOnly.enabled; sw3.classList.toggle('on',s.stickerOnly.enabled); });\n    mk('div',{className:'amg-sec-desc'},sec3).textContent='开启后角色的每条回复都只显示一张表情贴纸（按情绪自动选），不显示文字。文字仍会正常存进聊天记录供角色记忆，只是不展示。开启时与“连续发消息”不会同时生效。';\n\n    // 定时提醒（自定义 + 图二示例“工作日早晨叫醒”）\n    var sec4=mk('div',{className:'amg-sec'},pop);\n    var h4=mk('div',{className:'amg-sec-head'},sec4);\n    mk('span',{className:'nm'},h4).textContent='⏰ 定时提醒';\n    mk('div',{className:'amg-sec-desc'},sec4).textContent='到设定的星期几和时间段，角色会按概率主动找你说一句你写的提示词。同样只在你正打开这个聊天时才会真正发送，不会跨窗口误发；可以自由添加/删除多条。';\n    var alarmList=mk('div',{id:'amg-alarm-list'},sec4);\n\n    function renderAlarms(){\n      alarmList.innerHTML='';\n      (s.alarms=s.alarms||[]).forEach(function(a, idx){\n        var card=mk('div',{className:'amg-alarm-card'},alarmList);\n        var head=mk('div',{className:'amg-alarm-head'},card);\n        var nameInput=mk('input',{type:'text',className:'amg-alarm-name',value:a.label||'',placeholder:'提醒名称'},head);\n        nameInput.addEventListener('input',function(){ a.label=nameInput.value; });\n        var swA=mk('div',{className:'amg-sw'+(a.enabled?' on':'')},head); mk('div',{className:'dot'},swA);\n        swA.addEventListener('click',function(){ a.enabled=!a.enabled; swA.classList.toggle('on',a.enabled); });\n        var delBtn=mk('button',{className:'amg-alarm-del'},head); delBtn.textContent='🗑';\n        delBtn.addEventListener('click',function(){ s.alarms.splice(idx,1); renderAlarms(); });\n\n        var daysRow=mk('div',{className:'amg-days'},card);\n        [1,2,3,4,5,6,0].forEach(function(d){\n          var chip=mk('div',{className:'amg-day'+(a.days&&a.days.indexOf(d)>-1?' on':'')},daysRow);\n          chip.textContent=dayLabel(d);\n          chip.addEventListener('click',function(){\n            a.days=a.days||[];\n            var i=a.days.indexOf(d);\n            if(i>-1) a.days.splice(i,1); else a.days.push(d);\n            chip.classList.toggle('on', a.days.indexOf(d)>-1);\n          });\n        });\n\n        var timeRow=mk('div',{className:'amg-row'},card);\n        mk('span',{},timeRow).textContent='时间段';\n        var t1=mk('input',{type:'time',value:a.startTime||'08:00'},timeRow);\n        t1.addEventListener('change',function(){ a.startTime=t1.value; });\n        mk('span',{},timeRow).textContent='至';\n        var t2=mk('input',{type:'time',value:a.endTime||'08:30'},timeRow);\n        t2.addEventListener('change',function(){ a.endTime=t2.value; });\n\n        var probRow=mk('div',{className:'amg-row'},card);\n        mk('span',{},probRow).textContent='概率';\n        var p1=mk('input',{type:'number',min:'0',max:'100',className:'amg-prob',value:String(a.probMin!=null?a.probMin:100)},probRow);\n        p1.addEventListener('input',function(){ a.probMin=Math.max(0,Math.min(100,parseInt(p1.value,10)||0)); });\n        mk('span',{},probRow).textContent='% 至';\n        var p2=mk('input',{type:'number',min:'0',max:'100',className:'amg-prob',value:String(a.probMax!=null?a.probMax:100)},probRow);\n        p2.addEventListener('input',function(){ a.probMax=Math.max(0,Math.mi