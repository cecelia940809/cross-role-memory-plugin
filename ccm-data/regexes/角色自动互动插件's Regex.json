rops, sorrowful droopy expression, no text, square composition, high quality vector illustration',\n        angry:'cute chibi white bear sticker, sticker pack style, thick bold black outline, flat simple colors, plain white background, puffed cheeks furrowed brows steam from head fists clenched angry, no text, square composition, high quality vector illustration',\n        shy:'cute chibi white bear sticker, sticker pack style, thick bold black outline, flat simple colors, plain white background, blushing cheeks covering face with paws looking away bashfully shy, no text, square composition, high quality vector illustration',\n        love:'cute chibi white bear sticker, sticker pack style, thick bold black outline, flat simple colors, plain white background, heart shaped eyes holding a red heart blushing happily in love, no text, square composition, high quality vector illustration',\n        surprised:'cute chibi white bear sticker, sticker pack style, thick bold black outline, flat simple colors, plain white background, wide open eyes mouth open in shock surprised, no text, square composition, high quality vector illustration',\n        sleepy:'cute chibi white bear sticker, sticker pack style, thick bold black outline, flat simple colors, plain white background, drowsy half closed eyes yawning holding a pillow sleepy, no text, square composition, high quality vector illustration',\n        confused:'cute chibi white bear sticker, sticker pack style, thick bold black outline, flat simple colors, plain white background, tilted head puzzled confused expression, no text, square composition, high quality vector illustration',\n        scared:'cute chibi white bear sticker, sticker pack style, thick bold black outline, flat simple colors, plain white background, trembling wide scared eyes sweat drop hiding behind paws, no text, square composition, high quality vector illustration',\n        proud:'cute chibi white bear sticker, sticker pack style, thick bold black outline, flat simple colors, plain white background, smug confident smirk arms crossed sparkle effects proud, no text, square composition, high quality vector illustration',\n      };\n\n      if(settings.stickerOnly && settings.stickerOnly.enabled){\n        var text=msg.content||'';\n        var best=null,bestScore=0;\n        Object.keys(DICT).forEach(function(cat){ var score=0; DICT[cat].forEach(function(kw){if(text.indexOf(kw)>-1)score++;}); if(score>bestScore){bestScore=score;best=cat;} });\n        if(!best) best='happy';\n        var stickerPath=null;\n        try{\n          var fname='sticker_'+best+'.png';\n          if(await tavo.file.exists(fname,{scope:'global'})){ stickerPath=tavo.file.url(fname,'global'); }\n          else { stickerPath=await tavo.image.generate(PROMPTS[best], {aspectRatio:'1:1', saveAs:fname, scope:'global'}); }\n        }catch(e){ console.error('[只回表情包-生成失败]',e); }\n        while(scriptEl.previousSibling){ scriptEl.parentNode.removeChild(scriptEl.previousSibling); }\n        if(stickerPath){\n          var img=D.createElement('img');\n          img.src=stickerPath;\n          img.style.cssText='width:84px;height:84px;object-fit:contain;border-radius:14px;cursor:pointer;';\n          img.addEventListener('click',function(){ try{ tavo.utils.preview(img.src); }catch(e){} });\n          scriptEl.parentNode.insertBefore(img, scriptEl);\n        } else {\n          var span=D.createElement('span'); span.textContent=text;\n          scriptEl.parentNode.insertBefore(span, scriptEl);\n        }\n        return;\n      }\n\n      if(settings.burst && settings.burst.enabled){\n        var raw=msg.content||'';\n        var rough=raw.split(/(?<=[。！？\\n])/).map(function(s){return s.trim();}).filter(function(s){return s.length>0;});\n        var merged=[];\n        rough.forEach(function(s){\n          if(merged.length && merged[merged.length-1].length<4){ merged[merged.length-1]+=s; }\n          else merged.push(s);\n        });\n        var maxPar