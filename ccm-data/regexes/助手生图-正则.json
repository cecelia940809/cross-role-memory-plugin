{"id":252,"name":"助手生图-正则","entries":[{"identifier":"9e1ebdbb-effc-4b70-ae57-d04e42946320","name":"气泡内生图","findRegex":"<imagine>([\\s\\S]*?)<\\/imagine>","replaceString":"<style>\n  @keyframes imagine-spin {\n    to { transform: rotate(360deg); }\n  }\n  .imagine-spinner {\n    width: 32px; height: 32px;\n    border: 3px solid #444;\n    border-top-color: #999;\n    border-radius: 50%;\n    animation: imagine-spin 0.8s linear infinite;\n  }\n</style>\n<div id=\"imagine-box\" style=\"display:none;align-items:center;justify-content:center;padding:12px;\">\n  <div id=\"imagine-loading\" class=\"imagine-spinner\"></div>\n  <img id=\"imagine-result\" style=\"display:none;max-width:100%;cursor:pointer;\" />\n  <div id=\"imagine-error\" style=\"display:none;color:#f66;font-size:20px;font-weight:bold;\">✕</div>\n  <div id=\"imagine-debug\" style=\"display:none;color:#999;font-size:12px;text-align:center;\"></div>\n</div>\n<script>\n(async function () {\n  // ===前缀区 ===\n  // 🥵把 IMAGINE_PREFIX ='前缀' 中的前缀二字替换👇\n  const IMAGINE_PREFIX = '前缀';\n  // ===前缀区 ===\n\n  const box = document.getElementById('imagine-box');\n  const loading = document.getElementById('imagine-loading');\n  const result = document.getElementById('imagine-result');\n  const error = document.getElementById('imagine-error');\n  const debugEl = document.getElementById('imagine-debug');\n  let busy = false;\n\n  function showImg(src) {\n    loading.style.display = 'none';\n    error.style.display = 'none';\n    debugEl.style.display = 'none';\n    result.src = src;\n    result.style.display = 'block';\n    result.onclick = function () { tavo.utils.preview(this.src); };\n    box.style.display = 'flex';\n  }\n\n  function showLoading() {\n    debugEl.style.display = 'none';\n    error.style.display = 'none';\n    loading.style.display = 'block';\n    box.style.display = 'flex';\n  }\n\n  function showError(msg) {\n    loading.style.display = 'none';\n    debugEl.style.display = 'none';\n    error.style.display = 'block';\n    error.title = msg;\n    box.style.display = 'flex';\n  }\n\n  // ====== 主循环 ======\n  async function mainLoop() {\n    if (busy) return;\n    busy = true;\n\n    try {\n      console.log('[mainLoop] start');\n\n      // 步骤1：扫描最近20条消息 → 只收录图文一致的槽位进cache\n      const t = await tavo.message.count();\n      const s = t <= 20 ? 0 : -20;\n      const mList = await tavo.message.find([s], { role: 'assistant', hidden: false });\n      const oldCache = tavo.get('asschatcache') || {};\n      console.log('[step1] oldCache', JSON.stringify(oldCache));\n      const cache = {};\n      for (const msg of mList) {\n        const re = /<imagine><P(\\d+)>([\\s\\S]*?)<\\/P\\1><\\/imagine>/gi;\n        let m;\n        while ((m = re.exec(msg.content)) !== null) {\n          const slot = m[1];\n          const text = m[2].trim();\n          const hasImg = !!tavo.get('imagine_' + slot);\n          console.log('[step1] msg ' + msg.id + ' slot=' + slot + ' text=' + text + ' hasImg=' + hasImg + ' oldText=' + (oldCache[slot] || '(none)'));\n          if (hasImg) {\n            if (oldCache[slot] === text) {\n              cache[slot] = text;\n            } else {\n              console.log('[step1] text mismatch, unset imagine_' + slot);\n              tavo.unset('imagine_' + slot);\n            }\n          } else if (oldCache[slot] !== undefined) {\n            // 无图但在oldCache中 → 图片被evict了，cache保留，不请求\n            cache[slot] = oldCache[slot];\n          }\n        }\n      }\n      console.log('[step1] newCache', JSON.stringify(cache));\n\n      if (JSON.stringify(oldCache) !== JSON.stringify(cache)) {\n        console.log('[step1] cache changed, cleaning up');\n        for (const k of Object.keys(oldCache)) {\n          if (!(k in cache)) {\n            console.log('[step1] unset imagine_' + k);\n            tavo.unset('imagine_' + k);\n          }\n        }\n        tavo.unset('asschatcache');\n        tavo.set('asschatcache', cache);\n      }\n\n      // 步骤2：只看当前消息\n      const self = await tavo.message.current();\n      console.log('[step2] current msg id=' + (self ? self.id : 'null'));\n      if (!self) { busy = false; return; }\n      const currentMsg = mList.find(m => m.id === self.id) || self;\n      const cleanContent = currentMsg.content.replace(/<script[\\s\\S]*?<\\/script>/gi, '');\n\n      // PError检测：已标记失败的消息直接显示✕，不再请求\n      const perrorMatch = cleanContent.match(/<imagine><PError>([\\s\\S]*?)<\\/PError><\\/imagine>/i);\n      if (perrorMatch) {\n        console.log('[perror] found PError, skip');\n        showError('图片生成失败');\n        busy = false; return;\n      }\n\n      // 2a. 已打 <PX> 标记 → 先查cache，cache是请求与否的唯一依据\n      const numberedMatch = cleanContent.match(/<imagine><P(\\d+)>([\\s\\S]*?)<\\/P\\1><\\/imagine>/i);\n      if (numberedMatch) {\n        console.log('[2a] found PX, slot=' + numberedMatch[1]);\n        const slotNum = numberedMatch[1];\n        const promptText = numberedMatch[2].trim();\n        console.log('[2a] promptText=' + promptText);\n          const cachedSlot = Object.keys(cache).find(k => cache[k] === promptText);\n          if (cachedSlot) {\n            console.log('[2a] found in cache slot=' + cachedSlot);\n            const cachedImg = tavo.get('imagine_' + cachedSlot);\n            console.log('[2a] cachedImg=' + (cachedImg ? cachedImg.substring(0,50) : 'null'));\n            if (cachedImg) { showImg(cachedImg); }\n          } else {\n            console.log('[2a] NOT in cache, generating...');\n            // 提示词不在cache → 先生图，再重写PX\n            const slotKeys = Object.keys(cache).map(Number);\n            const newSlot = slotKeys.length ? Math.max(...slotKeys) + 1 : 1;\n            console.log('[2a] newSlot=' + newSlot);\n            tavo.unset('imagine_' + newSlot);\n\n            showLoading();\n            const img = await generate(newSlot, promptText, cache);\n            console.log('[2a] generate returned ' + (img ? img.substring(0,50)+'...' : 'null'));\n\n            if (img) {\n              currentMsg.content = currentMsg.content.replace(\n                /<imagine><P\\d+>([\\s\\S]*?)<\\/P\\d+><\\/imagine>/i,\n                '<imagine><P' + newSlot + '>$1</P' + newSlot + '></imagine>'\n              );\n              console.log('[2a] updating msg with new PX');\n              await tavo.message.update(currentMsg, { reuseContext: true });\n              showImg(img);\n            } else {\n              currentMsg.content = currentMsg.content.replace(\n                /<imagine><P\\d+>([\\s\\S]*?)<\\/P\\d+><\\/imagine>/i,\n                '<imagine><PError>$1</PError></imagine>'\n              );\n              console.log('[2a] updating msg with PError');\n              await tavo.message.update(currentMsg, { reuseContext: true });\n            }\n        }\n        busy = false; return;\n      }\n\n      // 2b. 无PX标记 → 检查是否有未处理<imagine>\n      const match = cleanContent.match(/<imagine>([\\s\\S]*?)<\\/imagine>/i);\n      if (!match) { console.log('[2b] no <imagine> found, stop'); busy = false; return; }\n      const captured = match[1].trim();\n      console.log('[2b] found <imagine>, promptText=' + captured);\n\n      // 2c. 提示词在 cache 中出现过 → 直接复用，不请求\n      const existingSlot = Object.keys(cache).find(k => cache[k] === captured);\n      if (existingSlot) {\n        console.log('[2c] found in cache slot=' + existingSlot);\n        const img = tavo.get('imagine_' + existingSlot);\n        console.log('[2c] img=' + (img ? img.substring(0,50) : 'null'));\n        if (img) { showImg(img); }\n        busy = false; return;\n      }\n\n      // 2d. 新提示词 → 先生图，再打标记\n      console.log('[2d] new prompt, generating...');\n      const slotKeys = Object.keys(cache).map(Number);\n      const newSlot = slotKeys.length ? Math.max(...slotKeys) + 1 : 1;\n      console.log('[2d] newSlot=' + newSlot);\n\n      tavo.unset('imagine_' + newSlot);\n\n      showLoading();\n      const img = await generate(newSlot, captured, cache);\n      console.log('[2d] generate returned ' + (img ? img.substring(0,50)+'...' : 'null'));\n\n      if (img) {\n        currentMsg.content = currentMsg.content.replace(\n          /<imagine>([\\s\\S]*?)<\\/imagine>/i,\n          '<imagine><P' + newSlot + '>$1</P' + newSlot + '></imagine>'\n        );\n        console.log('[2d] updating msg with new PX');\n        await tavo.message.update(currentMsg, { reuseContext: true });\n        showImg(img);\n      } else {\n        currentMsg.content = currentMsg.content.replace(\n          /<imagine>([\\s\\S]*?)<\\/imagine>/i,\n          '<imagine><PError>$1</PError></imagine>'\n        );\n        console.log('[2d] updating msg with PError');\n        await tavo.message.update(currentMsg, { reuseContext: true });\n      }\n    } finally {\n      busy = false;\n    }\n  }\n\n  async function generate(slot, promptText, cacheObj) {\n    console.log('[generate] slot=' + slot + ' prompt=' + promptText);\n    const fullPrompt = IMAGINE_PREFIX + promptText;\n    console.log('[generate] fullPrompt length=' + fullPrompt.length);\n    try {\n      console.log('[generate] calling tavo.image.generate...');\n      const timeout = new Promise((_, reject) => setTimeout(() => reject(new Error('生成超时')), 60000));\n      const rawImg = await Promise.race([tavo.image.generate(fullPrompt, {}), timeout]);\n      console.log('[generate] rawImg type=' + typeof rawImg + ' value=' + String(rawImg).substring(0,100));\n\n      const img = await new Promise((resolve, reject) => {\n        const tmp = new Image();\n        tmp.onload = () => {\n          console.log('[generate] image loaded, ' + tmp.width + 'x' + tmp.height);\n          const c = document.createElement('canvas');\n          c.width = tmp.width;\n          c.height = tmp.height;\n          c.getContext('2d').drawImage(tmp, 0, 0);\n          resolve(c.toDataURL('image/jpeg', 1.0));\n        };\n        tmp.onerror = () => reject(new Error('图片加载失败'));\n        tmp.src = rawImg;\n        if (tmp.complete && tmp.naturalWidth > 0) {\n          console.log('[generate] image already complete');\n          tmp.onload();\n        }\n      });\n\n      console.log('[generate] img dataURL length=' + img.length);\n      tavo.set('imagine_' + slot, img);\n      cacheObj[String(slot)] = promptText;\n\n      // 检查实际 imagine_X 数量，超过5则删最小编号\n      const liveSlots = Object.keys(cacheObj).filter(k => tavo.get('imagine_' + k));\n      if (liveSlots.length > 5) {\n        const nums = liveSlots.map(Number);\n        const oldest = String(Math.min(...nums));\n        console.log('[generate] evict imagine_' + oldest + ', keep cache');\n        tavo.unset('imagine_' + oldest);\n      }\n      tavo.set('asschatcache', cacheObj);\n      console.log('[generate] success, cache=' + JSON.stringify(cacheObj));\n\n      return img;\n    } catch (e) {\n      console.error('[generate] error:', e.message);\n      showError(e.message);\n      return null;\n    }\n  }\n\n  // 启动（单次，调试完改回 setInterval）\n  await mainLoop();\n  // setInterval(mainLoop, 50);\n})();\n</script>","trimStrings":[],"placements":["char"],"timing":"display","substitution":"none","minDepth":null,"maxDepth":null,"enabled":false},{"identifier":"0006676d-868f-4a98-8b67-21266051ce7e","name":"隐藏提示词-内2","findRegex":"/<\\/P\\d+>/gi","replaceString":"","trimStrings":[],"placements":["char"],"timing":"send","substitution":"none","minDepth":null,"maxDepth":null,"enabled":true},{"identifier":"d818cd13-a04b-4270-bc64-a3f9dd460d10","name":"隐藏提示词-内","findRegex":"/<P\\d+>/gi","replaceString":"","trimStrings":[],"placements":["char"],"timing":"send","substitution":"none","minDepth":null,"maxDepth":null,"enabled":true},{"identifier":"eb2fd337-516a-4dec-955e-58b08cee9fad","name":"⚠️内外二选一","findRegex":"","replaceString":"","trimStrings":[],"placements":["char"],"timing":"display","substitution":"none","minDepth":null,"maxDepth":null,"enabled":false},{"identifier":"7b6893a4-2791-4e1d-98c9-ab1999dcb055","name":"气泡外生图","findRegex":"<imagine>([\\s\\S]*?)<\\/imagine>","replaceString":"<div style=\"width:0;height:0;opacity:0;overflow:hidden;\"></div>\n<script>\n(async function () {\n  // ===前缀区 ===\n  // 🥵把 IMAGINE_PREFIX ='前缀' 中的前缀二字替换👇\n  const IMAGINE_PREFIX = '前缀';\n  // ===前缀区 ===\n\n  // 1. 获取最新一条消息\n  const lastMsg = (await tavo.message.find(-1))[0];\n  if (!lastMsg) return;\n\n  // 2. 检查是否有 <imagine>...</imagine> 包裹的文本\n  const match = lastMsg.content.match(/<imagine>([\\s\\S]*?)<\\/imagine>/i);\n  if (!match) return;\n  const captured = match[1].trim();\n\n  // 3. 获取变量 imagine-cache\n  const cached = tavo.get('imagine-cache');\n\n  // 4. 与缓存比较，相同则停止\n  if (captured === cached) return;\n\n  // 5. 存入缓存\n  tavo.set('imagine-cache', captured);\n\n  // 6. 发送 /imagine（带前缀）\n  tavo.input.set(`/imagine ${IMAGINE_PREFIX}${captured}`);\n  tavo.input.send();\n})();\n</script>","trimStrings":[],"placements":["char"],"timing":"display","substitution":"none","minDepth":null,"maxDepth":0,"enabled":true},{"identifier":"b351d7e0-7047-420e-afb4-2aa45beda83c","name":"隐藏提示词-外","findRegex":"<imagine>([\\s\\S]*?)<\\/imagine>","replaceString":"","trimStrings":[],"placements":["char"],"timing":"display","substitution":"none","minDepth":1,"maxDepth":null,"enabled":false}]}