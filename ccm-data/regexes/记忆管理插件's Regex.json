{"id":307,"name":"记忆管理插件's Regex","entries":[{"identifier":"5886a8fd-76af-483c-8c99-a002c48ef276","name":"记忆管理插件启动","findRegex":"$","replaceString":"<script>\n(function(){\ntry{\n  var T; try{T=window.top||window}catch(_){T=window}\n  var D=T.document||document;\n  var KEY='mm8_booted';\n  if(T[KEY])return;\n  T[KEY]=true;\n\n  var LIB_PREFIX='tavo_mm_lib_v1:';\n\n  var css=D.createElement('style');\n  css.textContent=[\n    '#mm-tab{position:fixed;top:0;left:50%;transform:translateX(-50%);z-index:9500;',\n      'width:52px;height:20px;border-radius:0 0 14px 14px;',\n      'background:linear-gradient(135deg,rgba(60,90,220,0.92),rgba(120,80,255,0.88));',\n      'border:1px solid rgba(140,120,255,0.5);border-top:none;',\n      'box-shadow:0 4px 14px rgba(80,80,255,0.4);',\n      'display:flex;align-items:center;justify-content:center;',\n      'cursor:pointer;transition:transform .2s;color:#fff;font-size:12px;',\n    '}',\n    '#mm-tab:active{transform:translateX(-50%) scale(0.95);}',\n    '#mm-tab.open .mm-chevron{transform:rotate(180deg);}',\n    '.mm-chevron{transition:transform .25s;display:inline-block;}',\n    '#mm-panel{position:fixed;top:0;left:50%;transform:translateX(-50%) translateY(-100%);',\n      'z-index:9490;width:220px;max-width:80vw;',\n      'background:rgba(12,14,28,0.97);border:1px solid rgba(120,120,255,0.35);',\n      'border-top:none;border-radius:0 0 16px 16px;padding:16px 14px 12px;',\n      'box-shadow:0 8px 24px rgba(0,0,0,0.5);',\n      'display:flex;flex-direction:column;gap:8px;',\n      'transition:transform .28s ease,opacity .28s ease;opacity:0;pointer-events:none;',\n    '}',\n    '#mm-panel.open{transform:translateX(-50%) translateY(20px);opacity:1;pointer-events:auto;}',\n    '.mm-panel-btn{display:flex;align-items:center;gap:8px;padding:9px 10px;border-radius:10px;',\n      'background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);',\n      'color:#e2e8f0;font-size:12.5px;cursor:pointer;transition:background .15s;',\n    '}',\n    '.mm-panel-btn:hover{background:rgba(255,255,255,0.1);}',\n    '.mm-panel-btn .mm-ic{font-size:16px;}',\n    '#mm-mask{position:fixed;inset:0;z-index:9600;background:rgba(0,0,0,0.45);backdrop-filter:blur(2px);}',\n    '#mm-pop{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:9700;',\n      'width:360px;max-width:90vw;max-height:78vh;background:rgba(10,14,28,0.97);',\n      'border:1px solid rgba(120,120,255,0.35);border-radius:18px;padding:18px 20px;',\n      'overflow-y:auto;box-shadow:0 12px 40px rgba(0,0,0,0.6);',\n    '}',\n    '#mm-pop .mm-title{color:#c4b5fd;font-size:15px;font-weight:700;margin-bottom:6px;display:flex;align-items:center;gap:6px;}',\n    '#mm-pop .mm-sub{color:#94a3b8;font-size:12px;margin-bottom:14px;line-height:1.5;}',\n    '#mm-pop .mm-stat{display:flex;justify-content:space-between;background:rgba(255,255,255,0.05);border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;color:#e2e8f0;}',\n    '#mm-pop .mm-stat b{color:#c4b5fd;}',\n    '#mm-list{max-height:240px;overflow-y:auto;margin-bottom:14px;}',\n    '.mm-item{font-size:12px;color:#cbd5e1;background:rgba(255,255,255,0.04);border-radius:8px;padding:7px 10px;margin-bottom:5px;line-height:1.4;white-space:pre-wrap;position:relative;}',\n    '.mm-item .mm-tag{color:#93c5fd;font-weight:700;display:block;margin-bottom:3px;}',\n    '.mm-item .mm-source{color:#94a3b8;font-size:10.5px;font-style:italic;display:block;margin-bottom:5px;}',\n    '.mm-item .mm-del{position:absolute;top:6px;right:8px;color:#f87171;font-size:11px;cursor:pointer;opacity:.7;}',\n    '.mm-item .mm-del:hover{opacity:1;}',\n    '#mm-go{width:100%;padding:11px;border:none;border-radius:10px;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;font-size:13px;font-weight:700;cursor:pointer;margin-bottom:8px;}',\n    '#mm-go2{width:100%;padding:9px;border:1px solid rgba(140,140,255,0.3);border-radius:10px;background:transparent;color:#c4b5fd;font-size:12px;cursor:pointer;margin-bottom:8px;}',\n    '#mm-go:disabled{opacity:.5;cursor:not-allowed;}',\n    '#mm-cancel{width:100%;padding:9px;border:1px solid rgba(255,255,255,0.12);border-radius:10px;background:transparent;color:#94a3b8;font-size:12px;cursor:pointer;}',\n    '#mm-toast{position:fixed;top:20px;left:50%;transform:translateX(-50%);background:rgba(16,20,38,0.95);color:#e2e8f0;padding:9px 18px;border-radius:20px;font-size:13px;z-index:10000;border:1px solid rgba(120,120,255,0.3);opacity:0;transition:opacity .25s;pointer-events:none;white-space:nowrap;}',\n    '#mm-toast.show{opacity:1;top:60px;transition:opacity .25s,top .25s;}',\n  ].join('');\n  D.head.appendChild(css);\n\n  function mk(t,a,p){var e=D.createElement(t);Object.keys(a||{}).forEach(function(k){e[k]=a[k]});if(p)p.appendChild(e);return e;}\n  function rm(el){el&&el.parentNode&&el.parentNode.removeChild(el);}\n\n  function toast(msg,dur){\n    var el=D.getElementById('mm-toast')||mk('div',{id:'mm-toast'},D.body);\n    el.textContent=msg;el.classList.add('show');\n    clearTimeout(el._t);\n    el._t=setTimeout(function(){el.classList.remove('show');},dur||2500);\n  }\n\n  function closePop(){rm(D.getElementById('mm-mask'));rm(D.getElementById('mm-pop'));}\n\n  // ---------- 顶部拉环入口 ----------\n  var panelOpen=false;\n  function togglePanel(force){\n    var tab=D.getElementById('mm-tab');\n    var panel=D.getElementById('mm-panel');\n    panelOpen = (typeof force==='boolean') ? force : !panelOpen;\n    if(panelOpen){ tab.classList.add('open'); panel.classList.add('open'); }\n    else { tab.classList.remove('open'); panel.classList.remove('open'); }\n  }\n\n  function buildTab(){\n    if(D.getElementById('mm-tab'))return;\n    var tab=mk('div',{id:'mm-tab',title:'记忆管理'},D.body);\n    tab.innerHTML='<span class=\"mm-chevron\">▾</span>';\n    tab.addEventListener('click',function(e){ e.stopPropagation(); togglePanel(); });\n\n    var panel=mk('div',{id:'mm-panel'},D.body);\n    panel.addEventListener('click',function(e){e.stopPropagation();});\n\n    var b1=mk('div',{className:'mm-panel-btn'},panel);\n    b1.innerHTML='<span class=\"mm-ic\">🧠</span><span>记忆总结</span>';\n    b1.addEventListener('click',function(){ togglePanel(false); openSummarize(); });\n\n    var b2=mk('div',{className:'mm-panel-btn'},panel);\n    b2.innerHTML='<span class=\"mm-ic\">📚</span><span>记忆库</span>';\n    b2.addEventListener('click',function(){ togglePanel(false); openLibrary(); });\n\n    D.addEventListener('click',function(){ if(panelOpen) togglePanel(false); });\n  }\n\n  // ---------- 记忆库：按用户身份（persona）分桶，同一身份下所有角色共享 ----------\n  var GLOBAL_KEY='GLOBAL_SHARED'; // v6 时期的全局共享桶，仅用于向旧数据迁移\n  var MIGRATED_FLAG_KEY=LIB_PREFIX+'__migrated_to_global_v1';\n  var MIGRATED_PERSONA_FLAG_KEY=LIB_PREFIX+'__migrated_to_persona_v1';\n\n  // 一次性迁移①：把 v1-v5 期间按角色/默认key分散存的库，合并进 v6 的全局共享桶。\n  function migrateAllToGlobal(){\n    try{\n      if(T.localStorage.getItem(MIGRATED_FLAG_KEY)) return;\n      var globalLib=loadLibrary(GLOBAL_KEY);\n      var existSet={}; globalLib.forEach(function(it){existSet[it]=true;});\n      var n=T.localStorage.length;\n      var oldKeys=[];\n      for(var i=0;i<n;i++){\n        var k=T.localStorage.key(i);\n        if(k && k.indexOf(LIB_PREFIX)===0 && k!==LIB_PREFIX+GLOBAL_KEY){\n          oldKeys.push(k);\n        }\n      }\n      oldKeys.forEach(function(k){\n        try{\n          var raw=T.localStorage.getItem(k);\n          var arr=raw?JSON.parse(raw):[];\n          if(Array.isArray(arr)){\n            arr.forEach(function(it){ if(!existSet[it]){ globalLib.push(it); existSet[it]=true; } });\n          }\n        }catch(e){}\n      });\n      saveLibraryRaw(GLOBAL_KEY,globalLib);\n      T.localStorage.setItem(MIGRATED_FLAG_KEY,'1');\n    }catch(e){ console.warn('[记忆管理] 旧角色库迁移失败',e); }\n  }\n\n  // 一次性迁移②：把 v6 的全局共享桶，并入\"当前用户身份\"的桶。\n  // 注意：由于历史数据没有记录当时用的是哪个身份，这里只能把旧数据整体\n  // 归到\"第一次打开 v7 时正在使用的身份\"下，是一次性的近似处理。\n  async function migrateGlobalToCurrentPersona(){\n    try{\n      if(T.localStorage.getItem(MIGRATED_PERSONA_FLAG_KEY)) return;\n      var legacy=loadLibrary(GLOBAL_KEY);\n      if(legacy.length>0){\n        var ctx=await getPersonaContext();\n        var bucket=loadLibrary(ctx.key);\n        var existCore={}; bucket.forEach(function(it){existCore[stripSourceLine(it)]=true;});\n        legacy.forEach(function(it){\n          var core=stripSourceLine(it);\n          if(!existCore[core]){ bucket.push(it); existCore[core]=true; }\n        });\n        saveLibraryRaw(ctx.key,bucket);\n      }\n      T.localStorage.setItem(MIGRATED_PERSONA_FLAG_KEY,'1');\n    }catch(e){ console.warn('[记忆管理] 身份库迁移失败',e); }\n  }\n\n  // 当前用户身份（persona）→ 库 key + 显示名\n  async function getPersonaContext(){\n    try{\n      var chat=await tavo.chat.current();\n      if(chat && chat.persona && chat.persona.id!=null){\n        return { key:'persona:'+chat.persona.id, label: chat.persona.name || ('身份'+chat.persona.id) };\n      }\n    }catch(e){ console.warn('[记忆管理] 无法获取用户身份，回退为默认身份桶',e); }\n    return { key:'persona:none', label:'默认身份' };\n  }\n\n  // 当前聊天的角色名（用于标注记忆来源）\n  async function getSourceCharacterName(){\n    try{\n      var chat=await tavo.chat.current();\n      if(chat && Array.isArray(chat.characters) && chat.characters.length){\n        return chat.characters[0].name || '未知角色';\n      }\n    }catch(e){}\n    return '未知角色';\n  }\n\n  // 给一个事件块文本，在标题行之后插入一行来源标注：（来源：XXX · YYYY-MM-DD）\n  function annotateSource(blockText, sourceName){\n    var dateStr=new Date().toISOString().slice(0,10);\n    var line='（来源：'+sourceName+' · '+dateStr+'）';\n    var lines=blockText.split('\\n');\n    if(lines.length && /^\\[.*\\]$/.test(lines[0].trim())){\n      lines.splice(1,0,line);\n    } else {\n      lines.unshift(line);\n    }\n    return lines.join('\\n');\n  }\n\n  // 去掉来源标注行，得到\"核心内容\"，用于判断两条记忆是否本质重复\n  // （避免同一事实被反复总结后，因为日期不同而被当成新记忆无限累积）\n  function stripSourceLine(blockText){\n    var lines=blockText.split('\\n').filter(function(l){ return !/^（来源[:：].*）$/.test(l.trim()); });\n    return lines.join('\\n').trim();\n  }\n\n  // 给库里\"有标题但没有来源行\"的旧条目，统一补一个通用来源标签。\n  // 幂等：已经有来源行的条目不会被重复处理，可以每次启动都调用。\n  function upgradeUntaggedEntries(key){\n    try{\n      var lib=loadLibrary(key);\n      var changed=false;\n      var upgraded=lib.map(function(it){\n        var lines=it.split('\\n');\n        var hasTitle=lines.length && /^\\[.*\\]$/.test(lines[0].trim());\n        var hasSource=hasTitle && lines.length>1 && /^（来源[:：].*）$/.test(lines[1].trim());\n        if(hasTitle && !hasSource){\n          changed=true;\n          lines.splice(1,0,'（来源：历史记录）');\n          return lines.join('\\n');\n        }\n        return it;\n      });\n      if(changed) saveLibraryRaw(key,upgraded);\n    }catch(e){ console.warn('[记忆管理] 旧记忆补标签失败',e); }\n  }\n\n  // ---------- 角色库存取（localStorage，跨聊天持久化） ----------\n  function loadLibrary(key){\n    try{\n      var raw=T.localStorage.getItem(LIB_PREFIX+key);\n      if(!raw) return [];\n      var arr=JSON.parse(raw);\n      return Array.isArray(arr)?arr:[];\n    }catch(e){ return []; }\n  }\n  function saveLibraryRaw(key,arr){\n    try{ T.localStorage.setItem(LIB_PREFIX+key, JSON.stringify(arr)); }catch(e){ console.error('[记忆管理] 写入角色库失败',e); }\n  }\n  // 合并去重存入角色库（完全相同文本视为重复，不覆盖旧数据）\n  function mergeIntoLibrary(key,newItems){\n    var lib=loadLibrary(key);\n    var existCore={};\n    lib.forEach(function(it){ existCore[stripSourceLine(it)]=true; });\n    var added=0;\n    newItems.forEach(function(it){\n      var core=stripSourceLine(it);\n      if(!existCore[core]){ lib.push(it); existCore[core]=true; added++; }\n    });\n    saveLibraryRaw(key,lib);\n    return {lib:lib, added:added};\n  }\n\n  // ---------- tag+bullet 事件块渲染 ----------\n  function renderBlockItem(container, blockText){\n    var lines = blockText.split('\\n').filter(function(l){return l.trim().length>0;});\n    var item = mk('div',{className:'mm-item'}, container);\n    var idx=0;\n    if(lines.length && /^\\[.*\\]$/.test(lines[0].trim())){\n      var tag = mk('span',{className:'mm-tag'}, item);\n      tag.textContent = lines[0].trim();\n      idx=1;\n    }\n    if(lines.length>idx && /^（来源[:：].*）$/.test(lines[idx].trim())){\n      var src = mk('span',{className:'mm-source'}, item);\n      src.textContent = lines[idx].trim();\n      idx++;\n    }\n    if(idx>0){\n      var rest = lines.slice(idx).join('\\n');\n      item.appendChild(D.createTextNode(rest));\n    } else {\n      item.textContent = blockText;\n    }\n    return item;\n  }\n\n  // ---------- 记忆总结：确认与结果弹窗 ----------\n  function buildConfirmPop(memories){\n    closePop();\n    var mask=mk('div',{id:'mm-mask'},D.body);\n    mask.addEventListener('click',closePop);\n    var pop=mk('div',{id:'mm-pop'},D.body);\n    pop.addEventListener('click',function(e){e.stopPropagation();});\n\n    var title=mk('div',{className:'mm-title'},pop);\n    title.innerHTML='<span>🧠</span><span>记忆总结</span>';\n\n    var sub=mk('div',{className:'mm-sub'},pop);\n    sub.textContent='会一次性完成：合并重复/相似内容 + 按事件归并为 [人物 — 事件] + · 细节 的结构化事件块，不会丢失任何独特信息。每条会自动标注来源角色和日期，完成后同步一份到当前用户身份的共享记忆库（同一身份下所有角色都能看到）。';\n\n    var stat=mk('div',{className:'mm-stat'},pop);\n    stat.innerHTML='当前记忆条数 &nbsp;<b>'+memories.length+'</b> 条';\n\n    var list=mk('div',{id:'mm-list'},pop);\n    memories.forEach(function(m){\n      var item=mk('div',{className:'mm-item'},list);\n      item.textContent=m;\n    });\n\n    var go=mk('button',{id:'mm-go'},pop);\n    go.textContent='开始总结';\n    go.addEventListener('click',function(){ doSummarize(memories,go); });\n\n    var cancel=mk('button',{id:'mm-cancel'},pop);\n    cancel.textContent='取消';\n    cancel.addEventListener('click',closePop);\n  }\n\n  function buildResultPop(before,after,newMemories,libAdded){\n    closePop();\n    var mask=mk('div',{id:'mm-mask'},D.body);\n    mask.addEventListener('click',closePop);\n    var pop=mk('div',{id:'mm-pop'},D.body);\n    pop.addEventListener('click',function(e){e.stopPropagation();});\n\n    var title=mk('div',{className:'mm-title'},pop);\n    title.innerHTML='<span>✅</span><span>总结完成</span>';\n\n    var stat=mk('div',{className:'mm-stat'},pop);\n    stat.innerHTML=before+' 条 → <b>'+after+'</b> 个事件块  ·  共享库新增 <b>'+libAdded+'</b> 条';\n\n    var list=mk('div',{id:'mm-list'},pop);\n    newMemories.forEach(function(m){\n      renderBlockItem(list,m);\n    });\n\n    var go=mk('button',{id:'mm-go'},pop);\n    go.textContent='完成';\n    go.addEventListener('click',closePop);\n  }\n\n  async function doSummarize(memories,btn){\n    btn.disabled=true; btn.textContent='总结中…';\n    try{\n      var memoryList=memories.map(function(m,i){return (i+1)+'. '+m;}).join('\\n');\n      var prompt='以下是当前的记忆列表（每行一条，互相独立）：\\n'+memoryList+'\\n\\n'+\n        '请对这些记忆做\"总结整理\"，在同一次处理中完成去重和结构化归类：\\n'+\n        '要求：\\n'+\n        '1. 先识别重复、高度相似或描述同一细节的记忆，只保留一条最完整的表述，不要重复出现\\n'+\n        '2. 再将合并后的记忆按所属事件归并为结构化的事件块：描述同一事件、同一场景、同一次互动的记忆归入同一块\\n'+\n        '3. 每个事件块的第一行是标题，格式：\"[涉及人物 — 事件简述]\"，涉及人物用逗号分隔，主角在前\\n'+\n        '4. 标题行之后，用\"· \"开头列出该事件的具体细节，每条占一行\\n'+\n        '5. 不属于任何事件、单独的个人信息（如年龄、过敏史等）保持独立，格式仍为\"[User — 个人信息]\"+一条\"· \"细节\\n'+\n        '6. 不要丢失任何原有的独特信息，不要编造新信息\\n'+\n        '7. 不同事件块之间，用一个单独的分隔行 \"===\" 隔开\\n'+\n        '8. 不要输出任何解释、编号或前言，只输出事件块本身\\n\\n'+\n        '输出格式示例：\\n'+\n        '[User, 维多利亚·凌 — 海边约会]\\n'+\n        '· 共进海鲜大餐并观看日落\\n'+\n        '· User视为今年最开心的一天\\n'+\n        '===\\n'+\n        '[User — 童年回忆]\\n'+\n        '· 童年养猫因病去世，仍有自责感';\n\n      var result=await tavo.generate(prompt,{context:false});\n      var rawMemories=result.split('===').map(function(b){return b.trim();}).filter(function(b){return b.length>0;});\n\n      if(rawMemories.length===0){ toast('❌ 总结结果为空，已取消保存'); closePop(); return; }\n\n      var sourceName=await getSourceCharacterName();\n      var newMemories=rawMemories.map(function(b){ return annotateSource(b,sourceName); });\n\n      var memory=await tavo.memory.current();\n      var before=memory.memories.length;\n      memory.memories=newMemories;\n      await tavo.memory.update(memory);\n\n      var ctx=await getPersonaContext();\n      var mr=mergeIntoLibrary(ctx.key,newMemories);\n\n      buildResultPop(before,newMemories.length,newMemories,mr.added);\n    }catch(err){\n      console.error('[记忆管理-总结]',err);\n      toast('❌ 失败：'+(err&&err.message||String(err)));\n      closePop();\n    }\n  }\n\n  async function openSummarize(){\n    try{\n      var memory=await tavo.memory.current();\n      if(!memory.memories||memory.memories.length===0){ toast('当前没有记忆可总结'); return; }\n      buildConfirmPop(memory.memories);\n    }catch(err){\n      console.error('[记忆管理]',err);\n      toast('❌ 读取记忆失败：'+(err&&err.message||String(err)));\n    }\n  }\n\n  // ---------- 共享记忆库面板 ----------\n  async function openLibrary(){\n    var ctx=await getPersonaContext();\n    var lib=loadLibrary(ctx.key);\n    renderLibraryPop(ctx.key,lib,ctx.label);\n  }\n\n  function renderLibraryPop(key,lib,label){\n    closePop();\n    var mask=mk('div',{id:'mm-mask'},D.body);\n    mask.addEventListener('click',closePop);\n    var pop=mk('div',{id:'mm-pop'},D.body);\n    pop.addEventListener('click',function(e){e.stopPropagation();});\n\n    var title=mk('div',{className:'mm-title'},pop);\n    var ticon=mk('span',{},title); ticon.textContent='📚';\n    var ttext=mk('span',{},title); ttext.textContent=' 记忆库 · '+label;\n\n    var sub=mk('div',{className:'mm-sub'},pop);\n    sub.textContent='同一用户身份「'+label+'」下所有角色共用这份记忆库；切换到别的用户身份聊天时，会使用另一份独立的库。每次\"记忆总结\"完成后会自动追加新增内容到这里，并标注来源角色和日期；打开任意角色的聊天时，也会自动把库里的新增内容合并进当前聊天记忆，无需手动导入。';\n\n    var stat=mk('div',{className:'mm-stat'},pop);\n    stat.innerHTML='库中共 &nbsp;<b>'+lib.length+'</b> 条';\n\n    var list=mk('div',{id:'mm-list'},pop);\n    if(lib.length===0){\n      var empty=mk('div',{className:'mm-item'},list);\n      empty.textContent='暂无内容，先用\"记忆总结\"生成一些记忆吧。';\n    }\n    lib.forEach(function(m,idx){\n      var item=renderBlockItem(list,m);\n      var del=mk('span',{className:'mm-del'},item);\n      del.textContent='删除';\n      del.addEventListener('click',function(e){\n        e.stopPropagation();\n        lib.splice(idx,1);\n        saveLibraryRaw(key,lib);\n        renderLibraryPop(key,lib,label);\n      });\n    });\n\n    var clearBtn=mk('button',{id:'mm-go2'},pop);\n    clearBtn.textContent='清空该身份的记忆库';\n    clearBtn.addEventListener('click',function(){\n      if(lib.length===0)return;\n      saveLibraryRaw(key,[]);\n      renderLibraryPop(key,[],label);\n      toast('已清空该身份的记忆库');\n    });\n\n    var cancel=mk('button',{id:'mm-cancel'},pop);\n    cancel.textContent='关闭';\n    cancel.addEventListener('click',closePop);\n  }\n\n  // ---------- 自动同步：进入任意角色的聊天时，把当前身份的记忆库自动合并进当前聊天记忆 ----------\n  // 只在脚本启动时跑一次（由顶部 KEY 的启动去重保证不会重复执行）。\n  async function autoSyncLibraryToChat(){\n    try{\n      var ctx=await getPersonaContext();\n      var lib=loadLibrary(ctx.key);\n      if(lib.length===0) return;\n\n      var memory=await tavo.memory.current();\n      var current=memory.memories||[];\n      var existCore={}; current.forEach(function(c){existCore[stripSourceLine(c)]=true;});\n      var addedCount=0;\n      lib.forEach(function(m){\n        var core=stripSourceLine(m);\n        if(!existCore[core]){ current.push(m); existCore[core]=true; addedCount++; }\n      });\n\n      if(addedCount>0){\n        memory.memories=current;\n        await tavo.memory.update(memory);\n        toast('🧠 已自动同步 '+addedCount+' 条记忆（身份：'+ctx.label+'）');\n      }\n    }catch(err){\n      console.warn('[记忆管理-自动同步] 跳过：',err);\n    }\n  }\n\n  async function bootSequence(){\n    buildTab();\n    migrateAllToGlobal();\n    await migrateGlobalToCurrentPersona();\n    var ctx=await getPersonaContext();\n    upgradeUntaggedEntries(ctx.key);\n    await autoSyncLibraryToChat();\n  }\n  bootSequence();\n  console.log('[记忆管理插件v8] 已加载');\n\n}catch(e){console.error('[记忆管理插件]',e);}\n})();\n</script>\n","trimStrings":[],"placements":["user"],"timing":"display","substitution":"none","minDepth":null,"maxDepth":null,"enabled":true}]}