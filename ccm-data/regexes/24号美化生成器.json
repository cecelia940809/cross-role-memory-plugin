der:1px solid #E5E7EB;border-radius:12px;padding:10px 14px;color:#1F2937;display:inline-block;max-width:90%;font-size:13px;box-shadow:0 1px 6px rgba(0,0,0,.06);', sample:'这是一条消息，极简白卡风格。' },\n    font:   { css:'color:#6B7280;font-size:13px;', sample:'【他放下手中的咖啡，抬起头看向窗外】' }\n  },\n  { id:'glass', cat:'modern', icon:'✨', name:'渐变玻璃', sub:'毛玻璃感 · 通透唯美',\n    tags:[{t:'渐变',c:'#4C1D95',b:'#EEF2FF'},{t:'玻璃',c:'#7C3AED',b:'#F3E8FF'}],\n    status: { css:'color:#4C1D95;background:linear-gradient(135deg,rgba(238,242,255,.95),rgba(249,240,255,.95));border:1.5px solid rgba(167,139,250,.3);border-radius:16px;padding:8px 16px;font-size:13px;', sample:'~ HP: 满血 ~  ~ MP: 充足 ~  ~ 状态: 良好 ~' },\n    quote:  { css:'color:#6D28D9;font-style:italic;', before:'「✎ ', after:'」' },\n    bubble: { css:'background:linear-gradient(135deg,rgba(238,242,255,.95),rgba(249,240,255,.95));border:1.5px solid rgba(167,139,250,.3);border-radius:18px;padding:10px 16px;color:#4C1D95;display:inline-block;max-width:90%;font-size:13px;', sample:'这是一条消息，渐变玻璃质感，通透唯美~' },\n    font:   { css:'color:#7C3AED;font-style:italic;font-size:13px;', sample:'【她站在落地窗前，城市的灯火在身后闪烁】' }\n  },\n  // ── 科幻系 ──\n  { id:'terminal', cat:'scifi', icon:'🖥️', name:'终端数据', sub:'极客黑客 · 代码风格',\n    tags:[{t:'科技',c:'#00FF41',b:'#001A00'},{t:'极客',c:'#00FFFF',b:'#001A1A'}],\n    status: { css:'font-family:monospace;color:#00FF41;background:#0D0D0D;border:1.5px solid #00FF41;border-radius:6px;padding:8px 16px;font-size:12px;text-shadow:0 0 6px #00FF41;', sample:'> status.query()  hp: 100  mp: 85  exp: 2450/3000  lv: 42' },\n    quote:  { css:'font-family:monospace;color:#00FF41;text-shadow:0 0 4px #00FF41;', before:'> \"', after:'\"' },\n    bubble: { css:'background:#0D0D0D;border:1.5px solid #00FF41;border-radius:6px;padding:10px 14px;color:#00FF41;font-family:monospace;display:inline-block;max-width:90%;font-size:12px;', sample:'> INPUT_RECEIVED: 消息解析完成，逻辑校验通过。' },\n    font:   { css:'font-family:monospace;color:#888;font-size:12px;', sample:'【系统日志: 情感模块异常波动，原因不明】' }\n  },\n  { id:'space', cat:'scifi', icon:'🌌', name:'星际低频', sub:'宇宙冷感 · 深空蓝调',\n    tags:[{t:'科幻',c:'#7EB8F7',b:'#050520'},{t:'深空',c:'#4A7FC0',b:'#0A0A30'}],\n    status: { css:'font-family:monospace;color:#7EB8F7;background:linear-gradient(135deg,#050520,#0A0A30);border:1px solid #1E3A5F;border-radius:16px;padding:8px 16px;font-size:12px;', sample:'◉ VITALS: 100%  ◉ SHIELDS: 85%  ◉ FUEL: 62%  ◉ SECTOR: 7' },\n    quote:  { css:'font-family:monospace;color:#7EB8F7;', before:'[ ', after:' ]' },\n    bubble: { css:'background:linear-gradient(135deg,#050520,#0A0A30);border:1px solid #1E3A5F;border-radius:16px;padding:10px 14px;color:#7EB8F7;font-family:monospace;display:inline-block;max-width:90%;font-size:12px;', sample:'星际通讯已建立，坐标锁定，等待您的回应。' },\n    font:   { css:'font-family:monospace;color:#4A7FC0;font-size:12px;', sample:'【飞船轻微颤动，舷窗外繁星如棋子般散落】' }\n  }\n];\n\n// ============================================================\n// 全局状态\n// ============================================================\nvar gStep = 0, canNext = false;\nvar selStyle = null;   // 当前选中风格\nvar aiOverride = null; // AI微调后覆盖的CSS {status,quote,bubble,font}\nvar curCat = 'platform';\n\nfunction gid(id){ return document.getElementById(id); }\nfunction qall(s){ return document.querySelectorAll(s); }\nfunction showToast(msg){ var t=gid('tst'); t.textContent=msg; t.className='toast on'; setTimeout(function(){ t.className='toast'; },2200); }\nfunction setDots(a){ for(var i=0;i<3;i++) gid('d'+i).className='dot'+(i<a?' done':i===a?' active':''); for(var j=0;j<2;j++) gid('l'+j).className='sline'+(j<a?' done':''); }\nfunction setNext(can,label){ canNext=can; var b=gid('nnx'); if(label) b.textContent=label; b.className=can?'nnx active':'nnx'; }\nfunction showSec(id){ qall('.sec').forEach(function(el){ el.className='sec'; }); gid(id).className='sec on'; window.scrollTo(0,0); }\n\n// ============================================================\n// 渲染风格网格\n// ============================================================\nfunction buildGrid(cat){\n  var grid = gid('style-grid');\n  grid.innerHTML = '';\n  STYLES.filter(function(s){ return s.cat===cat; }).forEach(function(s){\n    var btn = document.createElement('button');\n    btn.className = 'scard' + (selStyle && selStyle.id===s.id ? ' on' : '');\n    var tags = s.tags.map(function(t){ return '<span class=\"stag\" style=\"color:'+t.c+';background:'+t.b+'\">'+t.t+'</span>'; }).join('');\n    btn.innerHTML = '<div class=\"scard-check\">✓</div><span class=\"scard-icon\">'+s.icon+'</span><div class=\"scard-name\">'+s.name+'</div><div class=\"scard-sub\">'+s.sub+'</div><div class=\"scard-tags\">'+tags+'</div>';\n    btn.onclick = function(){ selStyle=s; aiOverride=null; buildGrid(cat); setNext(true,'下一步 →'); };\n    grid.appendChild(btn);\n  });\n}\n\n// 分类 Tab\n(function(){\n  qall('#cat-tabs .cat-tab').forEach(function(tab){\n    tab.onclick = function(){\n      qall('#cat-tabs .cat-tab').forEach(function(t){ t.className='cat-tab'; });\n      tab.className='cat-tab on';\n      curCat = tab.getAttribute('data-cat');\n      buildGrid(curCat);\n    };\n  });\n  buildGrid('platform');\n})();\n\n// ============================================================\n// 获取当前生效的CSS（AI覆盖优先）\n// ============================================================\nfunction getCSS(type){\n  if(aiOverride && aiOverride[type]) return aiOverride[type];\n  return selStyle ? selStyle[type].css : '';\n}\nfunction getBefore(){ return (aiOverride&&aiOverride.quote) ? '' : (selStyle ? selStyle.quote.before||'' : ''); }\nfunction getAfter(){  return (aiOverride&&aiOverride.quote) ? '' : (selStyle ? selStyle.quote.after||'' : ''); }\n\n// ============================================================\n// 构建预览HTML\n// ============================================================\nfunction buildPreview(){\n  if(!selStyle) return '';\n  var s = selStyle;\n  var statusCSS = getCSS('status');\n  var quoteCSS  = getCSS('quote');\n  var bubbleCSS = getCSS('bubble');\n  var fontCSS   = getCSS('font');\n  var qB = getBefore(), qA = getAfter();\n  var statusSample = aiOverride && aiOverride.statusSample ? aiOverride.statusSample : s.status.sample;\n  var bubbleSample = aiOverride && aiOverride.bubbleSample ? aiOverride.bubbleSample : s.bubble.sample;\n  var fontSample   = aiOverride && aiOverride.fontSample   ? aiOverride.fontSample   : s.font.sample;\n\n  return '<div class=\"preview-row\"><div class=\"preview-row-label\">状态栏</div><div style=\"'+statusCSS+'\">'+statusSample+'</div></div>'\n       + '<div class=\"preview-row\"><div class=\"preview-row-label\">聊天气泡</div><div style=\"'+bubbleCSS+'\">'+bubbleSample+'</div></div>'\n       + '<div class=\"preview-row\"><div class=\"preview-row-label\">对话引号</div><div style=\"font-size:13px;line-height:1.8\"><span style=\"'+quoteCSS+'\">'+esc(qB)+'今天天气真好，我们去散步吧！'+esc(qA)+'</span></div></div>'\n       + '<div class=\"preview-row\"><div class=\"preview-row-label\">旁白字体</div><div style=\"font-size:13px;line-height:1.8\"><span style=\"'+fontCSS+'\">'+fontSample+'</span></div></div>';\n}\nfunction esc(s){ return (s||'').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }\n\n// ============================================================\n// S1 初始化\n// ============================================================\nfunction initS1(){\n  var s = selStyle;\n  gid('sel-icon').textContent = s.icon;\n  gid('sel-name').textContent = s.name;\n  gid('sel-sub').textContent = s.sub;\n  gid('preview-area').innerHTML = buildPreview();\n  gid('ai-desc').value = '';\n  gid('ai-done-box').className = 'ai-done-box';\n\n  gid('ai-gen-btn').onclick = function(){\n    var desc = gid('ai-desc').value.trim();\n    if(!desc){ showToast('请先输入想调整的内容'); return; }\n    var btn = gid('ai-gen-btn');\n    btn.className = 'ai-btn loading';\n    btn.textContent = '⏳';\n    callAI(s, desc, function(err, result){\n      btn.className = 'ai-btn';\n      btn.innerHTML = '✨<br>生成';\n      if(err || !result){ showToast('❌ 生成失败，请重试'); return; }\n      aiOverride = result;\n      gid('preview-area').innerHTML = buildPreview();\n      gid('ai-done-box').className = 'ai-done-box on';\n      var lines = ['状态栏: '+(result.status||'(未变)'), '引号: '+(result.quote||'(未变)'), '气泡: '+(result.bubble||'(未变)'), '字体: '+(result.font||'(未变)')];\n      gid('ai-done-text').textContent = lines.join('\\n');\n      showToast('✅ AI整套样式已更新！');\n    });\n  };\n}\n\n// ============================================================\n// AI 调用\n// ============================================================\nfunction callAI(style, userDesc, callback){\n  var prompt = '你是CSS专家。用户选择了「'+style.name+'」风格（'+style.sub+'），现在想要调整：'+userDesc\n    +'\\n\\n请基于这个风格，重新生成4项内联CSS字符串（只含CSS属性，不含选择器和花括号）。'\n    +'\\n\\n严格按以下JSON格式返回，不要有任何其他文字：'\n    +'\\n{\"status\":\"CSS字符串\",\"quote\":\"CSS字符串\",\"bubble\":\"CSS字符串\",\"font\":\"CSS字符串\"}'\n    +'\\n\\n当前风格CSS参考：\\n状态栏: '+style.status.css+'\\n引号: '+style.quote.css+'\\n气泡: '+style.bubble.css+'\\n字体: '+style.font.css;\n\n  fetch('https://api.anthropic.com/v1/messages',{\n    method:'POST',\n    headers:{'Content-Type':'application/json'},\n    body:JSON.stringify({ model:'claude-sonnet-4-20250514', max_tokens:600,\n      messages:[{role:'user',content:prompt}] })\n  })\n  .then(function(r){ return r.json(); })\n  .then(function(data){\n    var text = (data.content&&data.content[0]&&data.content[0].text)||'';\n    text = text.trim().replace(/^```[a-z]*\\n?/i,'').replace(/```$/,'').trim();\n    callback(null, JSON.parse(text));\n  })\n  .catch(function(e){ callback(e,null); });\n}\n\n// ============================================================\n// 生成正则（4条）\n// ============================================================\nfunction generateRegex(){\n  var s = selStyle;\n  var suffix = (aiOverride ? 'AI微调·' : '') + s.name;\n  var statusCSS = getCSS('status');\n  var quoteCSS  = getCSS('quote');\n  var bubbleCSS = getCSS('bubble');\n  var fontCSS   = getCSS('font');\n  var qB = escAttr(getBefore()), qA = escAttr(getAfter());\n\n  return [\n    {\n      scriptName: '①状态栏 - '+suffix,\n      findRegex:  '(<status>[\\\\s\\\\S]*?</status>|【状态栏】[\\\\s\\\\S]*?【\\\\/状态栏】|(?:^|\\\\n)(?:HP|血量|生命|状态|角色状态)[：:].{0,150})',\n      replaceString: '<div style=\"'+statusCSS+'\">$1</div>'\n    },\n    {\n      scriptName: '②对话引号 - '+suffix,\n      findRegex:  '\"([^\"\\\\n]{1,300})\"',\n      replaceString: '<span style=\"'+quoteCSS+'\">'+qB+'$1'+qA+'</span>'\n    },\n    {\n      scriptName: '③聊天气泡 - '+suffix,\n      findRegex:  '\\\\*([^*\\\\n]{1,400})\\\\*',\n      replaceString: '<div style=\"'+bubbleCSS+'\">$1</div>'\n    },\n    {\n      scriptName: '④旁白字体 - '+suffix,\n      findRegex:  '【([^】]{1,300})】',\n      replaceString: '<span style=\"'+fontCSS+'\">【$1】</span>'\n    }\n  ];\n}\n\nfunction escAttr(s){\n  return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');\n}\n\n// ============================================================\n// 渲染结果页\n// ============================================================\nfunction renderResults(){\n  var regs = generateRegex();\n\n  // 最终预览\n  gid('final-preview').innerHTML = buildPreview();\n\n  // 正则列表\n  var html = '';\n  regs.forEach(function(r,i){\n    html += '<div class=\"result-section\"><div class=\"result-title\">'+r.scriptName+'</div>'\n          + '<div class=\"result-box\"><pre>查找：'+r.findRegex+'\\n替换：'+r.replaceString+'</pre>'\n          + '<button class=\"copy-btn\" data-idx=\"'+i+'\">复制</button></div></div>';\n  });\n  gid('regex-results').innerHTML = html;\n\n  qall('#regex-results .copy-btn').forEach(function(btn){\n    var i = parseInt(btn.getAttribute('data-idx'));\n    btn.onclick = function(){\n      var r = regs[i];\n      copyText('名称：'+r.scriptName+'\\n查找：'+r.findRegex+'\\n替换：'+r.replaceString, '✅ 已复制');\n    };\n  });\n\n  gid('btnCopyAll').onclick = function(){\n    copyText(regs.map(function(r){ return '=== '+r.scriptName+' ===\\n查找：'+r.findRegex+'\\n替换：'+r.replaceString; }).join('\\n\\n'), '✅ 已复制全部正则');\n  };\n\n  var ts = Date.now();\n  var jsonOut = JSON.stringify(regs.map(function(r,i){\n    return { id:'beauty_'+i+'_'+ts, scriptName:r.scriptName, findRegex:r.findRegex,\n      replaceString:r.replaceString, trimStrings:[], placement:[2], disabled:false,\n      markdownOnly:true, promptOnly:false, runOnEdit:false, substituteRegex:1,\n      minDepth:null, maxDepth:null };\n  }), null, 2);\n\n  gid('json-result').textContent = jsonOut;\n  gid('btnCopyJson').onclick = function(){ copyText(jsonOut, '✅ 已复制 JSON'); };\n}\n\n// ============================================================\n// 复制\n// ============================================================\nfunction copyText(text, toast){\n  function fb(){\n    var ta=document.createElement('textarea'); ta.value=text;\n    ta.style.cssText='position:fixed;top:0;left:0;opacity:0;pointer-events:none;';\n    document.body.appendChild(ta); ta.focus(); ta.select();\n    try{ document.execCommand('copy'); showToast(toast||'✅ 已复制'); }\n    catch(e){ showToast('❌ 复制失败，请手动长按'); }\n    document.body.removeChild(ta);\n  }\n  if(navigator.clipboard&&navigator.clipboard.writeText){\n    navigator.clipboard.writeText(text).then(function(){ showToast(toast||'✅ 已复制'); }).catch(fb);\n  } else { fb(); }\n}\n\n// ============================================================\n// 导航\n// ============================================================\ngid('nnx').addEventListener('click', function(){\n  if(!canNext) return;\n  if(gStep===0){\n    gStep=1; showSec('s1'); gid('nbk').className='nbk';\n    initS1(); setNext(true,'生成美化正则 ✨'); setDots(1);\n  } else if(gStep===1){\n    gStep=2; showSec('s2');\n    renderResults(); setNext(true,'重新配置'); setDots(2);\n  } else { resetAll(); }\n});\n\ngid('nbk').addEventListener('click', function(){\n  if(gStep===1){\n    gStep=0; showSec('s0'); gid('nbk').className='nbk hide';\n    setNext(!!selStyle, selStyle?'下一步 →':'选择风格开始'); setDots(0);\n  } else if(gStep===2){\n    gStep=1; showSec('s1'); initS1();\n    setNext(true,'生成美化正则 ✨'); setDots(1);\n  }\n});\n\ngid('btnReset').addEventListener('click', resetAll);\n\nfunction resetAll(){\n  gStep=0; selStyle=null; aiOverride=null; curCat='platform';\n  qall('#cat-tabs .cat-tab').forEach(function(t,i){ t.className='cat-tab'+(i===0?' on':''); });\n  buildGrid('platform');\n  showSec('s0'); gid('nbk').className='nbk hide';\n  setNext(false,'选择风格开始'); setDots(0);\n}\n</script>\n</body>\n</html>","trimStrings":[],"placements":["char"],"timing":"display","substitution":"none","minDepth":null,"maxDepth":null,"enabled":true}]}