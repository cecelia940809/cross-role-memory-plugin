{"id":39,"name":"24号美化生成器","entries":[{"identifier":"0398afc7-0cd2-4602-a42d-eb061fd6fa03","name":"美化","findRegex":"/【开场简介】/s","replaceString":"<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\n<title>24号正则美化室</title>\n<style>\n*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}\nhtml,body{min-height:100%;background:#FDF6FF;font-family:-apple-system,'PingFang SC','Hiragino Sans GB','Microsoft YaHei',sans-serif;color:#2D2D2D;-webkit-text-size-adjust:100%;}\nbutton{font-family:inherit;border:none;background:none;-webkit-appearance:none;appearance:none;cursor:pointer;touch-action:manipulation;outline:none;}\ninput,textarea{-webkit-appearance:none;appearance:none;font-family:inherit;}\n.app{max-width:480px;margin:0 auto;padding:0 14px 120px;}\n\n/* 头部 */\n.hd{text-align:center;padding:22px 0 14px;}\n.hd h1{font-size:24px;font-weight:900;background:linear-gradient(135deg,#C084FC,#F472B6,#FB923C);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-top:6px;}\n.hd p{color:#A78BFA;font-size:12.5px;margin-top:3px;font-weight:500;}\n.badge{display:inline-block;background:linear-gradient(135deg,#EDE9FE,#FCE7F3);border:1.5px solid #DDD6FE;border-radius:100px;padding:2px 10px;font-size:11px;color:#7C3AED;font-weight:600;margin-top:4px;}\n\n/* 步骤点 */\n.steps{display:flex;justify-content:center;align-items:center;gap:6px;margin-bottom:16px;}\n.dot{width:9px;height:9px;border-radius:50%;background:#E9D5FF;transition:all .3s;}\n.dot.active{background:linear-gradient(135deg,#A855F7,#EC4899);transform:scale(1.3);box-shadow:0 0 6px rgba(168,85,247,.4);}\n.dot.done{background:#34D399;}\n.sline{width:20px;height:2px;background:#E9D5FF;border-radius:1px;transition:background .3s;}\n.sline.done{background:#34D399;}\n\n/* 卡片 */\n.card{background:#fff;border-radius:18px;padding:16px;box-shadow:0 3px 16px rgba(168,85,247,.08);margin-bottom:12px;border:1px solid rgba(168,85,247,.06);}\n.ct{font-size:14px;font-weight:800;margin-bottom:14px;display:flex;align-items:center;gap:8px;color:#1F1F1F;}\n.ci{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}\n.sec{display:none;}.sec.on{display:block;}\n\n/* 分类Tab横向滚动 */\n.cat-tabs{display:flex;gap:6px;overflow-x:auto;padding-bottom:4px;margin-bottom:12px;scrollbar-width:none;}\n.cat-tabs::-webkit-scrollbar{display:none;}\n.cat-tab{flex-shrink:0;padding:5px 14px;border-radius:100px;font-size:11.5px;font-weight:700;border:1.5px solid #EDE9FE;background:#fff;color:#9333EA;transition:all .15s;white-space:nowrap;}\n.cat-tab.on{background:linear-gradient(135deg,#A855F7,#EC4899);color:#fff;border-color:transparent;box-shadow:0 2px 8px rgba(168,85,247,.3);}\n\n/* 风格卡片网格 */\n.style-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;}\n.scard{border:2px solid #EDE9FE;border-radius:16px;padding:13px 11px;background:#fff;transition:all .18s;cursor:pointer;position:relative;text-align:left;}\n.scard.on{border-color:#A855F7;background:#FAF5FF;box-shadow:0 0 0 3px rgba(168,85,247,.15);}\n.scard-check{position:absolute;top:8px;right:8px;width:18px;height:18px;border-radius:50%;background:linear-gradient(135deg,#A855F7,#EC4899);display:none;align-items:center;justify-content:center;font-size:10px;color:#fff;}\n.scard.on .scard-check{display:flex;}\n.scard-icon{font-size:26px;margin-bottom:5px;display:block;}\n.scard-name{font-size:12.5px;font-weight:800;color:#1F1F1F;margin-bottom:2px;}\n.scard-sub{font-size:10px;color:#AAA;line-height:1.4;}\n.scard-tags{display:flex;flex-wrap:wrap;gap:3px;margin-top:6px;}\n.stag{font-size:9px;padding:2px 6px;border-radius:100px;font-weight:600;}\n\n/* 预览区 */\n.preview-bg{background:#F8F5FF;border-radius:14px;padding:14px;border:1.5px solid #EDE9FE;margin-bottom:0;}\n.preview-row{margin-bottom:10px;}\n.preview-row:last-child{margin-bottom:0;}\n.preview-row-label{font-size:9.5px;font-weight:700;color:#A78BFA;margin-bottom:5px;letter-spacing:.3px;}\n\n/* AI区域 */\n.ai-area{margin-top:12px;}\n.ai-row{display:flex;gap:8px;align-items:flex-start;}\n.ai-row textarea{flex:1;border:2px solid #EDE9FE;border-radius:11px;padding:9px 12px;font-size:13px;color:#2D2D2D;background:#fff;outline:none;min-height:64px;resize:none;transition:border-color .15s;}\n.ai-row textarea:focus{border-color:#A855F7;}\n.ai-btn{flex-shrink:0;width:54px;padding:10px 6px;border-radius:10px;background:linear-gradient(135deg,#A855F7,#EC4899);color:#fff;font-size:11px;font-weight:800;text-align:center;line-height:1.5;box-shadow:0 2px 8px rgba(168,85,247,.3);transition:all .15s;}\n.ai-btn:active{transform:scale(.95);}\n.ai-btn.loading{background:linear-gradient(135deg,#C084FC,#F9A8D4);pointer-events:none;}\n.ai-done-box{margin-top:8px;background:#1E1B2E;border-radius:10px;padding:10px 12px;display:none;}\n.ai-done-box.on{display:block;}\n.ai-done-label{font-size:9.5px;color:#C4B5FD;font-weight:700;margin-bottom:3px;}\n.ai-done-text{font-size:9px;color:#7C6FAA;word-break:break-all;line-height:1.6;font-family:monospace;}\n\n/* 结果 */\n.result-box{background:#1E1B2E;border-radius:14px;padding:14px;margin-bottom:10px;position:relative;}\n.result-box pre{color:#E2D9F3;font-size:11px;line-height:1.7;white-space:pre-wrap;word-break:break-all;font-family:'Courier New',monospace;max-height:200px;overflow-y:auto;}\n.result-box pre::-webkit-scrollbar{width:3px;}\n.result-box pre::-webkit-scrollbar-thumb{background:#4C3D8A;border-radius:2px;}\n.copy-btn{position:absolute;top:10px;right:10px;background:rgba(168,85,247,.25);border:1px solid rgba(168,85,247,.4);color:#C4B5FD;border-radius:8px;padding:5px 10px;font-size:11px;font-weight:700;cursor:pointer;}\n.result-section{margin-bottom:10px;}\n.result-title{font-size:11px;font-weight:800;color:#7C3AED;margin-bottom:5px;display:flex;align-items:center;gap:4px;}\n.result-title::before{content:'';display:inline-block;width:3px;height:12px;background:linear-gradient(135deg,#A855F7,#EC4899);border-radius:2px;}\n\n/* 按钮 */\n.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:10px 16px;border-radius:100px;font-size:13px;font-weight:700;transition:all .15s;}\n.btn-main{background:linear-gradient(135deg,#A855F7,#EC4899);color:#fff;box-shadow:0 3px 12px rgba(168,85,247,.35);}\n.btn-out{background:#fff;border:2px solid #EDE9FE;color:#6D28D9;}\n.btn-full{width:100%;border-radius:12px;padding:13px;justify-content:center;}\n.tip-box{background:#FAF5FF;border:1.5px dashed #DDD6FE;border-radius:10px;padding:9px 12px;font-size:11.5px;color:#7C3AED;line-height:1.6;margin-bottom:12px;}\n.divider{height:1px;background:linear-gradient(to right,transparent,#EDE9FE,transparent);margin:12px 0;}\n.lbl{font-size:11px;font-weight:700;color:#9333EA;margin-bottom:5px;display:block;}\n.hide{display:none;}\n\n/* 底部导航 */\n.bn{position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1.5px solid #EDE9FE;padding:10px 14px;padding-bottom:calc(10px + env(safe-area-inset-bottom,0px));display:flex;gap:8px;z-index:9999;box-shadow:0 -4px 20px rgba(168,85,247,.06);}\n.nbk{flex:0 0 auto;padding:12px 16px;border-radius:11px;border:2px solid #EDE9FE;background:#fff;font-size:14px;font-weight:700;color:#6D28D9;}\n.nnx{flex:1;padding:13px;border-radius:11px;font-size:14px;font-weight:800;background:#E9D5FF;color:#C4B5FD;transition:all .2s;}\n.nnx.active{background:linear-gradient(135deg,#A855F7,#EC4899);color:#fff;box-shadow:0 3px 14px rgba(168,85,247,.4);}\n\n/* Toast */\n.toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%) translateY(10px);background:rgba(30,27,46,.92);color:#E2D9F3;padding:8px 18px;border-radius:100px;font-size:12px;z-index:99999;opacity:0;transition:all .25s;white-space:nowrap;pointer-events:none;border:1px solid rgba(168,85,247,.3);}\n.toast.on{opacity:1;transform:translateX(-50%) translateY(0);}\n\n/* 成功页 */\n.success-banner{text-align:center;padding:18px 0 10px;}\n.success-icon{font-size:52px;display:block;margin-bottom:8px;}\n.success-title{font-size:19px;font-weight:900;background:linear-gradient(135deg,#A855F7,#EC4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}\n.success-sub{font-size:12.5px;color:#9CA3AF;margin-top:3px;}\n\n/* 选中标识 */\n.sel-banner{background:linear-gradient(135deg,#F3E8FF,#FCE7F3);border-radius:12px;padding:10px 14px;display:flex;align-items:center;gap:10px;margin-bottom:12px;border:1.5px solid #DDD6FE;}\n.sel-banner-icon{font-size:24px;}\n.sel-banner-name{font-size:14px;font-weight:800;color:#6D28D9;}\n.sel-banner-sub{font-size:11px;color:#A78BFA;margin-top:1px;}\n</style>\n</head>\n<body>\n<div class=\"app\">\n  <div class=\"hd\">\n    <div style=\"font-size:38px\">✨</div>\n    <h1>24号正则美化室</h1>\n    <p>选一个整体风格，一键美化全部样式</p>\n    <span class=\"badge\">Tavo · 酒馆</span>\n  </div>\n\n  <div class=\"steps\">\n    <div class=\"dot active\" id=\"d0\"></div><div class=\"sline\" id=\"l0\"></div>\n    <div class=\"dot\" id=\"d1\"></div><div class=\"sline\" id=\"l1\"></div>\n    <div class=\"dot\" id=\"d2\"></div>\n  </div>\n\n  <!-- S0: 选风格 -->\n  <div class=\"sec on\" id=\"s0\">\n    <div class=\"card\">\n      <div class=\"ct\"><div class=\"ci\" style=\"background:#F3E8FF\">🎨</div>选择整体美化风格</div>\n      <div class=\"tip-box\">💡 选一个风格后，状态栏、引号、气泡、字体将自动统一为同一套设计</div>\n      <div class=\"cat-tabs\" id=\"cat-tabs\">\n        <button class=\"cat-tab on\" data-cat=\"platform\">平台风</button>\n        <button class=\"cat-tab\" data-cat=\"cute\">可爱系</button>\n        <button class=\"cat-tab\" data-cat=\"ancient\">古风系</button>\n        <button class=\"cat-tab\" data-cat=\"dark\">暗黑系</button>\n        <button class=\"cat-tab\" data-cat=\"romance\">浪漫系</button>\n        <button class=\"cat-tab\" data-cat=\"modern\">现代系</button>\n        <button class=\"cat-tab\" data-cat=\"scifi\">科幻系</button>\n      </div>\n      <div class=\"style-grid\" id=\"style-grid\"></div>\n    </div>\n  </div>\n\n  <!-- S1: 预览 + AI微调 -->\n  <div class=\"sec\" id=\"s1\">\n    <div class=\"card\">\n      <div class=\"ct\"><div class=\"ci\" style=\"background:#EDE9FE\">👁</div>整体效果预览</div>\n      <div class=\"sel-banner\" id=\"sel-banner\">\n        <span class=\"sel-banner-icon\" id=\"sel-icon\"></span>\n        <div>\n          <div class=\"sel-banner-name\" id=\"sel-name\"></div>\n          <div class=\"sel-banner-sub\" id=\"sel-sub\"></div>\n        </div>\n      </div>\n      <div class=\"preview-bg\" id=\"preview-area\"></div>\n    </div>\n\n    <div class=\"card\">\n      <div class=\"ct\"><div class=\"ci\" style=\"background:#FEF3C7\">✨</div>AI微调（选填）</div>\n      <div class=\"tip-box\" style=\"margin-bottom:10px\">描述你想调整的地方，AI会基于当前风格重新生成整套样式</div>\n      <div class=\"ai-row\">\n        <textarea id=\"ai-desc\" placeholder=\"例如：字体再大一点、背景换深蓝、引号改金色、整体更暗一些...\"></textarea>\n        <button class=\"ai-btn\" id=\"ai-gen-btn\">✨<br>生成</button>\n      </div>\n      <div class=\"ai-done-box\" id=\"ai-done-box\">\n        <div class=\"ai-done-label\">✨ AI已重新生成整套样式 —— 预览已更新</div>\n        <div class=\"ai-done-text\" id=\"ai-done-text\"></div>\n      </div>\n    </div>\n  </div>\n\n  <!-- S2: 导出 -->\n  <div class=\"sec\" id=\"s2\">\n    <div class=\"card\">\n      <div class=\"success-banner\">\n        <span class=\"success-icon\">🎉</span>\n        <div class=\"success-title\">美化正则已生成！</div>\n        <div class=\"success-sub\">复制后粘贴到酒馆正则脚本即可使用</div>\n      </div>\n    </div>\n\n    <div class=\"card\">\n      <div class=\"ct\"><div class=\"ci\" style=\"background:#EDE9FE\">👁</div>最终效果预览</div>\n      <div class=\"preview-bg\" id=\"final-preview\"></div>\n    </div>\n\n    <div class=\"card\">\n      <div class=\"ct\"><div class=\"ci\" style=\"background:#D1FAE5\">📋</div>正则脚本</div>\n      <div id=\"regex-results\"></div>\n      <div class=\"divider\"></div>\n      <button class=\"btn btn-main btn-full\" id=\"btnCopyAll\">📋 一键复制全部正则</button>\n    </div>\n\n    <div class=\"card\">\n      <div class=\"ct\"><div class=\"ci\" style=\"background:#FEF3C7\">🃏</div>JSON 格式（直接导入）</div>\n      <div class=\"result-box\" style=\"padding-bottom:10px;\">\n        <pre id=\"json-result\"></pre>\n      </div>\n      <button class=\"btn btn-main btn-full\" id=\"btnCopyJson\" style=\"margin-top:8px;\">📋 复制 JSON</button>\n    </div>\n\n    <button class=\"btn btn-out btn-full\" id=\"btnReset\" style=\"margin-bottom:10px;\">🔄 重新配置</button>\n  </div>\n</div>\n\n<div class=\"bn\">\n  <button class=\"nbk hide\" id=\"nbk\">← 返回</button>\n  <button class=\"nnx\" id=\"nnx\">选择风格开始</button>\n</div>\n<div class=\"toast\" id=\"tst\"></div>\n\n<script>\n// ============================================================\n// 整体风格数据\n// 每个风格包含 status / quote / bubble / font 四套CSS\n// ============================================================\nvar STYLES = [\n  // ── 平台风 ──\n  { id:'wechat', cat:'platform', icon:'💬', name:'微信风格', sub:'简洁圆润 · 温暖绿调',\n    tags:[{t:'平台',c:'#07C160',b:'#E8FFF2'},{t:'清新',c:'#555',b:'#F0F0F0'}],\n    status: { css:'font-family:sans-serif;color:#1A1A1A;background:#F0FFF4;border:1px solid #B7EAC9;border-radius:12px;padding:8px 14px;font-size:13px;', sample:'💚 HP: 满血 ── MP: 充足 ── 心情: 愉快' },\n    quote:  { css:'color:#111;font-weight:500;', before:'\\u201c', after:'\\u201d' },\n    bubble: { css:'background:#95EC69;border-radius:18px 18px 18px 4px;padding:10px 14px;color:#000;display:inline-block;max-width:90%;font-size:13px;', sample:'这是一条消息示例，绿色气泡很温暖~' },\n    font:   { css:'color:#555;font-size:13px;font-style:italic;', sample:'【他微微一笑，转身离去】' }\n  },\n  { id:'douyin', cat:'platform', icon:'🎵', name:'抖音风格', sub:'暗黑炫酷 · 霓虹科技',\n    tags:[{t:'平台',c:'#FE2C55',b:'#FFF0F2'},{t:'暗黑',c:'#ddd',b:'#333'}],\n    status: { css:'font-family:monospace;color:#FE2C55;background:#0D0D0D;border:1px solid #FE2C55;border-radius:8px;padding:8px 14px;font-size:12px;text-shadow:0 0 6px #FE2C55;', sa