{"id":203,"name":"孤单","entries":[{"identifier":"4833ecee-df6d-4fa0-8b9f-6c83dd0c2451","name":"删除思维链","findRegex":"/(<disclaimer>.*?</disclaimer>)|(<!--\\s*consider\\s*:\\s*(.*?)\\s*-->)|(.*?<OutputText>(\\n)?)|(.*?</think(ing)?>(\\n)?)|(<think(ing)?>[\\s\\S]*<\\/think(ing)?>(\\n)?)/gsi","replaceString":"<style>\n  .tp-panel { font: 14px system-ui, -apple-system, sans-serif; padding: 10px; border-radius: 10px; background: #1e1e22; color: #eee; max-width: 420px; }\n  .tp-panel h3 { margin: 0 0 8px; font-size: 15px; }\n  .tp-list { display: flex; flex-direction: column; gap: 4px; }\n  .tp-item { display: flex; align-items: center; justify-content: space-between; padding: 6px 10px; border-radius: 6px; background: #2a2a30; }\n  .tp-item.off { opacity: .45; }\n  .tp-item.dirty { outline: 1px solid #ffb74d; }\n  .tp-name { flex: 1; margin-right: 8px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n  .tp-tag { font-size: 11px; padding: 1px 6px; border-radius: 4px; background: #444; margin-right: 6px; }\n  .tp-toggle { appearance: none; width: 36px; height: 20px; background: #555; border-radius: 10px; position: relative; cursor: pointer; transition: background .15s; flex-shrink: 0; }\n  .tp-toggle:checked { background: #4caf50; }\n  .tp-toggle::after { content: ''; position: absolute; top: 2px; left: 2px; width: 16px; height: 16px; border-radius: 50%; background: #fff; transition: left .15s; }\n  .tp-toggle:checked::after { left: 18px; }\n  .tp-bar { display: flex; gap: 8px; margin-top: 8px; }\n  .tp-btn { flex: 1; padding: 7px 10px; border-radius: 6px; border: none; background: #4caf50; color: #fff; font-size: 14px; cursor: pointer; }\n  .tp-btn:disabled { background: #444; color: #888; cursor: not-allowed; }\n  .tp-btn.secondary { background: #555; flex: 0 0 auto; }\n  .tp-status { font-size: 12px; color: #888; margin-top: 6px; }\n</style>\n\n<div class=\"tp-panel\">\n  <h3>🎛️ 懒人版</h3>\n  <div class=\"tp-list\"></div>\n  <div class=\"tp-bar\">\n    <button class=\"tp-btn tp-save\" disabled>保存</button>\n    <button class=\"tp-btn secondary tp-reset\" disabled>撤销</button>\n  </div>\n  <div class=\"tp-status\"></div>\n</div>\n\n<script>\n(() => {\n  const root = document.currentScript.previousElementSibling;\n  const list = root.querySelector('.tp-list');\n  const status = root.querySelector('.tp-status');\n  const saveBtn = root.querySelector('.tp-save');\n  const resetBtn = root.querySelector('.tp-reset');\n\n  let currentPreset = null;\n  let visibleIds = [];\n  let originalEnabled = {};\n  let saving = false;\n  const MAX = 6;\n\n  const setStatus = (msg, color = '#888') => { status.textContent = msg; status.style.color = color; };\n\n  function dirtyIds() {\n    if (!currentPreset) return [];\n    return currentPreset.entries\n      .filter(e => visibleIds.includes(e.identifier) && originalEnabled.hasOwnProperty(e.identifier) && e.enabled !== originalEnabled[e.identifier])\n      .map(e => e.identifier);\n  }\n\n  function refreshDirtyUI() {\n    const dirty = dirtyIds();\n    saveBtn.disabled = dirty.length === 0 || saving;\n    resetBtn.disabled = dirty.length === 0 || saving;\n    saveBtn.textContent = dirty.length ? `保存 (${dirty.length} 项变更)` : '保存';\n    list.querySelectorAll('.tp-item').forEach(row => {\n      row.classList.toggle('dirty', dirty.includes(row.dataset.id));\n    });\n  }\n\n  async function init() {\n    try {\n      const presets = await tavo.preset.all();\n      if (!presets.length) { setStatus('无可用预设', '#f66'); return; }\n      currentPreset = await tavo.preset.get(Number(presets[0].id));\n      if (!currentPreset) { setStatus('预设不存在', '#f66'); return; }\n      const visible = currentPreset.entries.filter(e => e.active !== false && e.type !== 'marker');\n      visibleIds = visible.slice(0, MAX).map(e => e.identifier);\n      originalEnabled = {};\n      currentPreset.entries.forEach(e => {\n        if (visibleIds.includes(e.identifier)) originalEnabled[e.identifier] = !!e.enabled;\n      });\n      renderEntries();\n      setStatus(`显示前 ${visibleIds.length} 个条目（共 ${currentPreset.entries.length} 个）`);\n      refreshDirtyUI();\n    } catch (e) {\n      setStatus('加载失败: ' + e.message, '#f66');\n    }\n  }\n\n  function renderEntries() {\n    list.innerHTML = '';\n    currentPreset.entries.forEach(entry => {\n      if (!visibleIds.includes(entry.identifier)) return;\n\n      const row = document.createElement('div');\n      row.className = 'tp-item' + (entry.enabled ? '' : ' off');\n      row.dataset.id = entry.identifier;\n\n      const tag = document.createElement('span');\n      tag.className = 'tp-tag';\n      tag.textContent = entry.type === 'builtin' ? '内置' : '自定义';\n\n      const name = document.createElement('span');\n      name.className = 'tp-name';\n      name.textContent = entry.name || entry.identifier;\n      name.title = entry.identifier;\n\n      const tog = document.createElement('input');\n      tog.type = 'checkbox';\n      tog.className = 'tp-toggle';\n      tog.checked = !!entry.enabled;\n      tog.addEventListener('change', () => {\n        entry.enabled = tog.checked;\n        row.classList.toggle('off', !tog.checked);\n        refreshDirtyUI();\n      });\n\n      row.appendChild(tag);\n      row.appendChild(name);\n      row.appendChild(tog);\n      list.appendChild(row);\n    });\n  }\n\n  async function save() {\n    if (saving || !currentPreset) return;\n    const dirty = dirtyIds();\n    if (!dirty.length) return;\n    saving = true;\n    refreshDirtyUI();\n    setStatus('保存中…');\n    try {\n      await tavo.preset.update(currentPreset);\n      currentPreset.entries.forEach(e => {\n        if (visibleIds.includes(e.identifier)) originalEnabled[e.identifier] = !!e.enabled;\n      });\n      setStatus(`已保存 ${dirty.length} 项变更`, '#4caf50');\n    } catch (e) {\n      setStatus('保存失败: ' + e.message, '#f66');\n    } finally {\n      saving = false;\n      refreshDirtyUI();\n    }\n  }\n\n  function reset() {\n    if (!currentPreset) return;\n    currentPreset.entries.forEach(e => {\n      if (visibleIds.includes(e.identifier) && originalEnabled.hasOwnProperty(e.identifier)) {\n        e.enabled = originalEnabled[e.identifier];\n      }\n    });\n    renderEntries();\n    refreshDirtyUI();\n    setStatus('已撤销未保存变更');\n  }\n\n  saveBtn.addEventListener('click', save);\n  resetBtn.addEventListener('click', reset);\n  init();\n})();\n</script>","trimStrings":[],"placements":["char"],"timing":"sendAndDisplay","substitution":"escaped","minDepth":null,"maxDepth":null,"enabled":true}]}