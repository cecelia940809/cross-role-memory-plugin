{"id":84,"name":"透明美化","entries":[{"identifier":"dbfed94d-e3c0-42ea-96d4-e8bdd62370dd","name":"美化-正文","findRegex":"<content>([\\s\\S]*?)</content>","replaceString":"<style>\n@import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&display=swap');\n\n:root {\n  --bg-module: rgba(29, 31, 35, 0.7);\n  --color-text-secondary: #989da6;\n  --color-accent: #96A7BC;\n  --color-border: #68707a;\n  --font-main: 'Noto Serif SC', 'Source Han Serif CN', serif;\n  --font-size-base: 14px;\n  --border-radius: 6px;\n}\n\n.rp-container {\n  font-family: var(--font-main);\n  line-height: 1.7;\n  font-size: var(--font-size-base);\n  margin-bottom: 1.5rem;\n}\n\n.rp-container p {\n  margin: 0;\n}\n\n.rp-container strong {\n  font-weight: 700;\n  color: var(--color-accent);\n}\n\n.rp-container .content-container {\n  padding: 1.5rem 1.5rem 1.7rem 1.9rem;\n  border-radius: var(--border-radius);\n  background-color: var(--bg-module);\n  box-shadow: \n        0 8px 20px rgba(0, 0, 0, 0.4),\n        0 0 10px rgb(169, 198, 232) !important;\n    overflow: visible !important;\n    margin-left: 10px;\n    margin-right: 10px;\n    backdrop-filter: blur(7px);\n    -webkit-backdrop-filter: blur(7px);\n}\n\n.rp-container .content-container p {\n  margin: 1rem 0;\n}\n\n.scene-card {\n  background-color: rgba(0, 0, 0, 0.1);\n  border-radius: var(--border-radius);\n  padding: 0.8rem 1rem;\n  margin: 1rem auto 0 auto;\n  margin-top: 0.3rem;\n  font-size: 0.95em;\n  position: relative;\n  box-shadow: none !important;\n}\n\n.scene-card p {\n  margin: 0.4rem 0;\n  line-height: 1.6;\n}\n\n.scene-card .scene-divider {\n  height: 1px;\n  background: var(--color-border);\n  margin: 0.8rem 0;\n  opacity: 0.5;\n}\n\n.scene-item {\n  display: flex;\n  margin: 0.4rem 0;\n  align-items: center;\n}\n\n.scene-label {\n  flex-shrink: 0;\n  min-width: 70px;\n  padding-right: 8px;\n  text-align: right;\n}\n\n.scene-text {\n  flex: 1;\n  line-height: 1.6;\n}\n\n.scene-details {\n  margin: 0.5rem 0