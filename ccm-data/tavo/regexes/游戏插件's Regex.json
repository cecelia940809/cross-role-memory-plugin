{"id":295,"name":"游戏插件's Regex","entries":[{"identifier":"da6f09d5-ff05-4b6c-8eee-cd5297730769","name":"游戏插件启动","findRegex":"$","replaceString":"<script>\n(function(){\ntry{\n  var T; try{T=window.top||window}catch(_){T=window}\n  var D=T.document||document;\n  var KEY='gp_booted';\n  if(T[KEY])return;\n  T[KEY]=true;\n\n  var css=D.createElement('style');\n  css.textContent=[\n    '#gp-btn{position:fixed;bottom:160px;right:16px;z-index:9500;width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,rgba(34,197,94,0.92),rgba(6,182,212,0.88));border:1px solid rgba(120,230,200,0.5);box-shadow:0 4px 18px rgba(34,197,94,0.45);display:flex;align-items:center;justify-content:center;font-size:20px;cursor:pointer;backdrop-filter:blur(10px);transition:transform .15s;}',\n    '#gp-btn:hover{transform:scale(1.08);}',\n    '#gp-btn:active{transform:scale(0.95);}',\n    '#gp-mask{position:fixed;inset:0;z-index:9600;background:rgba(0,0,0,0.55);backdrop-filter:blur(2px);}',\n    '#gp-pop{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:9700;width:340px;max-width:92vw;max-height:88vh;background:rgba(10,16,18,0.97);border:1px solid rgba(34,197,150,0.35);border-radius:18px;padding:16px;overflow-y:auto;box-shadow:0 12px 40px rgba(0,0,0,0.6);color:#e2e8f0;}',\n    '.gp-title{font-size:15px;font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:6px;color:#86efac;}',\n    '#gp-close{position:absolute;top:12px;right:14px;font-size:18px;color:#94a3b8;cursor:pointer;background:none;border:none;}',\n    '#gp-toast{position:fixed;top:20px;left:50%;transform:translateX(-50%);background:rgba(16,20,38,0.95);color:#e2e8f0;padding:9px 18px;border-radius:20px;font-size:13px;z-index:10000;border:1px solid rgba(34,197,150,0.3);opacity:0;transition:opacity .25s;pointer-events:none;white-space:nowrap;}',\n    '#gp-toast.show{opacity:1;top:60px;transition:opacity .25s,top .25s;}',\n    /* spy game */\n    '.spy-players{display:flex;flex-wrap:wrap;gap:6px;margin:10px 0;}',\n    '.spy-chip{display:flex;align-items:center;gap:5px;padding:6px 10px;border-radius:9px;background:rgba(255,255,255,0.06);border:1.5px solid rgba(255,255,255,0.1);font-size:12px;}',\n    '.spy-chip.dead{opacity:0.35;text-decoration:line-through;}',\n    '.spy-chip.me{border-color:rgba(34,197,150,0.7);background:rgba(34,197,150,0.15);}',\n    '.spy-wordcard{background:linear-gradient(135deg,rgba(34,197,150,0.18),rgba(59,130,246,0.18));border:1.5px solid rgba(34,197,150,0.4);border-radius:14px;padding:16px;text-align:center;margin:10px 0;}',\n    '.spy-wordcard .w{font-size:22px;font-weight:900;color:#86efac;margin-top:4px;}',\n    '.spy-stepline{font-size:12.5px;color:#94a3b8;margin:8px 0;text-align:center;}',\n    '.spy-input{width:100%;min-height:60px;padding:9px 10px;border-radius:9px;border:1.5px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.05);color:#e2e8f0;font-size:12.5px;box-sizing:border-box;resize:vertical;}',\n    '.spy-vote-grid{display:flex;flex-direction:column;gap:6px;margin:10px 0;}',\n    '.spy-vote-opt{padding:10px 12px;border-radius:10px;background:rgba(255,255,255,0.05);border:1.5px solid rgba(255,255,255,0.08);font-size:13px;cursor:pointer;}',\n    '.spy-vote-opt:hover{background:rgba(248,113,113,0.18);}',\n    '.spy-vote-opt.sel{background:rgba(248,113,113,0.32);border-color:rgba(248,113,113,0.85);}',\n    '.spy-reveal-row{display:flex;justify-content:space-between;padding:8px 10px;border-radius:9px;background:rgba(255,255,255,0.04);margin-bottom:5px;font-size:12.5px;}',\n    '.spy-reveal-row.spy{color:#f87171;}',\n    '.spy-log{max-height:170px;overflow-y:auto;margin:8px 0;padding:8px 10px;border-radius:10px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);}',\n    '.spy-log-item{font-size:12px;line-height:1.55;margin-bottom:6px;color:#cbd5e1;}',\n    '.spy-log-item b{color:#86efac;margin-right:4px;}',\n    '.spy-log-item.out b{color:#f87171;}',\n    '.spy-log-empty{font-size:12px;color:#64748b;text-align:center;padding:6px 0;}',\n    '.spy-loading{font-size:12px;color:#64748b;text-align:center;padding:6px 0;}',\n    '.spy-spectator{font-size:12px;color:#facc15;text-align:center;background:rgba(250,204,21,0.12);border:1px solid rgba(250,204,21,0.3);border-radius:8px;padding:6px 8px;margin-bottom:8px;}',\n    '.spy-word-badge{display:flex;align-items:center;justify-content:center;gap:4px;font-size:12.5px;font-weight:700;color:#86efac;background:rgba(34,197,150,0.14);border:1px solid rgba(34,197,150,0.35);border-radius:9px;padding:6px 8px;margin-bottom:8px;}',\n    '#spy-go{width:100%;padding:11px;border:none;border-radius:10px;background:linear-gradient(135deg,#22c55e,#06b6d4);color:#fff;font-weight:700;cursor:pointer;margin-top:8px;}',\n    '#spy-go:disabled{opacity:0.5;cursor:not-allowed;}',\n  ].join('');\n  D.head.appendChild(css);\n\n  function mk(t,a,p){var e=D.createElement(t);Object.keys(a||{}).forEach(function(k){e[k]=a[k]});if(p)p.appendChild(e);return e;}\n  function rm(el){el&&el.parentNode&&el.parentNode.removeChild(el);}\n  function toast(msg,dur){\n    var el=D.getElementById('gp-toast')||mk('div',{id:'gp-toast'},D.body);\n    el.textContent=msg;el.classList.add('show');\n    clearTimeout(el._t);el._t=setTimeout(function(){el.classList.remove('show');},dur||2200);\n  }\n\n  function closePop(){rm(D.getElementById('gp-mask'));rm(D.getElementById('gp-pop'));}\n\n  /* ============ 谁是卧底 ============ */\n  var WORD_PAIRS=[\n    /* 食物饮品 */\n    ['苹果','梨'],['西瓜','哈密瓜'],['火锅','烧烤'],['咖啡','奶茶'],['面条','米饭'],\n    ['包子','饺子'],['豆浆','牛奶'],['蛋糕','面包'],['薯片','爆米花'],['冰淇淋','雪糕'],\n    ['白酒','啤酒'],['粽子','汤圆'],['烤鸭','烧鹅'],['寿司','刺身'],['泡面','拉面'],\n    /* 动物 */\n    ['猫','狗'],['狮子','老虎'],['乌龟','蜗牛'],['企鹅','海豹'],['蜜蜂','苍蝇'],\n    ['大象','犀牛'],['孔雀','天鹅'],['青蛙','蟾蜍'],['狐狸','狼'],['麻雀','燕子'],\n    ['蝴蝶','蜻蜓'],\n    /* 日常物品 */\n    ['雨伞','帽子'],['沙发','床'],['钢笔','毛笔'],['牙刷','牙签'],['镜子','照片'],\n    ['口罩','面具'],['热水袋','暖宝宝'],['滑板','自行车'],['手机','平板电脑'],\n    ['钥匙','门卡'],['背包','手提包'],['台灯','蜡烛'],['闹钟','手表'],['冰箱','冰柜'],\n    ['扫把','拖把'],['剪刀','小刀'],['橡皮','涂改液'],['订书机','胶带'],['插座','充电宝'],\n    /* 场所建筑 */\n    ['电影院','剧场'],['超市','便利店'],['图书馆','书店'],['医院','诊所'],['公园','广场'],\n    ['地铁站','公交站'],['幼儿园','小学'],['寺庙','教堂'],['菜市场','市集'],['电梯','扶梯'],\n    ['停车场','车库'],['游乐场','动物园'],['邮局','银行'],\n    /* 活动运动 */\n    ['篮球','排球'],['游泳','跑步'],['爬山','徒步'],['钓鱼','捕鱼'],['下棋','打牌'],\n    ['瑜伽','普拉提'],['滑雪','滑冰'],['露营','野餐'],['射箭','射击'],['跳绳','踢毽子'],\n    ['蹦极','跳伞'],\n    /* 情绪与抽象 */\n    ['开心','兴奋'],['害怕','紧张'],['孤独','寂寞'],['嫉妒','羡慕'],['感动','感激'],\n    /* 数码科技 */\n    ['耳机','音箱'],['打印机','复印机'],['路由器','交换机'],['键盘','鼠标'],['摄像头','麦克风'],\n    /* 自然天气 */\n    ['草原','沙漠'],['台风','地震'],['彩虹','极光'],['暴雨','冰雹'],['雾','霾'],\n    ['沙尘暴','龙卷风'],['露珠','霜'],\n    /* 职业 */\n    ['老师','教练'],['医生','护士'],['厨师','服务员'],['律师','法官'],['演员','导演'],\n    ['画家','摄影师'],['邮递员','快递员'],\n    /* 交通工具 */\n    ['飞机','火车'],['地铁','轻轨'],['出租车','网约车'],['帆船','游艇'],['直升机','热气球'],\n    ['电动车','摩托车'],\n    /* 节日 */\n    ['婚礼','葬礼'],['春节','元宵节'],['端午节','中秋节'],['圣诞节','万圣节'],['情人节','七夕节'],\n    /* 娱乐文化 */\n    ['吉他','钢琴'],['电影','电视剧'],['话剧','音乐剧'],['演唱会','音乐节'],['桌游','剧本杀'],\n    ['漫画','小说'],['公主','女王'],\n    /* 服饰 */\n    ['西装','衬衫'],['凉鞋','拖鞋'],['围巾','领带'],['帽子','头盔'],\n    /* 身体健康 */\n    ['感冒','过敏'],['近视','散光'],['牙痛','头痛'],\n    /* 植物 */\n    ['樱花','玫瑰'],['仙人掌','多肉'],['竹子','芦苇'],\n    /* 通讯书信 */\n    ['信件','邮件'],['日记','日历'],\n    /* 亲属称谓 */\n    ['爷爷','外公'],['姑姑','阿姨'],\n  ];\n  var SPY_STYLE_POOL=[\n    '你说话风格特别口语化，就像日常聊天随口说一句，说一件具体的小事或吐槽一下就行，别写成排比句或长句子，10-20字左右最好。',\n    '你说话风格很随性简短，一两个词或半句大白话带过就够了，不用讲究文采，越接地气越好。',\n    '你说话风格带点毒舌吐槽或调侃，一句话怼到点上就行，别铺垫，别解释原因。',\n    '你说话风格是那种随口一说的碎碎念语气，可以不是完整句子，想到什么说什么。',\n    '你说话风格偏理性直接，就事论事说一个具体细节或个人经历，不用比喻，别写太长。',\n    '你说话风格可以稍微有点画面感，但也要克制、简短，一句话就够，不要堆砌形容词，也不要用\"还顺手\"\"仿佛\"\"像是在诉说\"这种文绉绉的写法。',\n    '你说话风格是结合自己的生活习惯或职业背景来说，用\"我平时……\"\"我上次……\"这种角度，从你这个角色自己会经历的事情带出这个词的某个特点，别写成跟自己无关的客观场景描写。',\n  ];\n  var SPY_ANTI_AI_HINT='另外几点很重要：说人话，别写成小作文；不要用\"不是……而是……\"\"与其……不如……\"这类工整的对仗句式；不要用破折号或分号硬接好几层比喻/排比堆叠在一句话里；不要每句都追求\"金句感\"或刻意升华一个道理；越短越好，能一句话说完就不要写两句。';\n  var SPY_FALLBACK_LINES=[\n    '（…正在想怎么形容，先卖个关子）',\n    '（皱着眉想了想，一时没组织好语言）',\n    '（欲言又止，好像还在斟酌用词）',\n    '（沉默了两秒，像是在选合适的说法）',\n    '（挠了挠头，一时没想到贴切的比喻）',\n    '（顿了顿，示意大家先等等自己）',\n  ];\n  /* 描述生成失败时的兜底台词：同一局游戏内尽量不重复使用同一句 */\n  function spyPickFallbackLine(){\n    SPY.usedFallbacks = SPY.usedFallbacks || [];\n    var avail=SPY_FALLBACK_LINES.filter(function(l){ return SPY.usedFallbacks.indexOf(l)===-1; });\n    var pool=avail.length ? avail : SPY_FALLBACK_LINES;\n    var pick=pool[Math.floor(Math.random()*pool.length)];\n    SPY.usedFallbacks.push(pick);\n    return pick;\n  }\n  var SPY=null;\n\n  function withTimeout(promise, ms){\n    return new Promise(function(resolve, reject){\n      var timer=setTimeout(function(){ reject(new Error('超时（'+(ms/1000)+'s）')); }, ms);\n      promise.then(function(v){ clearTimeout(timer); resolve(v); }, function(e){ clearTimeout(timer); reject(e); });\n    });\n  }\n\n  function spyShuffle(arr){\n    var a=arr.slice();\n    for(var i=a.length-1;i>0;i--){ var j=Math.floor(Math.random()*(i+1)); var t=a[i];a[i]=a[j];a[j]=t; }\n    return a;\n  }\n  function spyAlive(){ return SPY.players.filter(function(p){return p.alive;}); }\n  function spyFindById(id){ return SPY.players.find(function(p){return String(p.id)===String(id);}); }\n  function spyMeAlive(){ var me=spyFindById('user'); return !!(me&&me.alive); }\n\n  function spyGetUsedPairIdx(){\n    try{\n      var raw=T.localStorage&&T.localStorage.getItem('tavo_spy_used_pairs');\n      if(raw){ var arr=JSON.parse(raw); if(Array.isArray(arr)) return arr; }\n    }catch(e){}\n    return T.__spyUsedPairIdx || [];\n  }\n  function spySaveUsedPairIdx(arr){\n    T.__spyUsedPairIdx=arr;\n    try{ T.localStorage&&T.localStorage.setItem('tavo_spy_used_pairs', JSON.stringify(arr)); }catch(e){}\n  }\n  function spyPickWordPair(){\n    var used=spyGetUsedPairIdx();\n    if(!Array.isArray(used) || used.length>=WORD_PAIRS.length){ used=[]; }\n    var avail=[];\n    for(var i=0;i<WORD_PAIRS.length;i++){ if(used.indexOf(i)===-1) avail.push(i); }\n    var idx=avail[Math.floor(Math.random()*avail.length)];\n    used.push(idx);\n    spySaveUsedPairIdx(used);\n    return WORD_PAIRS[idx];\n  }\n\n  async function spySetup(){\n    var chat=null; try{ chat=await tavo.chat.current(); }catch(e){}\n    var aiChars=(chat&&chat.characters)||[];\n    if(aiChars.length<2){\n      return {error:'谁是卧底至少需要 3 名玩家（你 + 至少 2 个角色），当前群聊里的角色不够，请先在群聊里多加几个角色。'};\n    }\n    var players=[{id:'user',name:'你（玩家）',isUser:true,alive:true}];\n    aiChars.forEach(function(c){ players.push({id:c.id,name:c.name,isUser:false,alive:true}); });\n    var total=players.length;\n    var spyCount = total>=7 ? 2 : 1;\n    var pair=spyPickWordPair();\n    var civilWord=pair[0], spyWord=pair[1];\n    var shuffled=spyShuffle(players.map(function(p){return p.id;}));\n    var spyIds=shuffled.slice(0,spyCount);\n    players.forEach(function(p){\n      p.isSpy = spyIds.indexOf(p.id)>-1;\n      p.word = p.isSpy ? spyWord : civilWord;\n      if(!p.isUser){ p.descStyle = SPY_STYLE_POOL[Math.floor(Math.random()*SPY_STYLE_POOL.length)]; }\n    });\n    return {players:players, civilWord:civilWord, spyWord:spyWord, spyCount:spyCount};\n  }\n\n  function spyAvatarText(p){ return p.isUser ? '🧑' : '🤖'; }\n\n  function renderSpyPlayers(container){\n    container.innerHTML='';\n    SPY.players.forEach(function(p){\n      var chip=mk('div',{className:'spy-chip'+(p.alive?'':' dead')+(p.isUser?' me':'')},container);\n      chip.textContent=spyAvatarText(p)+' '+p.name+(p.alive?'':'（已出局）');\n    });\n  }\n\n  function renderSpyLog(container){\n    var box=mk('div',{className:'spy-log'},container);\n    if(!SPY.log.length){\n      mk('div',{className:'spy-log-empty'},box).textContent='暂无发言记录';\n      return box;\n    }\n    SPY.log.forEach(function(item){\n      var row=mk('div',{className:'spy-log-item'+(item.out?' out':'')},box);\n      var b=mk('b',{},row); b.textContent='[第'+item.round+'轮] '+item.name+'：';\n      mk('span',{},row).textContent=item.text;\n    });\n    box.scrollTop=box.scrollHeight;\n    return box;\n  }\n\n  function renderSpySpectatorBanner(container){\n    if(!spyMeAlive()){\n      mk('div',{className:'spy-spectator'},container).textContent='👀 你已出局，正在旁观游戏进度';\n    }\n  }\n\n  function renderSpyWordBadge(container){\n    var me=spyFindById('user');\n    if(!me || !me.word) return;\n    mk('div',{className:'spy-word-badge'},container).textContent='🎯 我的词：'+me.word;\n  }\n\n  async function openSpy(){\n    closePop();\n    var mask=mk('div',{id:'gp-mask'},D.body);\n    mask.addEventListener('click',closePop);\n    var pop=mk('div',{id:'gp-pop'},D.body);\n    pop.addEventListener('click',function(e){e.stopPropagation();});\n    var closeBtn=mk('button',{id:'gp-close'},pop); closeBtn.innerHTML='✕'; closeBtn.addEventListener('click',closePop);\n    var title=mk('div',{className:'gp-title'},pop);\n    title.innerHTML='<span>🕵️</span><span>谁是卧底</span>';\n    var body=mk('div',{},pop);\n    body.textContent='正在读取当前群聊角色…';\n\n    var setup=await spySetup();\n    if(setup.error){\n      body.innerHTML='';\n      mk('div',{style:'color:#f87171;font-size:13px;line-height:1.6;'},body).textContent=setup.error;\n      return;\n    }\n    SPY={players:setup.players, civilWord:setup.civilWord, spyWord:setup.spyWord, round:0, phase:'intro', order:[], speakIndex:0, log:[], usedFallbacks:[]};\n    renderSpyIntro(body);\n  }\n\n  function renderSpyIntro(body){\n    body.innerHTML='';\n    mk('div',{className:'spy-stepline'},body).textContent='共 '+SPY.players.length+' 名玩家（含你），'+(SPY.players.filter(function(p){return p.isSpy;}).length)+' 名卧底。点击开始后系统会偷偷分配身份。投票时也可能把你投出局，出局后你可以继续旁观游戏进度。';\n    var playersBox=mk('div',{className:'spy-players'},body);\n    renderSpyPlayers(playersBox);\n    var go=mk('button',{id:'spy-go'},body); go.textContent='🎬 开始游戏，分配身份';\n    go.addEventListener('click',function(){\n      renderSpyWordReveal(body);\n    });\n  }\n\n  function renderSpyWordReveal(body){\n    body.innerHTML='';\n    var me=spyFindById('user');\n    mk('div',{className:'spy-stepline'},body).textContent='身份已偷偷分配好啦，只有你能看到自己的词：';\n    var card=mk('div',{className:'spy-wordcard'},body);\n    mk('div',{style:'font-size:12px;color:#94a3b8;'},card).textContent='你的词是';\n    mk('div',{className:'w'},card).textContent=me.word;\n    mk('div',{style:'font-size:11px;color:#64748b;margin-top:8px;'},card).textContent='（描述时不能直接说出这个词，要靠形容/联想让队友判断你是不是同类）';\n    var go=mk('button',{id:'spy-go'},body); go.textContent='👀 我记好了，开始第一轮';\n    go.addEventListener('click',function(){\n      SPY.round=1;\n      startSpyRound(body);\n    });\n  }\n\n  async function startSpyRound(body){\n    SPY.phase='describe';\n    var alive=spyAlive();\n    SPY.order=spyShuffle(alive.map(function(p){return p.id;}));\n    SPY.speakIndex=0;\n    await runSpyDescribeStep(body);\n  }\n\n  async function runSpyDescribeStep(body){\n    body.innerHTML='';\n    renderSpySpectatorBanner(body);\n    renderSpyWordBadge(body);\n    mk('div',{style:'font-size:13px;font-weight:700;color:#86efac;margin-bottom:6px;'},body).textContent='第 '+SPY.round+' 轮 · 轮流描述';\n    var playersBox=mk('div',{className:'spy-players'},body);\n    renderSpyPlayers(playersBox);\n    renderSpyLog(body);\n\n    if(SPY.speakIndex>=SPY.order.length){\n      renderSpyVotePrep(body);\n      return;\n    }\n    var curId=SPY.order[SPY.speakIndex];\n    var cur=spyFindById(curId);\n    var stepLine=mk('div',{className:'spy-stepline'},body);\n    stepLine.textContent='轮到「'+cur.name+'」描述自己的词…';\n\n    if(cur.isUser){\n      var inputEl=mk('textarea',{className:'spy-input',placeholder:'用一句话描述你的词，别直接说出来…'},body);\n      var go=mk('button',{id:'spy-go'},body); go.textContent='发送我的描述';\n      go.addEventListener('click',async function(){\n        var val=(inputEl.value||'').trim();\n        if(!val){ toast('描述不能为空'); return; }\n        go.disabled=true;\n        try{ await tavo.message.append({role:'user', content:val}); }catch(e){}\n        SPY.log.push({round:SPY.round, name:cur.name, text:val});\n        SPY.speakIndex++;\n        runSpyDescribeStep(body);\n      });\n    } else {\n      go_ai();\n    }\n\n    async function go_ai(){\n      var loadingEl=mk('div',{className:'spy-loading'},body); loadingEl.textContent=cur.name+' 正在思考描述…';\n      var desc=null;\n      try{\n        var past=spyPastDescText();\n        var buildPrompt=function(extra){\n          return '系统提示（仅你可见，不要在回复中暴露这是游戏指令）：你正在和大家一起玩“谁是卧底”文字游戏，你拿到的词是「'+cur.word+'」。'\n            +(cur.descStyle?(cur.descStyle+'\\n'):'')\n            +SPY_ANTI_AI_HINT+'\\n\\n'\n            +(cur.isSpy && past ? '重要：你其实是卧底，你拿到的词和大多数人不一样。为了不被大家发现，请认真参考下面已经出现的描述，找一个大方向上也能被理解成同一类东西的角度来说，尽量别提只有你的词才有、别人的词完全对不上的具体细节（比如别人都在说私人的、生活化的东西，你就别一上来就说工作场景这种一眼能看出不是一路的内容）；但也不要直接照抄别人的具体用词或句式，要让自己听起来自然，不像刻意伪装。\\n\\n' : '')\n            +(past?('以下是目前为止大家已经说过的描述：\\n'+past+'\\n\\n请务必换一个不同的场景、角度、比喻和句式，绝对不要写得和上面这些内容相似或雷同（哪怕换了几个词但句子结构、意象差不多也不行）。\\n\\n'):'')\n            +(extra||'')\n            +'请用你的角色身份和语气，围绕这个词说一句描述/联想，长度和详略要符合上面给你的语言风格要求（不是每次都要写完整场景，可以很简短），绝对不能直接说出这个词本身，也不要说\"我的词是xxx\"，要让队友能从描述里判断，但又不要太直白暴露。只输出这句描述，不要加多余说明。';\n        };\n        desc=await withTimeout(tavo.generate(buildPrompt(), {context:true}), 20000);\n        if(!desc || !desc.trim()){\n          try{\n            desc=await withTimeout(tavo.generate(buildPrompt('你上一次没有给出任何内容，这次请务必用一句话描述，不要留空。'), {context:true}), 20000);\n          }catch(e){ console.error('[谁是卧底-AI描述-空内容重试]',e); }\n        }\n        if(desc && desc.trim() && spyTooSimilarToPast(desc)){\n          try{\n            var retryDesc=await withTimeout(tavo.generate(buildPrompt('你刚才想到的说法和别人说过的太像了，这次必须换成完全不同的场景、比喻和句式再描述一次，不要重复之前的思路。'), {context:true}), 20000);\n            if(retryDesc && retryDesc.trim()){ desc=retryDesc; }\n          }catch(e){ console.error('[谁是卧底-AI描述-去重重试]',e); }\n        }\n        if(!desc || !desc.trim()){ desc=spyPickFallbackLine(); }\n        await tavo.message.append({role:'assistant', characterId:(typeof cur.id==='number'?cur.id:undefined), content:desc});\n      }catch(e){\n        console.error('[谁是卧底-AI描述]',e);\n        desc=spyPickFallbackLine();\n        try{ await tavo.message.append({role:'assistant', characterId:(typeof cur.id==='number'?cur.id:undefined), content:desc}); }catch(e2){}\n      }\n      rm(loadingEl);\n      SPY.log.push({round:SPY.round, name:cur.name, text:desc});\n      SPY.speakIndex++;\n      runSpyDescribeStep(body);\n    }\n  }\n\n  /* 用户已出局时的自动投票流程：不再显示任何\"进入投票/让大家投票\"按钮，\n     描述结束后直接自动开始统计投票并展示进度，用户只需要看结果 */\n  function renderSpyVoteAuto(body){\n    body.innerHTML='';\n    renderSpySpectatorBanner(body);\n    renderSpyWordBadge(body);\n    mk('div',{style:'font-size:13px;font-weight:700;color:#f87171;margin-bottom:6px;'},body).textContent='第 '+SPY.round+' 轮投票';\n    var playersBox=mk('div',{className:'spy-players'},body);\n    renderSpyPlayers(playersBox);\n    renderSpyLog(body);\n    var statusEl=mk('div',{id:'spy-go', className:'spy-stepline'},body);\n    statusEl.textContent='正在查看其他角色投票…';\n    (async function(){\n      try{\n        await resolveSpyVote(body, null);\n      }catch(err){\n        console.error('[谁是卧底-投票流程异常]',err);\n        toast('❌ 投票过程出错，已自动按已有结果继续');\n        spyContinueAfterVoteFail(body);\n      }\n    })();\n  }\n\n  function renderSpyVotePrep(body){\n    body.innerHTML='';\n    renderSpySpectatorBanner(body);\n    renderSpyWordBadge(body);\n    mk('div',{style:'font-size:13px;font-weight:700;color:#86efac;margin-bottom:6px;'},body).textContent='第 '+SPY.round+' 轮 · 大家都描述完了';\n    var playersBox=mk('div',{className:'spy-players'},body);\n    renderSpyPlayers(playersBox);\n    renderSpyLog(body);\n    mk('div',{className:'spy-stepline'},body).textContent = spyMeAlive()\n      ? '上面已经显示了这一轮大家的描述，想清楚了就开始投票吧。'\n      : '上面已经显示了这一轮大家的描述，你已出局不能投票，但可以进入投票查看大家的选择。';\n    var go=mk('button',{id:'spy-go'},body); go.textContent='🗳️ 进入投票';\n    go.addEventListener('click',function(){\n      if(spyMeAlive()){ renderSpyVote(body); } else { renderSpyVoteAuto(body); }\n    });\n  }\n\n  function renderSpyVote(body){\n    body.innerHTML='';\n    renderSpyWordBadge(body);\n    mk('div',{style:'font-size:13px;font-weight:700;color:#f87171;margin-bottom:6px;'},body).textContent='第 '+SPY.round+' 轮投票 · 选出你觉得最可疑的人';\n    renderSpyLog(body);\n\n    var alive=spyAlive();\n    var grid=mk('div',{className:'spy-vote-grid'},body);\n    var selected=null;\n    var opts={};\n    alive.filter(function(p){return p.id!=='user';}).forEach(function(p){\n      var opt=mk('div',{className:'spy-vote-opt'},grid);\n      opt.textContent=spyAvatarText(p)+' '+p.name;\n      opts[p.id]=opt;\n      opt.addEventListener('click',function(){\n        selected=p.id;\n        Object.keys(opts).forEach(function(k){opts[k].classList.toggle('sel', String(k)===String(p.id));});\n      });\n    });\n    var go=mk('button',{id:'spy-go'},body); go.textContent='确认投票';\n    go.addEventListener('click',async function(){\n      if(!selected){ toast('请先选一个人'); return; }\n      go.disabled=true; go.textContent='正在统计投票…';\n      try{\n        await resolveSpyVote(body, selected);\n      }catch(err){\n        console.error('[谁是卧底-投票流程异常]',err);\n        toast('❌ 投票过程出错，已自动按已有结果继续');\n        try{ var outP=spyFindById(selected); if(outP){ outP.alive=false; } }catch(e2){}\n        spyContinueAfterVoteFail(body);\n      }\n    });\n  }\n\n  function spyContinueAfterVoteFail(body){\n    var aliveNow=spyAlive();\n    var aliveSpiesNow=aliveNow.filter(function(p){return p.isSpy;});\n    if(aliveSpiesNow.length===0){ endSpyGame(body,'civil'); }\n    else if(aliveNow.length<=2){ endSpyGame(body,'spy'); }\n    else { SPY.round++; startSpyRound(body); }\n  }\n\n  /* 玩家名字里含有\"你（玩家）\"这种写法，如果原样嵌进第三人称叙述的提示词里，\n     模型容易把\"你\"误读成是在对它自己说话，导致角色说话人称错乱（比如把用户出局说成自己出局）。\n     所有会被拼进 generate() 提示词、用来\"叙述某个玩家怎么样\"的地方，都改用这个安全称呼。 */\n  function spyPromptName(name){\n    return name==='你（玩家）' ? '人类玩家' : name;\n  }\n\n  function spyPastDescText(){\n    var items=SPY.log.filter(function(item){ return !item.out; });\n    if(!items.length) return '';\n    return items.map(function(item){ return '「'+spyPromptName(item.name)+'」：\"'+item.text+'\"'; }).join('\\n');\n  }\n  function spyBigrams(s){\n    var set={};\n    for(var i=0;i<s.length-1;i++){ set[s.substr(i,2)]=true; }\n    return set;\n  }\n  function spySimilarity(a,b){\n    a=(a||'').replace(/[\\s，。；、！？“”\"'’‘…—-]/g,'');\n    b=(b||'').replace(/[\\s，。；、！？“”\"'’‘…—-]/g,'');\n    if(a.length<2||b.length<2) return 0;\n    var A=spyBigrams(a), B=spyBigrams(b);\n    var keysA=Object.keys(A), keysB=Object.keys(B);\n    var inter=0; keysA.forEach(function(k){ if(B[k]) inter++; });\n    var unionSet={}; keysA.concat(keysB).forEach(function(k){ unionSet[k]=true; });\n    var union=Object.keys(unionSet).length;\n    return union ? inter/union : 0;\n  }\n  function spyTooSimilarToPast(text){\n    var items=SPY.log.filter(function(item){ return !item.out; });\n    for(var i=0;i<items.length;i++){\n      if(spySimilarity(text, items[i].text)>=0.4) return true;\n    }\n    return false;\n  }\n\n  function spyRoundDescText(round){\n    var items=SPY.log.filter(function(item){ return item.round===round && !item.out; });\n    if(!items.length) return '（本轮没有可参考的描述）';\n    return items.map(function(item){ return '「'+spyPromptName(item.name)+'」：\"'+item.text+'\"'; }).join('\\n');\n  }\n\n  /* 从AI投票回复中匹配目标玩家：优先精确匹配角色名；对用户（名字是\"你（玩家）\"这种非常规写法，\n     AI很容易只回复\"你\"/\"玩家\"/\"用户\"而匹配不上，导致用户实际上几乎不会被投出局）额外做宽松匹配兜底 */\n  function spyMatchVote(resp, candidates){\n    if(!resp) return null;\n    var exact=candidates.find(function(p){ return resp.indexOf(p.name)>-1; });\n    if(exact) return exact;\n    var userCand=candidates.find(function(p){ return p.id==='user'; });\n    if(userCand){\n      var mentionsOther=candidates.some(function(p){ return p.id!=='user' && resp.indexOf(p.name)>-1; });\n      if(!mentionsOther){\n        var loose=['玩家','用户','你自己','投你','是你','选你','就是你','怀疑你'];\n        if(loose.some(function(al){ return resp.indexOf(al)>-1; })) return userCand;\n      }\n    }\n    return null;\n  }\n\n  async function resolveSpyVote(body, userVoteId){\n    var alive=spyAlive();\n    var votes={}; // targetId -> count\n    function addVote(t){ if(t==null)return; var k=String(t); votes[k]=(votes[k]||0)+1; }\n    addVote(userVoteId);\n\n    var goBtn=D.getElementById('spy-go');\n    var aliveNonUser=alive.filter(function(p){return p.id!=='user';});\n    for(var i=0;i<aliveNonUser.length;i++){\n      var voter=aliveNonUser[i];\n      if(goBtn) goBtn.textContent='正在让 '+voter.name+' 投票…（'+(i+1)+'/'+aliveNonUser.length+'）';\n      var candidates=alive.filter(function(p){return p.id!==voter.id;});\n      var names=candidates.map(function(p){return spyPromptName(p.name);}).join('、');\n      var pick=null;\n      try{\n        var prompt='系统提示（仅你可见）：你是「'+voter.name+'」，正在玩“谁是卧底”。本轮所有人的描述原文如下：\\n'+spyRoundDescText(SPY.round)+'\\n\\n'\n          +'请仔细比较大家描述的角度、用词和具体细节来判断谁最可疑，重点参考以下线索：\\n1）如果大多数人的描述指向同一类共同特征，而某个人的描述在措辞、侧重点或具体细节上明显不是一路（比如别人都强调某个共性，只有ta的说法完全不同、或用了很不一样的具体细节词），这个人更值得怀疑。\\n2）特别注意语义上的矛盾：如果某人描述的具体感官/功能特征（比如口感是甜还是苦、质地是软还是硬、用途是什么）和大多数人明显相反或对不上（比如别人都说甜的软的日常吃喝的东西，ta却说是苦的、提神用的），这是非常直接的矛盾信号，基本可以认定ta和大家拿到的不是同一个词，要重点怀疑，即使ta的话听起来很自然、说得也不少。\\n3）如果某人的描述是用\"不是……\"\"跟……没关系\"\"不算是\"\"说不清\"这类否定、回避的说法，却没有说出任何具体、正面的特征，这种回避型表达本身就是很强的可疑信号——正常玩家通常会主动说出至少一个具体细节，而不是绕开重点，请优先怀疑这样的人。\\n4）如果某人的描述空洞含糊、信息量极低，或者套在很多不同的东西上都说得通，也应该重点怀疑。\\n5）如果大家的描述都比较接近、看不出明显破绽，可以结合语气是否心虚、是否答非所问来判断。\\n不要因为某人是\"用户\"或者\"玩家\"就手下留情或者刻意回避投给ta，只要ta的发言符合上述可疑特征，也应该正常投给ta——用词/感官/功能明显对不上的矛盾信号，比\"发言自然、听起来合理\"更重要，请优先依据矛盾和不合群程度来判断，不要因为对方说得流畅就放弃怀疑。\\n\\n请按以下格式回答：\\n第一行：用不超过30字说明你怀疑谁、为什么（重点指出矛盾点或不合群之处）。\\n第二行：以\"投给：\"开头，只写你最终选择的那个人的名字，不要加任何其他文字。\\n可选玩家（必须从中选一个）：'+names;\n        var resp=await withTimeout(tavo.generate(prompt, {context:true}), 20000);\n        var voteLineMatch=resp && resp.match(/投给[：:]\\s*([^\\n]+)/);\n        pick = voteLineMatch ? spyMatchVote(voteLineMatch[1], candidates) : null;\n        if(!pick) pick=spyMatchVote(resp, candidates);\n      }catch(e){ console.error('[谁是卧底-AI投票]',e,'(已超时或失败，自动随机投票兜底)'); }\n      if(!pick){ pick=candidates[Math.floor(Math.random()*candidates.length)]; }\n      addVote(pick.id);\n    }\n    if(goBtn) goBtn.textContent='正在统计投票…';\n\n    var maxCount=-1, tied=[];\n    Object.keys(votes).forEach(function(id){\n      if(votes[id]>maxCount){ maxCount=votes[id]; tied=[id]; }\n      else if(votes[id]===maxCount){ tied.push(id); }\n    });\n    var outId=tied[Math.floor(Math.random()*tied.length)];\n    var outP=spyFindById(outId);\n    outP.alive=false;\n    var outIsUser = outP.id==='user';\n\n    try{\n      await tavo.message.append({role:'user', content: outIsUser ? '🗳️ 投票结果：你被投出局了！' : ('🗳️ 投票结果：「'+outP.name+'」被投出局了。')});\n    }catch(e){}\n    SPY.log.push({round:SPY.round, name:'系统', text:(outIsUser?'你被投票出局了。':('「'+outP.name+'」被投票出局了。')), out:true});\n\n    var aliveNow=spyAlive();\n    var aliveSpies=aliveNow.filter(function(p){return p.isSpy;});\n\n    body.innerHTML='';\n    renderSpySpectatorBanner(body);\n    renderSpyWordBadge(body);\n    mk('div',{style:'font-size:13px;font-weight:700;color:#f87171;margin-bottom:6px;'},body).textContent = outIsUser ? '💥 你被投出局了！可以继续旁观游戏进度' : ('「'+outP.name+'」被投出局了');\n    var playersBox=mk('div',{className:'spy-players'},body);\n    renderSpyPlayers(playersBox);\n    renderSpyLog(body);\n\n    if(aliveSpies.length===0){\n      endSpyGame(body,'civil');\n    } else if(aliveNow.length<=2){\n      endSpyGame(body,'spy');\n    } else {\n      var go=mk('button',{id:'spy-go'},body); go.textContent='▶ 进入下一轮';\n      go.addEventListener('click',function(){\n        SPY.round++;\n        startSpyRound(body);\n      });\n    }\n  }\n\n  function endSpyGame(body, winner){\n    body.innerHTML='';\n    var banner=mk('div',{style:'text-align:center;font-size:18px;font-weight:900;margin:10px 0;color:'+(winner==='civil'?'#86efac':'#f87171')+';'},body);\n    banner.textContent = winner==='civil' ? '🎉 平民阵营获胜！' : '🕵️ 卧底阵营获胜！';\n    mk('div',{style:'font-size:12px;color:#94a3b8;text-align:center;margin-bottom:10px;'},body).textContent='平民词：'+SPY.civilWord+'　|　卧底词：'+SPY.spyWord;\n    SPY.players.forEach(function(p){\n      var row=mk('div',{className:'spy-reveal-row'+(p.isSpy?' spy':'')},body);\n      mk('span',{},row).textContent=spyAvatarText(p)+' '+p.name+(p.alive?'':'（已出局）');\n      mk('span',{},row).textContent=(p.isSpy?'🕵️ 卧底':'👤 平民')+' · '+p.word;\n    });\n    try{\n      tavo.message.append({role:'user', content:'游戏结束！'+(winner==='civil'?'平民阵营获胜！':'卧底阵营获胜！')+' 揭晓：平民词「'+SPY.civilWord+'」，卧底词「'+SPY.spyWord+'」。'});\n    }catch(e){}\n    var go=mk('button',{id:'spy-go'},body); go.textContent='🔄 再来一局';\n    go.addEventListener('click',function(){ openSpy(); });\n  }\n\n  function buildButton(){\n    if(D.getElementById('gp-btn'))return;\n    var btn=mk('div',{id:'gp-btn',title:'谁是卧底'},D.body);\n    btn.textContent='🕵️';\n    btn.addEventListener('click',function(e){\n      e.stopPropagation();\n      if(D.getElementById('gp-pop')) closePop();\n      else openSpy();\n    });\n  }\n  buildButton();\n  console.log('[游戏插件v18] 已加载');\n\n}catch(e){console.error('[游戏插件]',e);}\n})();\n</script>\n","trimStrings":[],"placements":["user"],"timing":"display","substitution":"none","minDepth":null,"maxDepth":null,"enabled":true}]}