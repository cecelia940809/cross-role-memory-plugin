{"id":280,"name":"记忆整理插件's Regex","entries":[{"identifier":"7dc6668c-10eb-4cec-b1cf-fe6e79eb838f","name":"记忆整理插件启动","findRegex":"$","replaceString":"<script>\n(function(){\ntry{\n  var T; try{T=window.top||window}catch(_){T=window}\n  var D=T.document||document;\n  var KEY='cm_booted';\n  if(T[KEY])return;\n  T[KEY]=true;\n\n  var css=D.createElement('style');\n  css.textContent=[\n    '#cm-btn{',\n      'position:fixed;bottom:90px;right:16px;z-index:9500;',\n      'width:48px;height:48px;border-radius:50%;',\n      'background:linear-gradient(135deg,rgba(100,50,220,0.92),rgba(150,80,255,0.88));',\n      'border:1px solid rgba(180,120,255,0.5);',\n      'box-shadow:0 4px 18px rgba(120,60,255,0.45);',\n      'display:flex;align-items:center;justify-content:center;',\n      'font-size:20px;cursor:pointer;backdrop-filter:blur(10px);',\n      'transition:transform .15s,box-shadow .15s;',\n    '}',\n    '#cm-btn:hover{transform:scale(1.08);box-shadow:0 6px 24px rgba(140,70,255,0.6);}',\n    '#cm-btn:active{transform:scale(0.95);}',\n    '#cm-mask{position:fixed;inset:0;z-index:9600;background:rgba(0,0,0,0.45);backdrop-filter:blur(2px);}',\n    '#cm-pop{',\n      'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);',\n      'z-index:9700;width:340px;max-width:90vw;max-height:75vh;',\n      'background:rgba(14,10,28,0.97);border:1px solid rgba(130,80,255,0.35);',\n      'border-radius:18px;padding:18px 20px;overflow-y:auto;',\n      'box-shadow:0 12px 40px rgba(0,0,0,0.6);',\n    '}',\n    '#cm-pop .cm-title{color:#c4b5fd;font-size:15px;font-weight:700;margin-bottom:6px;display:flex;align-items:center;gap:6px;}',\n    '#cm-pop .cm-sub{color:#94a3b8;font-size:12px;margin-bottom:14px;line-height:1.5;}',\n    '#cm-pop .cm-stat{display:flex;justify-content:space-between;background:rgba(255,255,255,0.05);border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;color:#e2e8f0;}',\n    '#cm-pop .cm-stat b{color:#c4b5fd;}',\n    '#cm-list{max-height:220px;overflow-y:auto;margin-bottom:14px;}',\n    '.cm-item{font-size:12px;color:#cbd5e1;background:rgba(255,255,255,0.04);border-radius:8px;padding:7px 10px;margin-bottom:5px;line-height:1.4;}',\n    '#cm-go{width:100%;padding:11px;border:none;border-radius:10px;background:linear-gradient(135deg,#8b5cf6,#6366f1);color:#fff;font-size:13px;font-weight:700;cursor:pointer;margin-bottom:8px;}',\n    '#cm-go:disabled{opacity:.5;cursor:not-allowed;}',\n    '#cm-cancel{width:100%;padding:9px;border:1px solid rgba(255,255,255,0.12);border-radius:10px;background:transparent;color:#94a3b8;font-size:12px;cursor:pointer;}',\n    '#cm-toast{position:fixed;top:20px;left:50%;transform:translateX(-50%);background:rgba(20,16,40,0.95);color:#e2e8f0;padding:9px 18px;border-radius:20px;font-size:13px;z-index:10000;border:1px solid rgba(130,80,255,0.3);opacity:0;transition:opacity .25s;pointer-events:none;white-space:nowrap;}',\n    '#cm-toast.show{opacity:1;top:60px;transition:opacity .25s,top .25s;}',\n  ].join('');\n  D.head.appendChild(css);\n\n  function mk(t,a,p){var e=D.createElement(t);Object.keys(a||{}).forEach(function(k){e[k]=a[k]});if(p)p.appendChild(e);return e;}\n  function rm(el){el&&el.parentNode&&el.parentNode.removeChild(el);}\n\n  function toast(msg,dur){\n    var el=D.getElementById('cm-toast')||mk('div',{id:'cm-toast'},D.body);\n    el.textContent=msg;el.classList.add('show');\n    clearTimeout(el._t);\n    el._t=setTimeout(function(){el.classList.remove('show');},dur||2500);\n  }\n\n  function closePop(){rm(D.getElementById('cm-mask'));rm(D.getElementById('cm-pop'));}\n\n  function buildConfirmPop(memories){\n    closePop();\n    var mask=mk('div',{id:'cm-mask'},D.body);\n    mask.addEventListener('click',closePop);\n\n    var pop=mk('div',{id:'cm-pop'},D.body);\n    pop.addEventListener('click',function(e){e.stopPropagation();});\n\n    var title=mk('div',{className:'cm-title'},pop);\n    title.innerHTML='<span>🧹</span><span>记忆整理</span>';\n\n    var sub=mk('div',{className:'cm-sub'},pop);\n    sub.textContent='将识别重复或相似的记忆条目并合并精简，不会丢失任何独特信息。';\n\n    var stat=mk('div',{className:'cm-stat'},pop);\n    stat.innerHTML='当前记忆条数 &nbsp;<b>'+memories.length+'</b> 条';\n\n    var list=mk('div',{id:'cm-list'},pop);\n    memories.forEach(function(m){\n      var item=mk('div',{className:'cm-item'},list);\n      item.textContent=m;\n    });\n\n    var go=mk('button',{id:'cm-go'},pop);\n    go.textContent='开始整理';\n    go.addEventListener('click',function(){ doConsolidate(memories,go); });\n\n    var cancel=mk('button',{id:'cm-cancel'},pop);\n    cancel.textContent='取消';\n    cancel.addEventListener('click',closePop);\n  }\n\n  function buildResultPop(before,after,newMemories){\n    closePop();\n    var mask=mk('div',{id:'cm-mask'},D.body);\n    mask.addEventListener('click',closePop);\n\n    var pop=mk('div',{id:'cm-pop'},D.body);\n    pop.addEventListener('click',function(e){e.stopPropagation();});\n\n    var title=mk('div',{className:'cm-title'},pop);\n    title.innerHTML='<span>✅</span><span>整理完成</span>';\n\n    var stat=mk('div',{className:'cm-stat'},pop);\n    stat.innerHTML=before+' 条 → <b>'+after+'</b> 条';\n\n    var list=mk('div',{id:'cm-list'},pop);\n    newMemories.forEach(function(m){\n      var item=mk('div',{className:'cm-item'},list);\n      item.textContent=m;\n    });\n\n    var go=mk('button',{id:'cm-go'},pop);\n    go.textContent='完成';\n    go.addEventListener('click',closePop);\n  }\n\n  async function doConsolidate(memories,btn){\n    btn.disabled=true;\n    btn.textContent='整理中…';\n    try{\n      var memoryList=memories.map(function(m,i){return (i+1)+'. '+m;}).join('\\n');\n\n      var prompt='以下是当前的记忆列表：\\n'+memoryList+'\\n\\n'+\n        '请识别其中重复、高度相似或可合并的条目，将它们合并为更精简的表达。\\n'+\n        '要求：\\n'+\n        '1. 保留所有独特信息，不丢失任何事实\\n'+\n        '2. 相同或近义的内容合并为一条，措辞更精炼\\n'+\n        '3. 不矛盾的不同条目都保留，不要合并不相关的内容\\n'+\n        '4. 输出格式：每行一条，\"- \"开头，不要编号，不要任何解释或前言\\n'+\n        '5. 如果没有需要合并的内容，原样输出所有条目';\n\n      var result=await tavo.generate(prompt,{context:false});\n\n      var newMemories=result.split('\\n')\n        .map(function(line){return line.replace(/^-\\s*/,'').trim();})\n        .filter(function(line){return line.length>0;});\n\n      if(newMemories.length===0){\n        toast('❌ 整理结果为空，已取消保存');\n        closePop();\n        return;\n      }\n\n      var memory=await tavo.memory.current();\n      var before=memory.memories.length;\n      memory.memories=newMemories;\n      await tavo.memory.update(memory);\n\n      buildResultPop(before,newMemories.length,newMemories);\n    }catch(err){\n      console.error('[记忆整理]',err);\n      toast('❌ 失败：'+(err&&err.message||String(err)));\n      closePop();\n    }\n  }\n\n  async function openConsolidate(){\n    try{\n      var memory=await tavo.memory.current();\n      if(!memory.memories||memory.memories.length===0){\n        toast('当前没有记忆可整理');\n        return;\n      }\n      buildConfirmPop(memory.memories);\n    }catch(err){\n      console.error('[记忆整理]',err);\n      toast('❌ 读取记忆失败：'+(err&&err.message||String(err)));\n    }\n  }\n\n  function buildButton(){\n    if(D.getElementById('cm-btn'))return;\n    var btn=mk('div',{id:'cm-btn',title:'整理记忆'},D.body);\n    btn.textContent='🧹';\n    btn.addEventListener('click',function(e){\n      e.stopPropagation();\n      openConsolidate();\n    });\n  }\n\n  buildButton();\n  console.log('[记忆整理插件v1] 已加载');\n\n}catch(e){console.error('[记忆整理插件]',e);}\n})();\n</script>","trimStrings":[],"placements":["user"],"timing":"display","substitution":"none","minDepth":null,"maxDepth":null,"enabled":true},{"identifier":"7cdd51f2-a9a8-4aec-9d8b-6216ca9d8650","name":"记忆整理指令清理","findRegex":"/<CM_CMD>[\\s\\S]*?<\\/CM_CMD>/gi","replaceString":"","trimStrings":[],"placements":["char"],"timing":"display","substitution":"none","minDepth":null,"maxDepth":null,"enabled":true}]}